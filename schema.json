      "cleveland_browns": "browns",
      "dallas_cowboys": "cowboys",
      "denver_broncos": "broncos",
      "detroit_lions": "lions",
      "green_bay_packers": "packers",
      "houston_texans": "texans",
      "indianapolis_colts": "colts",
      "jacksonville_jaguars": "jaguars",
      "kansas_city_chiefs": "chiefs",
