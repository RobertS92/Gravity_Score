      "tampa_bay_buccaneers": "buccaneers",
      "tennessee_titans": "titans",
      "washington_commanders": "commanders"
    }
  },
  "data_quality_rules": {
    "description": "Data quality validation rules",
    "player_validation": {
      "required_fields": ["name", "team", "position"],
      "name_validation": {
        "min_length": 2,
        "max_length": 100,
        "pattern": "^[A-Za-z\\s\\-'.\\.]+$"
      },
      "jersey_number_validation": {
        "unique_per_team": true,
        "valid_range": [0, 99]
      },
      "social_media_validation": {
        "handle_format": "^[a-zA-Z0-9_.]+$",
        "follower_count_range": [0, 100000000]
      }
    },
    "team_validation": {
      "required_fields": ["name", "city", "division", "conference"],
      "record_validation": {
        "total_games_max": 17,
        "wins_plus_losses_plus_ties_equals_games_played": true
      }
    }
  },
  "export_formats": {
    "description": "Supported export formats and their schemas",
    "parquet": {
      "compression": "snappy",
      "schema_evolution": "backward_compatible",
      "nullable_fields": true
    },
    "csv": {
      "encoding": "utf-8",
      "delimiter": ",",
      "quote_char": "\"",
      "null_representation": "",
      "compression": "gzip"
    },
    "json": {
      "encoding": "utf-8",
      "pretty_print": true,
      "null_representation": null
    }
  },
  "version_history": {
    "1.0.0": {
      "release_date": "2024-01-01",
      "changes": [
        "Initial schema definition",
        "Player and team data models",
