{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NFL Gravity Data Schema",
  "description": "Complete data schema for NFL Gravity pipeline outputs",
  "version": "1.0.0",
  "generated_at": "2024-01-01T00:00:00Z",
  "definitions": {
    "player_data": {
      "type": "object",
      "title": "NFL Player Data Schema",
      "description": "Comprehensive schema for NFL player information",
      "required": ["name", "team", "position"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Full player name",
          "minLength": 1,
          "maxLength": 100,
          "examples": ["Patrick Mahomes", "Tom Brady", "Aaron Rodgers"]
        },
        "team": {
          "type": "string",
          "description": "NFL team name (lowercase)",
          "enum": [
            "49ers", "bears", "bengals", "bills", "broncos", "browns", "buccaneers",
            "cardinals", "chargers", "chiefs", "colts", "commanders", "cowboys",
            "dolphins", "eagles", "falcons", "giants", "jaguars", "jets", "lions",
            "packers", "panthers", "patriots", "raiders", "rams", "ravens",
            "saints", "seahawks", "steelers", "texans", "titans", "vikings"
          ]
        },
        "position": {
          "type": "string",
          "description": "Player position abbreviation",
          "enum": [
            "QB", "RB", "FB", "WR", "TE", "LT", "LG", "C", "RG", "RT",
            "DE", "DT", "NT", "OLB", "ILB", "MLB", "CB", "S", "FS", "SS",
            "K", "P", "LS", "KR", "PR"
          ]
        },
        "jersey_number": {
          "type": ["integer", "null"],
          "description": "Jersey number",
          "minimum": 0,
          "maximum": 99
        },
        "height": {
          "type": ["string", "null"],
          "description": "Player height in feet-inches format",
          "pattern": "^\\d+'\\d+\"$|^\\d+\\.\\d+$",
          "examples": ["6'3\"", "5'10\"", "6.25"]
        },
        "weight": {
          "type": ["integer", "null"],
          "description": "Player weight in pounds",
          "minimum": 100,
          "maximum": 500
        },
        "age": {
          "type": ["integer", "null"],
          "description": "Player age in years",
          "minimum": 18,
          "maximum": 50
        },
        "birth_date": {
          "type": ["string", "null"],
          "description": "Birth date in ISO format",
          "format": "date"
        },
        "college": {
          "type": ["string", "null"],
          "description": "College or university attended",
          "maxLength": 100
        },
        "draft_year": {
          "type": ["integer", "null"],
          "description": "NFL Draft year",
          "minimum": 1936,
          "maximum": 2030
        },
        "draft_round": {
          "type": ["integer", "null"],
          "description": "Draft round",
          "minimum": 1,
          "maximum": 7
        },
        "draft_pick": {
          "type": ["integer", "null"],
          "description": "Overall draft pick number",
          "minimum": 1,
          "maximum": 300
        },
        "years_pro": {
          "type": ["integer", "null"],
          "description": "Years as professional player",
          "minimum": 0,
          "maximum": 30
        },
        "games_played": {
          "type": ["integer", "null"],
          "description": "Games played in current season",
          "minimum": 0,
          "maximum": 20
        },
        "games_started": {
          "type": ["integer", "null"],
          "description": "Games started in current season",
          "minimum": 0,
          "maximum": 20
        },
        "twitter_handle": {
          "type": ["string", "null"],
          "description": "Twitter username without @ symbol",
          "maxLength": 50,
          "pattern": "^[a-zA-Z0-9_]+$"
        },
        "instagram_handle": {
          "type": ["string", "null"],
          "description": "Instagram username without @ symbol",
          "maxLength": 50,
          "pattern": "^[a-zA-Z0-9_.]+$"
        },
        "twitter_followers": {
          "type": ["integer", "null"],
          "description": "Number of Twitter followers",
          "minimum": 0
        },
        "instagram_followers": {
          "type": ["integer", "null"],
          "description": "Number of Instagram followers",
          "minimum": 0
        },
        "wikipedia_url": {
          "type": ["string", "null"],
          "description": "Wikipedia page URL",
          "format": "uri",
          "pattern": "^https://en\\.wikipedia\\.org/wiki/"
        },
        "career_highlights": {
          "type": ["array", "null"],
          "description": "List of career highlights and achievements",
          "items": {
            "type": "string",
            "maxLength": 200
          },
          "maxItems": 50
        },
        "awards": {
          "type": ["array", "null"],
          "description": "List of awards and honors",
          "items": {
            "type": "string",
            "maxLength": 200
          },
          "maxItems": 50
        },
        "data_source": {
          "type": ["string", "null"],
          "description": "Primary data source for this record",
          "enum": ["nfl.com", "espn.com", "pro-football-reference.com", "wikipedia", "social_media", "test"]
        },
        "scraped_at": {
          "type": ["string", "null"],
          "description": "Timestamp when data was scraped",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "team_data": {
      "type": "object",
      "title": "NFL Team Data Schema",
      "description": "Comprehensive schema for NFL team information",
      "required": ["name", "city", "division", "conference"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Full team name",
          "minLength": 1,
          "maxLength": 50,
          "examples": ["Kansas City Chiefs", "New England Patriots", "San Francisco 49ers"]
        },
        "city": {
          "type": "string",
          "description": "Team city",
          "minLength": 1,
          "maxLength": 50
        },
        "division": {
          "type": "string",
          "description": "NFL division",
          "enum": [
            "AFC North", "AFC South", "AFC East", "AFC West",
            "NFC North", "NFC South", "NFC East", "NFC West"
          ]
        },
        "conference": {
          "type": "string",
          "description": "NFL conference",
          "enum": ["AFC", "NFC"]
        },
        "founded": {
          "type": ["integer", "null"],
          "description": "Year team was founded",
          "minimum": 1920,
          "maximum": 2030
        },
        "stadium": {
          "type": ["string", "null"],
          "description": "Home stadium name",
          "maxLength": 100
        },
        "head_coach": {
          "type": ["string", "null"],
          "description": "Current head coach name",
          "maxLength": 100
        },
        "wins": {
          "type": ["integer", "null"],
          "description": "Current season wins",
          "minimum": 0,
          "maximum": 17
        },
        "losses": {
          "type": ["integer", "null"],
          "description": "Current season losses",
          "minimum": 0,
          "maximum": 17
        },
        "ties": {
          "type": ["integer", "null"],
          "description": "Current season ties",
          "minimum": 0,
          "maximum": 17
        },
        "twitter_handle": {
          "type": ["string", "null"],
          "description": "Official Twitter handle",
          "maxLength": 50,
          "pattern": "^[a-zA-Z0-9_]+$"
        },
        "instagram_handle": {
          "type": ["string", "null"],
          "description": "Official Instagram handle",
          "maxLength": 50,
          "pattern": "^[a-zA-Z0-9_.]+$"
        },
        "official_website": {
          "type": ["string", "null"],
          "description": "Official team website URL",
          "format": "uri"
        },
        "data_source": {
          "type": ["string", "null"],
          "description": "Primary data source for this record",
          "enum": ["nfl.com", "espn.com", "team_social_media", "test"]
        },
        "scraped_at": {
          "type": ["string", "null"],
          "description": "Timestamp when data was scraped",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "pipeline_metadata": {
      "type": "object",
      "title": "Pipeline Execution Metadata",
      "description": "Metadata about pipeline execution and data quality",
      "properties": {
        "extraction_timestamp": {
          "type": "string",
          "description": "Pipeline execution timestamp",
          "format": "date-time"
        },
        "nfl_gravity_version": {
          "type": "string",
          "description": "Version of NFL Gravity used",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "record_counts": {
          "type": "object",
          "properties": {
            "players": {
              "type": "integer",
              "minimum": 0
            },
            "teams": {
              "type": "integer",
              "minimum": 0
            },
            "total_records": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "data_sources": {
          "type": "object",
          "description": "Count of records by data source",
          "patternProperties": {
            "^[a-zA-Z0-9._-]+$": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "team_coverage": {
          "type": "object",
          "description": "Number of players found per team",
          "patternProperties": {
            "^[a-zA-Z0-9]+$": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "position_distribution": {
          "type": "object",
          "description": "Distribution of player positions",
          "patternProperties": {
            "^[A-Z]{1,3}$": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "extraction_summary": {
          "type": "object",
          "properties": {
            "teams_with_players": {
              "type": "integer",
              "description": "Number of teams with at least one player",
              "minimum": 0
            },
            "players_with_social_media": {
              "type": "integer",
              "description": "Players with social media information",
              "minimum": 0
            },
            "players_with_wikipedia": {
              "type": "integer",
              "description": "Players with Wikipedia pages",
              "minimum": 0
            },
            "avg_fields_per_player": {
              "type": "number",
              "description": "Average number of fields per player record",
              "minimum": 0
            }
          }
        }
      }
    }
  },
  "type": "object",
  "properties": {
    "players": {
      "type": "array",
      "description": "Array of NFL player records",
      "items": {
        "$ref": "#/definitions/player_data"
      }
    },
    "teams": {
      "type": "array",
      "description": "Array of NFL team records",
      "items": {
        "$ref": "#/definitions/team_data"
      }
    },
    "metadata": {
      "$ref": "#/definitions/pipeline_metadata"
    }
  },
  "field_mappings": {
    "description": "Common field mappings for data transformation",
    "height_formats": {
      "feet_inches": "6'3\"",
      "decimal_feet": "6.25",
      "centimeters": "191"
    },
    "weight_formats": {
      "pounds": "230",
      "kilograms": "104"
    },
    "team_abbreviations": {
      "arizona_cardinals": "cardinals",
      "atlanta_falcons": "falcons",
      "baltimore_ravens": "ravens",
      "buffalo_bills": "bills",
