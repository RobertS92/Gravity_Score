modules = ["python-3.11", "postgresql-16", "python3", "nodejs-20"]

[nix]
channel = "stable-24_05"
packages = ["arrow-cpp", "glibcLocales", "libxcrypt", "pkg-config", "xcodebuild", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "NFL Gravity Web App"

[[workflows.workflow]]
name = "NFL Gravity Web App"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python app.py"
waitForPort = 5000

[[ports]]
localPort = 3000
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 44591
externalPort = 3000

[deployment]
deploymentTarget = "cloudrun"
run = ["sh", "-c", "python app.py"]

[agent]
expertMode = true
