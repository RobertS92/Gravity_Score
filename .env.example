# Database (Supabase Postgres connection string)
PG_DSN=postgresql://user:password@host:5432/gravity

# --- Scraping (in-process via gravity_api; gravity-scrapers sibling optional) ---
# Run jobs locally:
#   PYTHONPATH=. python3 -m gravity_api.jobs.roster_sync
#   PYTHONPATH=. python3 -m gravity_api.jobs.nightly_pipeline
#   PYTHONPATH=. python3 -m gravity_api.jobs.bulk_scrape_pipeline --scrape --score
# Firecrawl: set key OR leave empty / DISABLE_FIRECRAWL=1 to skip paid scrapes.
DISABLE_FIRECRAWL=0
FIRECRAWL_API_KEY=
# Optional extended scrapers (google trends, on3 NIL, transfer portal, etc.)
SCRAPE_EXTENDED=0
# Roster sync defaults (ESPN team ids, comma-separated)
ROSTER_SYNC_DEFAULT_SPORT=cfb
ROSTER_SYNC_DEFAULT_TEAM_IDS=
ROSTER_SYNC_SPORTS=cfb,ncaab_mens,ncaab_womens,ncaa_baseball,ncaa_volleyball,nfl,nba,wnba
CURRENT_STATS_SEASON=

# Legacy sibling scrapers service (deprecated — leave unset in production)
SCRAPERS_SERVICE_URL=
SCRAPERS_SERVICE_API_KEY=
# gravity_api: copy the two SCRAPERS_* lines into the API env so GET /v1/operations/dashboard can proxy job status/progress.
# https://github.com/RobertS92/gravity-ml (if you expose HTTP inference)
ML_SERVICE_URL=
ML_SERVICE_API_KEY=
# Optional: Redis for scraper priority queues (gravity-scrapers); gravity_api reads REDIS_URL for future wiring.
REDIS_URL=

# APIs
# College Football Data API (cfbd_api_stats scraper; https://collegefootballdata.com)
CFBD_API_KEY=
# CFBD API free tier is ~1000 requests/month. Per-process counters (restart clears run counter).
CFBD_MAX_REQUESTS_PER_MONTH=950
# Limit CFBD calls per audit run; 0 career depth = 2 calls/athlete (search + current season).
CFBD_MAX_CALLS_PER_RUN=900
CFBD_CAREER_DEPTH=0
CFBD_REQUEST_DELAY_MS=250
CFBD_RATE_LIMIT_COOLDOWN_SECS=120
# Serialize CFBD HTTP calls (audit uses concurrency>1 for Firecrawl scrapers).
CFBD_MAX_CONCURRENT_REQUESTS=1
FIRECRAWL_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=
PASSWORD_RESET_WEBHOOK_URL=
PASSWORD_RESET_TTL_MINUTES=30

# App
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
# Comma-separated, exact-match origins (no trailing slash, no spaces around commas).
# Browsers send Origin without a trailing slash; CORS must match exactly.
CORS_ORIGINS=http://localhost:5173,https://www.gravityscore.ai,https://gravityscore.ai
# Required for Bearer auth: login, register, onboarding, /me, /v1/user/preferences.
JWT_SECRET=
# Password hashing for POST /v1/auth/register (bcrypt; see requirements-gravity-api.txt).
# Required for POST /v1/scores/athletes/{id}/sync-from-ml (append score row from gravity-ml).
GRAVITY_INTERNAL_API_KEY=
# Partner API (/v2/partner) — bootstrap key for dev; production keys live in partner_api_keys.
GRAVITY_PARTNER_API_KEY=
GRAVITY_PARTNER_API_RATE_LIMIT_PER_MINUTE=600
# When JWT_SECRET is set and this is 0/false, watchlist/alerts ignore ?user_id= (Bearer only).
GRAVITY_ALLOW_QUERY_USER_ID=1

# gravity-terminal
VITE_API_URL=http://localhost:8000

# --- railway-service/ (separate deploy; see railway-service/app/config.py) ---
# API_KEY=
# PORT=8000
# CORS_ORIGINS=["https://your-app.lovable.app","http://localhost:5173"]
# Optional: omit both if this deploy has no Supabase (API still starts; DB routes return 503).
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
# PERPLEXITY_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# FIRECRAWL_API_KEY=
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
