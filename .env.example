# Database (Supabase Postgres connection string)
PG_DSN=postgresql://user:password@host:5432/gravity

# Sibling services (see docs/SCRAPER_EXHAUSTIVE.md)
# https://github.com/RobertS92/gravity-scrapers
SCRAPERS_SERVICE_URL=
# Must match gravity-scrapers SCRAPER_API_KEY exactly (local .env + Railway Variables).
# POST /jobs/* returns {"detail":"Unauthorized"} if missing, wrong, or different length.
SCRAPERS_SERVICE_API_KEY=
# gravity_api: copy the two SCRAPERS_* lines into the API env so GET /v1/operations/dashboard can proxy job status/progress.
# https://github.com/RobertS92/gravity-ml (if you expose HTTP inference)
ML_SERVICE_URL=
ML_SERVICE_API_KEY=
# Optional: Redis for scraper priority queues (gravity-scrapers); gravity_api reads REDIS_URL for future wiring.
REDIS_URL=

# APIs
FIRECRAWL_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=

# App
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,https://gravity.yourdomain.com
# Required for Bearer auth: login, register, onboarding, /me, /v1/user/preferences.
JWT_SECRET=
# Password hashing for POST /v1/auth/register (bcrypt; see requirements-gravity-api.txt).
# Required for POST /v1/scores/athletes/{id}/sync-from-ml (append score row from gravity-ml).
GRAVITY_INTERNAL_API_KEY=
# When JWT_SECRET is set and this is 0/false, watchlist/alerts ignore ?user_id= (Bearer only).
GRAVITY_ALLOW_QUERY_USER_ID=1

# gravity-terminal
VITE_API_URL=http://localhost:8000

# --- railway-service/ (separate deploy; see railway-service/app/config.py) ---
# API_KEY=
# PORT=8000
# CORS_ORIGINS=["https://your-app.lovable.app","http://localhost:5173"]
# Optional: omit both if this deploy has no Supabase (API still starts; DB routes return 503).
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
# PERPLEXITY_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# FIRECRAWL_API_KEY=
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
