# Gravity FastAPI — must be reachable; `/v1` is appended automatically if missing
# Examples: http://localhost:8000  OR  https://api.example.com/v1
VITE_API_URL=http://localhost:8000

# false = real API + DB (scrapers/ML data). true = browser fixtures only (no backend) — not for production
VITE_USE_MOCKS=false

# Optional static Bearer token (e.g. shared API key). Session token in localStorage overrides when set.
VITE_API_BEARER_TOKEN=

# Fallback UUID when not logged in (watchlist/alerts ?user_id=). Prefer JWT: POST /v1/auth/login, store access_token as gravity_access_token.
VITE_TERMINAL_USER_ID=

# Prefer server-side agent: leave empty and use VITE_AGENT_USE_PROXY=true
VITE_ANTHROPIC_API_KEY=

# Use gravity_api POST /v1/agent/complete (Anthropic key on server only)
VITE_AGENT_USE_PROXY=true

# Supabase Realtime — enables live score updates and event feed without polling
# Get from: Supabase dashboard → Settings → API → Project URL and anon public key
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
