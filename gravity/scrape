    def _fill_missing_fields(self, player_data: PlayerData, llm_data: Dict, missing_fields: List[str]) -> int:
        """
        Fill missing fields in player_data from llm_data
        
        Returns:
            Number of fields successfully filled
        """
        filled_count = 0
        
        for field_path in missing_fields:
            try:
                # Parse field path (e.g., "identity.height")
                parts = field_path.split('.')
                if len(parts) != 2:
                    continue
                
                section_name, field_name = parts
                
                # Get the data section
                if section_name == "identity":
                    section = player_data.identity
                    # Map LLM field names to identity fields
                    llm_field_map = {
                        "height": "height",
                        "weight": "weight",
                        "jersey_number": "jersey_number",
                        "college": "college",
                        "birth_date": "birth_date",
                        "age": "age",
                        "draft_year": "draft_year",
                        "draft_round": "draft_round",
                        "draft_pick": "draft_pick",
                        "hometown": "hometown",
                        "years_in_league": "years_in_league"
                    }
                    
                    llm_field = llm_field_map.get(field_name)
                    if llm_field and llm_data.get(llm_field):
                        value = llm_data[llm_field]
                        
                        # Type conversion based on field
                        if field_name in ["weight", "jersey_number", "age", "draft_year", "draft_round", "draft_pick", "years_in_league"]:
                            try:
                                value = int(value) if isinstance(value, (int, str)) and str(value).isdigit() else None
                            except:
                                value = None
                        
                        if value and not getattr(section, field_name, None):
                            setattr(section, field_name, value)
                            filled_count += 1
                            logger.debug(f"✓ Filled {field_path} = {value}")
                
                elif section_name == "brand":
                    section = player_data.brand
                    # Similar mapping for brand fields
                    llm_field_map = {
                        "instagram_followers": "instagram_followers",
                        "twitter_followers": "twitter_followers",
                        "tiktok_followers": "tiktok_followers",
                        "youtube_subscribers": "youtube_subscribers"
                    }
                    
                    llm_field = llm_field_map.get(field_name)
                    if llm_field and llm_data.get(llm_field):
                        value = llm_data[llm_field]
                        try:
                            value = int(value) if isinstance(value, (int, str)) and str(value).replace(',', '').isdigit() else None
                        except:
                            value = None
                        
                        if value and not getattr(section, field_name, None):
                            setattr(section, field_name, value)
                            filled_count += 1
                            logger.debug(f"✓ Filled {field_path} = {value}")
                
                elif section_name == "proof":
                    section = player_data.proof
                    # Handle stats fields
                    if field_name == "stats" and (llm_data.get("career_stats") or llm_data.get("current_season_stats")):
                        if llm_data.get("career_stats") and not section.career_stats:
                            section.career_stats = llm_data["career_stats"]
                            filled_count += 1
                        if llm_data.get("current_season_stats") and not section.current_season_stats:
                            section.current_season_stats = llm_data["current_season_stats"]
                            filled_count += 1
            except Exception as e:
                logger.debug(f"Error filling field {field_path}: {e}")
                continue
        
        return filled_count
    
    def _is_field_filled(self, player_data: PlayerData, field_path: str) -> bool:
        """Check if a field is filled (not null/empty)"""
        try:
            parts = field_path.split('.')
            if len(parts) != 2:
                return False
            
            section_name, field_name = parts
            section = getattr(player_data, section_name, None)
            
            if not section:
                return False
            
            value = getattr(section, field_name, None)
            
            # Check if value is filled
            if value is None:
                return False
            if isinstance(value, str) and not value.strip():
                return False
            if isinstance(value, (list, dict)) and len(value) == 0:
                return False
            
            return True
        except:
            return False
    
    def _collect_brand(self, player_name: str) -> BrandData:
        """
        Collect brand/social media data.
        Uses Firecrawl for finding handles, FREE APIs for follower counts.
        """
        brand = BrandData()
        
        # Step 1: Find social media handles
        # Try Firecrawl first, fallback to FREE DuckDuckGo search
        social_handles = {}
        firecrawl_available = hasattr(self, 'scraper') and hasattr(self.scraper, 'api_key') and self.scraper.api_key and self.scraper.api_key != "fc-test"
        
        logger.info(f"🔍 Starting social media collection for {player_name}")
        logger.info(f"   Firecrawl available: {firecrawl_available}")
        
        if firecrawl_available:
            try:
                logger.info(f"🔍 Finding social media handles for {player_name} (Firecrawl)...")
                
                ig_handle = self.social_collector.find_social_handle(player_name, 'instagram')
                if ig_handle:
                    brand.instagram_handle = ig_handle
                    social_handles["instagram"] = ig_handle
                
                tw_handle = self.social_collector.find_social_handle(player_name, 'twitter')
                if tw_handle:
                    brand.twitter_handle = tw_handle
                    social_handles["twitter"] = tw_handle
                
                tt_handle = self.social_collector.find_social_handle(player_name, 'tiktok')
                if tt_handle:
                    brand.tiktok_handle = tt_handle
                    social_handles["tiktok"] = tt_handle
                
                yt_handle = self.social_collector.find_social_handle(player_name, 'youtube')
                if yt_handle:
                    brand.youtube_channel = yt_handle
                    
            except Exception as e:
                logger.debug(f"Firecrawl search failed: {e}")
        
        # Fallback to FREE Enhanced Multi-Source search if Firecrawl not available or failed
        if not social_handles:
            try:
                from gravity.enhanced_social_collector import EnhancedSocialCollector
                
                logger.info(f"🔍 Using Enhanced Multi-Source collector for {player_name}...")
                
                # Get position and team for validation
