    def export_both(self, player_data: PlayerData, base_filename: str = None) -> Tuple[str, str]:
        """Export player data to both JSON and CSV files"""
        if not base_filename:
            base_filename = player_data.player_name.replace(' ', '_')
        
        json_file = self.export_to_json(player_data, f"{base_filename}_{datetime.now().strftime('%Y%m%d_%H%M%S')}.json")
        csv_file = self.export_to_csv(player_data, f"{base_filename}_{datetime.now().strftime('%Y%m%d_%H%M%S')}.csv")
        
        logger.info(f"Data exported to JSON: {json_file} and CSV: {csv_file}")
        return json_file, csv_file
    
    def export_multiple_to_csv(self, player_data_list: List[PlayerData], filename: str = None) -> str:
        """Export multiple players to a single CSV file"""
        if not filename:
            filename = f"nfl_players_{datetime.now().strftime('%Y%m%d_%H%M%S')}.csv"
        
        # Use output folder if set
        if hasattr(self, 'output_folder') and self.output_folder:
            filename = os.path.join(self.output_folder, os.path.basename(filename))
        
        if not player_data_list:
            logger.warning("No player data to export")
            return filename
        
        # Flatten all players
        all_flat_data = [self._flatten_player_data(p) for p in player_data_list]
        
        # Get union of all fieldnames
        all_fieldnames = set()
        for flat_data in all_flat_data:
            all_fieldnames.update(flat_data.keys())
        fieldnames = sorted(all_fieldnames)
        
        # Write CSV
        with open(filename, 'w', newline='', encoding='utf-8') as f:
            writer = csv.DictWriter(f, fieldnames=fieldnames)
            writer.writeheader()
            for flat_data in all_flat_data:
                # Fill missing fields with empty string
                row = {field: flat_data.get(field, '') for field in fieldnames}
                writer.writerow(row)
        
        logger.info(f"Exported {len(player_data_list)} players to CSV: {filename}")
        return filename


