    def _extract_number_multi(self, text: str, patterns: List[str]) -> Optional[int]:
        """Try multiple patterns to extract a number"""
        for pattern in patterns:
            value = self._extract_number(text, pattern)
            if value is not None:
                return value
        return None
    
    def _extract_weekly_stats(self, text: str, year: str, position: str) -> List[Dict]:
        """Extract weekly stats for current season (for velocity calculation)"""
        weekly_stats = []
        
        # Look for game log or weekly stats section
        game_log_patterns = [
            r'Game Log[^\n]*(.*?)(?:\n\n[A-Z]|\n\d{4}|$)',
            r'Weekly Stats[^\n]*(.*?)(?:\n\n[A-Z]|\n\d{4}|$)',
            rf'{year}[^\n]*Game[^\n]*(.*?)(?:\n\n[A-Z]|\n\d{4}|$)'
        ]
        
        game_log_text = ""
        for pattern in game_log_patterns:
            match = re.search(pattern, text, re.IGNORECASE | re.DOTALL)
            if match:
                game_log_text = match.group(1)
                break
        
        if not game_log_text:
            return weekly_stats
        
        # Extract individual game stats
        # Pattern: Week number, opponent, stats
        game_patterns = [
            rf'Week\s+(\d+)[^\n]*([^\n]+)\n([^\n]+)',  # Week X, Opponent, Stats line
            rf'(\d+)[^\n]*@?\s*([A-Z][^\n]+)\n([^\n]+)',  # Number, Opponent, Stats
        ]
        
        for pattern in game_patterns:
            matches = re.finditer(pattern, game_log_text, re.IGNORECASE | re.MULTILINE)
            for match in matches:
                week_num = match.group(1)
                opponent = match.group(2).strip() if len(match.groups()) > 1 else ""
                stats_line = match.group(3).strip() if len(match.groups()) > 2 else match.group(2).strip()
                
                # Extract position-specific stats from stats line
                game_stats = {'week': int(week_num), 'opponent': opponent}
                
                if position == 'QB':
                    game_stats['pass_yards'] = self._extract_number(stats_line, r'(\d+)[,\s]+yds?')
                    game_stats['pass_tds'] = self._extract_number(stats_line, r'(\d+)[,\s]+tds?')
                    game_stats['interceptions'] = self._extract_number(stats_line, r'(\d+)[,\s]+ints?')
                elif position == 'RB':
                    game_stats['rush_yards'] = self._extract_number(stats_line, r'(\d+)[,\s]+yds?')
                    game_stats['rush_tds'] = self._extract_number(stats_line, r'(\d+)[,\s]+tds?')
                    game_stats['receptions'] = self._extract_number(stats_line, r'(\d+)[,\s]+rec')
                elif position in ['WR', 'TE']:
                    game_stats['rec_yards'] = self._extract_number(stats_line, r'(\d+)[,\s]+yds?')
                    game_stats['receptions'] = self._extract_number(stats_line, r'(\d+)[,\s]+rec')
                    game_stats['rec_tds'] = self._extract_number(stats_line, r'(\d+)[,\s]+tds?')
                elif position in ['DL', 'LB', 'DB']:
                    game_stats['tackles'] = self._extract_number(stats_line, r'(\d+)[,\s]+tkl')
                    game_stats['sacks'] = self._extract_number(stats_line, r'([\d.]+)[,\s]+sacks?')
                    game_stats['interceptions'] = self._extract_number(stats_line, r'(\d+)[,\s]+ints?')
                
                if any(v is not None for k, v in game_stats.items() if k != 'week' and k != 'opponent'):
                    weekly_stats.append(game_stats)
                
                # Limit to recent weeks (last 8 weeks for velocity)
                if len(weekly_stats) >= 8:
                    break
        
        return weekly_stats
    
