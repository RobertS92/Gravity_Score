                        logger.info(f"   ✅ Twitter: @{ddg_handles['twitter']} (DuckDuckGo)")
                    
                    if ddg_handles.get("tiktok"):
                        brand.tiktok_handle = ddg_handles["tiktok"]
                        social_handles["tiktok"] = ddg_handles["tiktok"]
                        logger.info(f"   ✅ TikTok: @{ddg_handles['tiktok']} (DuckDuckGo)")
                    
                    if ddg_handles.get("youtube"):
                        brand.youtube_channel = ddg_handles["youtube"]
                        logger.info(f"   ✅ YouTube: {ddg_handles['youtube']} (DuckDuckGo)")
                    
                    found_count = sum(1 for h in ddg_handles.values() if h)
                    logger.info(f"   📊 DuckDuckGo fallback found {found_count}/4 platforms")
                    
            except Exception as e2:
                logger.warning(f"DuckDuckGo fallback also failed for {player_name}: {e2}")
        
        # Step 2: Get follower COUNTS using FREE APIs (no Firecrawl costs!)
        # 🚀 FAST_MODE OPTIMIZATION: Parallel API calls for 2-3x speed boost
        if hasattr(self, 'free_collector') and self.free_collector and social_handles:
            try:
                logger.info(f"📊 Getting social stats for {player_name} (FREE APIs)...")
                
                # Helper functions for parallel execution
                def get_instagram():
                    if social_handles.get("instagram"):
                        try:
                            logger.info(f"   🔄 Calling get_instagram_stats for @{social_handles['instagram']}...")
                            ig_stats = self.free_collector.social.get_instagram_stats(social_handles["instagram"])
                            logger.info(f"   📊 Instagram API returned: {ig_stats}")
                            return ig_stats
                        except Exception as e:
                            logger.warning(f"Instagram stats failed: {e}")
                    return {}
                
                def get_twitter():
                    if social_handles.get("twitter"):
                        try:
                            logger.info(f"   🔄 Calling get_twitter_stats for @{social_handles['twitter']}...")
                            tw_stats = self.free_collector.social.get_twitter_stats(social_handles["twitter"])
                            logger.info(f"   📊 Twitter API returned: {tw_stats}")
                            return tw_stats
                        except Exception as e:
                            logger.warning(f"Twitter stats failed: {e}")
                    return {}
                
                def get_tiktok():
                    if social_handles.get("tiktok"):
                        try:
                            logger.info(f"   🔄 Calling get_tiktok_stats for @{social_handles['tiktok']}...")
                            tt_stats = self.free_collector.social.get_tiktok_stats(social_handles["tiktok"])
                            logger.info(f"   📊 TikTok API returned: {tt_stats}")
                            return tt_stats
                        except Exception as e:
                            logger.warning(f"TikTok stats failed: {e}")
                    return {}
                
                def get_youtube():
                    try:
                        return self.free_collector.youtube.get_player_youtube_stats(player_name, "NFL")
                    except Exception as e:
                        logger.warning(f"YouTube stats failed: {e}")
                        return {}
                
                def get_wikipedia():
                    try:
                        return self.free_collector.wikipedia.get_page_views(player_name)
                    except Exception as e:
                        logger.warning(f"Wikipedia stats failed: {e}")
                        return {}
                
                # 🚀 Run all API calls in parallel (saves 2-3 seconds per player!)
                with ThreadPoolExecutor(max_workers=5) as executor:
                    future_instagram = executor.submit(get_instagram)
                    future_twitter = executor.submit(get_twitter)
                    future_tiktok = executor.submit(get_tiktok)
                    future_youtube = executor.submit(get_youtube)
                    future_wikipedia = executor.submit(get_wikipedia)
                    
                    # Collect results with timeout
                    try:
                        ig_stats = future_instagram.result(timeout=5)
                        instagram_followers = ig_stats.get("followers", 0)
                        if instagram_followers and instagram_followers > 0:
                            brand.instagram_followers = instagram_followers
                            brand.instagram_verified = ig_stats.get("verified", False)
                            logger.info(f"   ✅ Instagram: {brand.instagram_followers:,} followers")
                        else:
                            logger.warning(f"   ⚠️  Instagram followers is None/0")
                    except Exception as e:
                        logger.warning(f"Instagram result failed: {e}")
                    
                    try:
                        tw_stats = future_twitter.result(timeout=5)
                        twitter_followers = tw_stats.get("followers", 0)
                        if twitter_followers and twitter_followers > 0:
                            brand.twitter_followers = twitter_followers
                            brand.twitter_verified = tw_stats.get("verified", False)
                            logger.info(f"   ✅ Twitter: {brand.twitter_followers:,} followers")
                        else:
                            logger.warning(f"   ⚠️  Twitter followers is None/0")
                    except Exception as e:
                        logger.warning(f"Twitter result failed: {e}")
                    
                    try:
                        tt_stats = future_tiktok.result(timeout=5)
                        tiktok_followers = tt_stats.get("followers", 0)
                        if tiktok_followers and tiktok_followers > 0:
                            brand.tiktok_followers = tiktok_followers
                            brand.tiktok_likes = tt_stats.get("likes", 0)
                            logger.info(f"   ✅ TikTok: {brand.tiktok_followers:,} followers")
                        else:
                            logger.warning(f"   ⚠️  TikTok followers is None/0")
                    except Exception as e:
                        logger.warning(f"TikTok result failed: {e}")
                    
                    try:
                        yt_stats = future_youtube.result(timeout=5)
                        if yt_stats.get("subscribers"):
                            brand.youtube_subscribers = yt_stats.get("subscribers", 0)
                            brand.youtube_views = yt_stats.get("total_views", 0)
                            brand.youtube_videos_count = yt_stats.get("video_count", 0)
                            logger.info(f"   ✅ YouTube: {brand.youtube_subscribers:,} subscribers")
                    except Exception as e:
                        logger.warning(f"YouTube result failed: {e}")
                    
                    try:
                        wiki_stats = future_wikipedia.result(timeout=5)
                        brand.wikipedia_page_views = wiki_stats.get("page_views_30d", 0)
                        if brand.wikipedia_page_views > 0:
                            logger.info(f"   ✅ Wikipedia: {brand.wikipedia_page_views:,} views (30d)")
                    except Exception as e:
                        logger.warning(f"Wikipedia result failed: {e}")
                
                if brand.instagram_followers or brand.twitter_followers:
                    logger.info(f"📈 Social stats summary: IG={brand.instagram_followers or 0:,}, TW={brand.twitter_followers or 0:,}, Wiki={brand.wikipedia_page_views or 0:,}")
                
            except Exception as e:
                logger.warning(f"Free API stats collection failed for {player_name}: {e}")
        
        # Step 3: News analysis (uses FREE sources: Google News RSS, DuckDuckGo, ESPN)
        if hasattr(self, 'free_collector') and self.free_collector and self.free_collector.news:
            try:
                logger.info(f"📰 Collecting news data for {player_name}...")
                
                # Get ESPN ID if available for ESPN news API
                espn_id = None
                if hasattr(self, '_espn_player_data') and self._espn_player_data:
                    espn_id = self._espn_player_data.get('id')
                
                news_data = self.free_collector.news.collect_news_data(player_name, espn_id)
                brand.news_headline_count_30d = news_data.get('news_headline_count_30d', 0)
                brand.news_headline_count_7d = news_data.get('news_headline_count_7d', 0)
                brand.news_headline_count_365d = news_data.get('news_headline_count_365d', 0)
                brand.news_headline_count_1095d = news_data.get('news_headline_count_1095d', 0)
                brand.brand_sentiment = news_data.get('media_sentiment', 0.0)
                brand.brand_sentiment_7d = news_data.get('media_sentiment_7d', 0.0)
                brand.brand_sentiment_30d = news_data.get('media_sentiment_30d', 0.0)
                brand.brand_sentiment_365d = news_data.get('media_sentiment_365d', 0.0)
                brand.brand_sentiment_1095d = news_data.get('media_sentiment_1095d', 0.0)
                brand.mention_velocity = news_data.get('mention_velocity', 0.0)
                
                if brand.news_headline_count_30d > 0:
                    logger.info(f"   📰 News: {brand.news_headline_count_30d} headlines (30d), sentiment={brand.brand_sentiment:.2f}")
                else:
                    logger.warning(f"   ⚠️  No news headlines found for {player_name}")
            except Exception as e:
                logger.warning(f"News collection failed for {player_name}: {e}")
                import traceback
                logger.debug(traceback.format_exc())
        else:
            # Fallback to old NewsAnalyzer if FreeCollector not available
            try:
                logger.info(f"📰 Collecting news data for {player_name} (legacy method)...")
                news_data = self.news_analyzer.analyze_news(player_name)
                brand.news_headline_count_30d = news_data.get('news_headline_count_30d', 0)
                brand.news_headline_count_7d = news_data.get('news_headline_count_7d', 0)
                brand.news_headline_count_365d = news_data.get('news_headline_count_365d', 0)
                brand.news_headline_count_1095d = news_data.get('news_headline_count_1095d', 0)
                brand.brand_sentiment = news_data.get('brand_sentiment', 0.0)
                brand.brand_sentiment_7d = 0.0  # Legacy analyzer doesn't have this
                brand.brand_sentiment_30d = news_data.get('brand_sentiment', 0.0)  # Use overall sentiment
                brand.brand_sentiment_365d = 0.0
                brand.brand_sentiment_1095d = 0.0
                brand.mention_velocity = news_data.get('mention_velocity', 0)
                
                if brand.news_headline_count_30d > 0:
                    logger.info(f"   📰 News: {brand.news_headline_count_30d} headlines (30d), sentiment={brand.brand_sentiment:.2f}")
                else:
                    logger.warning(f"   ⚠️  No news headlines found for {player_name}")
            except Exception as e:
                logger.warning(f"News analysis failed for {player_name}: {e}")
        
        # Step 4: Google Trends (use FREE pytrends if available, else Firecrawl fallback)
        if hasattr(self, 'free_collector') and self.free_collector:
            try:
                logger.info(f"📈 Collecting Google Trends data for {player_name}...")
                trends_data = self.free_collector.trends.get_trends_score(player_name, "NFL")
                brand.google_trends_score = trends_data.get('trends_score', 0)
                if brand.google_trends_score > 0:
                    logger.info(f"   📈 Google Trends: {brand.google_trends_score}")
                else:
                    logger.warning(f"   ⚠️  Google Trends returned 0 for {player_name}")
            except Exception as e:
                logger.warning(f"Google Trends failed for {player_name}: {e}")
                brand.google_trends_score = 0
        else:
            # Fallback to Firecrawl-based trends
            try:
                trends_data = self.trends_analyzer.get_trends_data(player_name)
                trends_score = trends_data.get('trends_score')
                if trends_score is None and brand.news_headline_count_30d:
                    trends_score = min(100, brand.news_headline_count_30d)
                brand.google_trends_score = trends_score or 0
            except Exception as e:
                logger.warning(f"Trends analyzer failed for {player_name}: {e}")
                brand.google_trends_score = 0
        
        return brand
    
    def _collect_proof(self, player_name: str, position: str) -> ProofData:
        """Collect performance/proof data - Uses ESPN API (no Firecrawl)"""
        proof = ProofData()
        
        # Debug logging
        logger.info(f"   _collect_proof: hasattr _espn_player_data = {hasattr(self, '_espn_player_data')}")
        if hasattr(self, '_espn_player_data'):
            logger.info(f"   _collect_proof: _espn_player_data is not None = {self._espn_player_data is not None}")
        
        # =====================================================================
        # USE ESPN DATA FROM IDENTITY COLLECTION (already fetched)
        # =====================================================================
        if hasattr(self, '_espn_player_data') and self._espn_player_data:
            espn_data = self._espn_player_data
            espn_stats = espn_data.get("stats", {})
            
            logger.info(f"✅ Using cached ESPN stats for {player_name}")
            
            # Map ESPN stats to proof data
            current_season = espn_stats.get("current_season", {})
            career = espn_stats.get("career", {})
            by_year = espn_stats.get("by_year", {})
            
            # CRITICAL: Clean ESPN stats IMMEDIATELY before processing
            # ESPN returns values like "3,587" as strings - convert NOW
            logger.info(f"   🧹 Cleaning ESPN stats values...")
            for stats_dict in [current_season, career]:
                if stats_dict:
                    for key, value in list(stats_dict.items()):
                        if isinstance(value, str) and key not in ['name', 'team', 'position', 'status', 'year']:
                            cleaned = self.stats_collector._clean_stat_value(value)
                            if cleaned is not None:
                                stats_dict[key] = cleaned
            
            # Clean year-by-year stats
            for year, year_stats in by_year.items():
                if isinstance(year_stats, dict):
                    for stat_key, stat_val in list(year_stats.items()):
                        if isinstance(stat_val, str) and stat_key not in ['name', 'team', 'position', 'status', 'year']:
                            cleaned = self.stats_collector._clean_stat_value(stat_val)
                            if cleaned is not None:
                                year_stats[stat_key] = cleaned
            
            # Career stats
            career_stats = {
                "rushing_attempts": career.get("rushingAttempts", 0),
                "rushing_yards": career.get("rushingYards", 0),
                "rushing_touchdowns": career.get("rushingTouchdowns", 0),
                "yards_per_carry": career.get("yardsPerRushAttempt", 0),
                "receptions": career.get("receptions", 0),
                "receiving_yards": career.get("receivingYards", 0),
                "receiving_touchdowns": career.get("receivingTouchdowns", 0),
                "yards_per_reception": career.get("yardsPerReception", 0),
                "passing_attempts": career.get("passingAttempts", 0),
                "passing_completions": career.get("passingCompletions", 0),
                "passing_yards": career.get("passingYards", 0),
                "passing_touchdowns": career.get("passingTouchdowns", 0),
                "interceptions": career.get("interceptions", 0),
                "sacks": career.get("sacks", 0),
                "tackles": career.get("tackles", 0),
                "fumbles": career.get("fumbles", 0),
                "fumbles_lost": career.get("fumblesLost", 0),
                "touchdowns": career.get("rushingTouchdowns", 0) + career.get("receivingTouchdowns", 0) + career.get("passingTouchdowns", 0),
                "yards": career.get("rushingYards", 0) + career.get("receivingYards", 0) + career.get("passingYards", 0)
            }
            
            # Current season stats (2024)
            current_season_stats = {
                "rushing_attempts": current_season.get("rushingAttempts", 0),
                "rushing_yards": current_season.get("rushingYards", 0),
                "rushing_touchdowns": current_season.get("rushingTouchdowns", 0),
                "yards_per_carry": current_season.get("yardsPerRushAttempt", 0),
                "receptions": current_season.get("receptions", 0),
                "receiving_yards": current_season.get("receivingYards", 0),
                "receiving_touchdowns": current_season.get("receivingTouchdowns", 0),
                "yards_per_reception": current_season.get("yardsPerReception", 0),
                "passing_yards": current_season.get("passingYards", 0),
                "passing_touchdowns": current_season.get("passingTouchdowns", 0),
                "fumbles": current_season.get("fumbles", 0)
            }
            
            # Previous season stats (2023)
            last_season_stats = {}
            if "2023" in by_year:
                prev = by_year["2023"]
                last_season_stats = {
                    "rushing_yards": prev.get("rushingYards", 0),
                    "rushing_touchdowns": prev.get("rushingTouchdowns", 0),
                    "receiving_yards": prev.get("receivingYards", 0),
                    "receptions": prev.get("receptions", 0)
                }
            
            # Year-by-year breakdown - comprehensive stats
            career_stats_by_year = {}
            for year, year_stats in by_year.items():
                career_stats_by_year[year] = {
                    "rushing_yards": year_stats.get("rushingYards", 0),
                    "rushing_touchdowns": year_stats.get("rushingTouchdowns", 0),
                    "rushing_attempts": year_stats.get("rushingAttempts", 0),
                    "receptions": year_stats.get("receptions", 0),
                    "receiving_yards": year_stats.get("receivingYards", 0),
                    "receiving_touchdowns": year_stats.get("receivingTouchdowns", 0),
                    "passing_yards": year_stats.get("passingYards", 0),
                    "passing_touchdowns": year_stats.get("passingTouchdowns", 0),
                    "passing_completions": year_stats.get("passingCompletions", 0),
                    "passing_attempts": year_stats.get("passingAttempts", 0),
                    "interceptions": year_stats.get("interceptions", 0),
                    "sacks": year_stats.get("sacks", 0),
                    "tackles": year_stats.get("tackles", 0),
                    "fumbles": year_stats.get("fumbles", 0),
                    "games_played": year_stats.get("gamesPlayed", 0)
                }
            
            # Awards from ESPN - extract from awards list
            awards_list = espn_data.get("awards", [])
            proof.awards = [a.get("name", "") if isinstance(a, dict) else str(a) for a in awards_list]
            
            # Year-by-year awards tracking - extract from awards list
            for award in awards_list:
                if isinstance(award, dict):
                    award_name = award.get("name", "").lower()
                    award_year = award.get("year")
                    if award_year:
                        try:
                            year = int(award_year)
                            if "pro bowl" in award_name:
                                proof.pro_bowls_by_year[year] = True
                            if "all-pro" in award_name or "all pro" in award_name:
                                proof.all_pro_selections_by_year[year] = True
                            if "super bowl" in award_name:
                                proof.super_bowl_wins_by_year[year] = True
                        except (ValueError, TypeError):
                            pass
            
            # Calculate totals from year-by-year if available
            if proof.pro_bowls_by_year:
                proof.pro_bowls = sum(1 for v in proof.pro_bowls_by_year.values() if v)
            else:
                # Use ESPN counts or count from awards list
                proof.pro_bowls = espn_data.get("pro_bowls", 0)
                if proof.pro_bowls == 0:
                    proof.pro_bowls = len([a for a in awards_list if isinstance(a, dict) and "pro bowl" in a.get("name", "").lower()])
            
            if proof.all_pro_selections_by_year:
                proof.all_pro_selections = sum(1 for v in proof.all_pro_selections_by_year.values() if v)
            else:
                proof.all_pro_selections = espn_data.get("all_pro", 0)
                if proof.all_pro_selections == 0:
                    proof.all_pro_selections = len([a for a in awards_list if isinstance(a, dict) and ("all-pro" in a.get("name", "").lower() or "all pro" in a.get("name", "").lower())])
            
            if proof.super_bowl_wins_by_year:
                proof.super_bowl_wins = sum(1 for v in proof.super_bowl_wins_by_year.values() if v)
            
            # Estimate PFF grade from accolades (since we don't have PFF subscription)
            pff_grade = self.stats_collector._estimate_pff_grade(
                proof.pro_bowls,
                proof.all_pro_selections,
                position
            )
            proof.pff_grade = pff_grade
            logger.info(f"   📊 Estimated PFF grade: {pff_grade} (from {proof.pro_bowls} Pro Bowls, {proof.all_pro_selections} All-Pros)")
            
            # Estimate playoff appearances from years with stats (rough approximation)
            # Better approach would be to check team records, but this gives a baseline
            years_with_stats = list(by_year.keys())
            if years_with_stats and not proof.playoff_appearances:
                # Assume ~50% of career years had playoff appearances (conservative estimate)
                proof.playoff_appearances = len(years_with_stats) // 2
                for year in years_with_stats:
                    year_int = int(year) if isinstance(year, str) else year
                    # Mark every other year as playoff (placeholder logic)
                    if year_int % 2 == 0:
                        proof.playoff_appearances_by_year[year_int] = True
            
            # Extract position-specific career totals
            proof.career_touchdowns = career_stats.get("touchdowns") or (
                career.get("rushingTouchdowns", 0) + 
                career.get("receivingTouchdowns", 0) + 
                career.get("passingTouchdowns", 0)
            )
            
            proof.career_yards = career_stats.get("yards") or (
                career.get("rushingYards", 0) + 
                career.get("receivingYards", 0) + 
                career.get("passingYards", 0)
            )
            
            proof.career_receptions = career.get("receptions") or career_stats.get("receptions")
            proof.career_completions = career.get("passingCompletions") or career_stats.get("passing_completions")
            proof.career_sacks = career.get("sacks") or career_stats.get("sacks")
            proof.career_interceptions = career.get("interceptions") or career_stats.get("interceptions")
            
            # Set career stats
            proof.career_stats = career_stats
            proof.current_season_stats = current_season_stats
            proof.last_season_stats = last_season_stats
            proof.career_stats_by_year = career_stats_by_year
            
            # ESPN doesn't provide NFL awards via API - use Wikipedia
            logger.info(f"   🔍 ESPN awards unavailable for NFL, using Wikipedia for {player_name}...")
            try:
                wiki_achievements = self.stats_collector._extract_achievements_by_year(player_name)
                logger.info(f"   Wikipedia returned keys: {list(wiki_achievements.keys())}")
                logger.info(f"   Pro Bowls by year: {wiki_achievements.get('pro_bowls_by_year', {})}")
            except Exception as e:
                logger.error(f"   Wikipedia extraction failed: {e}")
                wiki_achievements = {
                    'pro_bowls_by_year': {},
                    'all_pro_selections_by_year': {},
                    'super_bowl_wins_by_year': {},
                    'playoff_appearances_by_year': {}
                }
            proof.pro_bowls_by_year = wiki_achievements.get('pro_bowls_by_year', {})
            proof.all_pro_selections_by_year = wiki_achievements.get('all_pro_selections_by_year', {})
            proof.super_bowl_wins_by_year = wiki_achievements.get('super_bowl_wins_by_year', {})
            proof.playoff_appearances_by_year = wiki_achievements.get('playoff_appearances_by_year', {})
            
            # Calculate totals from year-by-year data
            if proof.pro_bowls_by_year:
                proof.pro_bowls = sum(1 for v in proof.pro_bowls_by_year.values() if v)
            if proof.all_pro_selections_by_year:
                proof.all_pro_selections = sum(1 for v in proof.all_pro_selections_by_year.values() if v)
            if proof.super_bowl_wins_by_year:
                proof.super_bowl_wins = sum(1 for v in proof.super_bowl_wins_by_year.values() if v)
            if proof.playoff_appearances_by_year:
                proof.playoff_appearances = sum(1 for v in proof.playoff_appearances_by_year.values() if v)
            
            # CRITICAL: Aggregate career totals from year-by-year stats (ESPN direct path)
            if proof.career_stats_by_year:
                logger.info(f"   📊 Aggregating career stats from {len(proof.career_stats_by_year)} seasons...")
                
                aggregated = {}
                sum_stats = [
                    'passing_yards', 'passing_touchdowns', 'passing_attempts', 'passing_completions', 'interceptions',
                    'rushing_yards', 'rushing_touchdowns', 'rushing_attempts',
                    'receptions', 'receiving_yards', 'receiving_touchdowns',
                    'sacks', 'tackles', 'fumbles', 'fumbles_lost', 'solo_tackles', 'assisted_tackles',
                    'tackles_for_loss', 'qb_hits', 'passes_defended', 'forced_fumbles'
                ]
                
                for year, year_stats in proof.career_stats_by_year.items():
                    for stat in sum_stats:
                        if stat in year_stats:
                            val = year_stats[stat]
                            # Ensure numeric
                            if isinstance(val, (int, float)) and val > 0:
                                aggregated[stat] = aggregated.get(stat, 0) + val
                
                # Override career_stats with aggregated values
                for stat, total in aggregated.items():
                    proof.career_stats[stat] = total
                
                # Log aggregated totals
                if aggregated.get('passing_yards', 0) > 0:
                    logger.info(f"      ✅ Passing: {aggregated.get('passing_yards', 0):,.0f} yds, "
                               f"{aggregated.get('passing_touchdowns', 0)} TDs")
