    def _clean_stat_value(self, value, as_type='float'):
        """Convert stat string to numeric type"""
        if value is None or value == "" or value == "Unknown":
            return None
        
        if isinstance(value, (int, float)):
            return float(value) if as_type == 'float' else int(value)
        
        try:
            cleaned = str(value).replace(',', '').strip()
            if not cleaned:
                return None
            return float(cleaned) if as_type == 'float' else int(float(cleaned))
        except (ValueError, AttributeError):
            return None
    
    def _clean_stats_dict(self, stats_dict):
        """Recursively clean all stat values in a dictionary"""
        if not isinstance(stats_dict, dict):
            return stats_dict
        
        cleaned = {}
        for key, value in stats_dict.items():
            if isinstance(value, dict):
                cleaned[key] = self._clean_stats_dict(value)
            elif key in ['name', 'team', 'position', 'status', 'year']:
                cleaned[key] = value
            else:
                numeric_val = self._clean_stat_value(value)
                cleaned[key] = numeric_val if numeric_val is not None else 0
        return cleaned
    
    def _calculate_passer_rating(self, comp, att, yards, tds, ints):
        """Calculate NFL passer rating using official formula"""
        if not att or att == 0:
            return None
        
        try:
            comp = float(comp) if comp else 0
            att = float(att)
            yards = float(yards) if yards else 0
            tds = float(tds) if tds else 0
            ints = float(ints) if ints else 0
            
            a = max(0, min(2.375, ((comp / att) - 0.3) * 5))
            b = max(0, min(2.375, ((yards / att) - 3) * 0.25))
            c = max(0, min(2.375, (tds / att) * 20))
            d = max(0, min(2.375, 2.375 - ((ints / att) * 25)))
            
            rating = ((a + b + c + d) / 6) * 100
            return round(rating, 1)
        except (ValueError, TypeError, ZeroDivisionError):
            return None
    
    def _estimate_pff_grade(self, pro_bowls: int, all_pro: int, position: str) -> float:
        """Estimate PFF grade from accolades"""
        base = 60.0
        
        try:
            pro_bowls = int(pro_bowls) if pro_bowls else 0
            all_pro = int(all_pro) if all_pro else 0
            
            if pro_bowls > 0:
                base += min(pro_bowls * 3, 15)
            
            if all_pro > 0:
                base += min(all_pro * 5, 15)
            
            premium_positions = ['QB', 'WR', 'DE', 'CB', 'EDGE', 'LT', 'RT']
            if position in premium_positions:
                base += 2
            
            return min(base, 95.0)
        except (ValueError, TypeError):
            return 60.0
    
