    def _get_contract_status(self, player_name: str) -> Dict:
        """Get contract and free agency status with enhanced collection"""
        data = {
            'status': 'unknown',
            'free_agency_year': None,
            'franchise_tag_candidate': False,
            'holdout_risk': False
        }
        
        # Method 1: Spotrac for contract details
        spotrac_url = f"https://www.spotrac.com/nfl/search/{quote(player_name)}/"
        result = self.scraper.scrape(spotrac_url)
        
        if result and 'markdown' in result:
            text = result['markdown']
            text_lower = text.lower()
            
            # Contract status
            if 'free agent' in text_lower:
                data['status'] = 'free_agent'
            elif 'expiring' in text_lower:
                data['status'] = 'expiring_soon'
            elif 'signed' in text_lower or 'extension' in text_lower:
                data['status'] = 'under_contract'
            else:
                data['status'] = 'under_contract'  # Default assumption
            
            # Free agency year - try multiple patterns
            fa_patterns = [
                r'free agent[:\s]+(\d{4})',
                r'expires[:\s]+(\d{4})',
                r'contract[:\s]+through[:\s]+(\d{4})',
                r'(\d{4})[:\s]+free agent',
                r'fa[:\s]+(\d{4})'
            ]
            for pattern in fa_patterns:
                fa_match = re.search(pattern, text_lower)
                if fa_match:
                    try:
                        data['free_agency_year'] = int(fa_match.group(1))
                        break
                    except:
                        continue
            
            # Franchise tag candidate
            data['franchise_tag_candidate'] = 'franchise tag' in text_lower or 'franchise-tag' in text_lower
            
            # Holdout risk
            holdout_terms = ['holdout', 'contract dispute', 'wants new deal', 'seeking extension', 
                           'contract negotiations', 'unhappy with contract']
            data['holdout_risk'] = any(term in text_lower for term in holdout_terms)
        
        # Method 2: Try OverTheCap as fallback
        if data['status'] == 'unknown' or not data.get('free_agency_year'):
            try:
                otc_url = f"https://overthecap.com/search/{quote(player_name)}"
                otc_result = self.scraper.scrape(otc_url)
                
                if otc_result and 'markdown' in otc_result:
                    text = otc_result['markdown'].lower()
                    
                    if data['status'] == 'unknown':
                        if 'free agent' in text:
                            data['status'] = 'free_agent'
                        else:
                            data['status'] = 'under_contract'
                    
                    # Try to extract contract year
                    if not data.get('free_agency_year'):
                        year_match = re.search(r'(\d{4})[:\s]+(?:free|expires|contract)', text)
                        if year_match:
                            try:
                                data['free_agency_year'] = int(year_match.group(1))
                            except:
                                pass
            except Exception as e:
                logger.debug(f"OverTheCap fallback failed: {e}")
        
        return data
    
    def _calculate_injury_risk(self, injuries: List[Dict], position: str, age: int = None) -> float:
        """Calculate injury risk score (0-100)"""
        score = 0
        
        # Only add base score if there are actual injuries
        if injuries:
            # Base score from injury count (less aggressive)
            score += len(injuries) * 3
            
            # Severity weighting
            for injury in injuries:
                if injury.get('severity') == 'severe':
                    score += 20
                elif injury.get('severity') == 'moderate':
                    score += 10
                else:
                    score += 5
            
            # Recent injuries weighted more
            recent_injuries = [inj for inj in injuries if '2024' in str(inj.get('date', '')) or '2025' in str(inj.get('date', ''))]
            score += len(recent_injuries) * 15
            
            # Games missed factor
            total_games_missed = sum(inj.get('games_missed', 0) for inj in injuries)
            if total_games_missed > 0:
                score += min(20, total_games_missed * 2)  # Cap at 20 points
        else:
            # No injuries found - use position baseline only
            position_rate = self.position_injury_rates.get(position, 40)
            score = position_rate / 10  # Much lower baseline (4-6.5 instead of 10)
        
        # Position risk (only if we have injuries)
        if injuries:
            position_rate = self.position_injury_rates.get(position, 40)
            score += position_rate / 10  # Reduced from /4
        
        # Age factor (only if we have injuries or age is high)
        if age:
            if age > 32:
                score += (age - 32) * 2  # Only penalize after 32
            elif age < 25:
                score -= 3  # Small bonus for young players
        
        return min(100, round(score, 1))
    
    def _calculate_controversy_risk(self, controversies: List[Dict]) -> float:
        """Calculate controversy risk score (0-100)"""
        score = 0
        
        # Only score if there are actual controversies
        if controversies:
            # Base score from count (less aggressive)
            score += len(controversies) * 8
            
            # Type weighting
            for cont in controversies:
                cont_type = cont.get('type', '').lower()
                if cont_type in ['arrested', 'charged']:
                    score += 25
                elif cont_type in ['suspended', 'banned']:
                    score += 20
                elif cont_type in ['investigation', 'lawsuit']:
                    score += 15
                elif cont_type in ['fine', 'violation']:
                    score += 10
                else:
                    score += 5
            
            # Recent controversies weighted more
            recent_controversies = [c for c in controversies if '2024' in str(c.get('date', '')) or '2025' in str(c.get('date', ''))]
            score += len(recent_controversies) * 15
        else:
            # No controversies found - very low baseline
            score = 5  # Minimal baseline risk
        
        return min(100, round(score, 1))
    
    def _calculate_age_risk(self, age: int, position: str) -> float:
        """Calculate age-related risk (0-100)"""
        # Peak ages by position
        peak_ages = {
            'QB': 32, 'RB': 26, 'WR': 28, 'TE': 29,
            'OL': 29, 'DL': 28, 'LB': 28, 'DB': 27,
            'K': 30, 'P': 30
        }
        
        peak_age = peak_ages.get(position, 28)
        
        if age <= peak_age:
            # Before peak - low risk
            
            return max(0, (peak_age - age) * 2)
        else:
            # After peak - increasing risk
            years_past_peak = age - peak_age
            return min(100, years_past_peak * 15)

