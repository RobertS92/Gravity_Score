Headlines:
{combined_text}

Return comma-separated numbers only:""",
                    "stream": False,
                    "options": {
                        "temperature": 0.3,
                        "num_predict": 50
                    }
                },
                timeout=60
            )
            
            if response.status_code == 200:
                result = response.json().get("response", "").strip()
                # Extract all numbers
                sentiments = [float(match.group(0)) for match in re.finditer(r'-?\d+\.?\d*', result)]
                
                # Pad with keyword-based if needed
                while len(sentiments) < len(texts):
                    sentiments.append(self._calculate_sentiment_keyword(texts[len(sentiments)]))
                
                # Clamp all to -1 to 1
                return [max(-1.0, min(1.0, s)) for s in sentiments[:len(texts)]]
            else:
                logger.warning(f"Ollama batch API error {response.status_code}. Falling back to keyword method.")
                return [self._calculate_sentiment_keyword(t) for t in texts]
                
        except Exception as e:
            logger.warning(f"LLM batch sentiment analysis failed: {e}. Falling back to keyword method.")
            return [self._calculate_sentiment_keyword(t) for t in texts]
    
    def _calculate_sentiment_keyword(self, text: str) -> float:
        """Calculate sentiment score (-1 to 1) with weighted keywords and negation handling"""
        if not text:
            return 0.0
        
        text_lower = text.lower()
        words = text_lower.split()
        
        pos_score = 0.0
        neg_score = 0.0
        
        # Check each word and nearby context
        for i, word in enumerate(words):
            # Clean word (remove punctuation)
            clean_word = re.sub(r'[^\w]', '', word)
            
            # Check for positive words
            if clean_word in self.positive_words:
                weight = self.positive_words[clean_word]
                
                # Check for negation (look back 2-3 words)
                negated = False
                for j in range(max(0, i-3), i):
                    if words[j] in self.negation_words:
                        negated = True
                        break
                
                if negated:
                    # Negation flips to negative
                    neg_score += weight * 0.8  # Slightly less weight when negated
                else:
                    # Check for intensifiers
                    intensified = any(words[j] in self.intensifiers for j in range(max(0, i-2), i))
                    if intensified:
                        pos_score += weight * 1.3
                    else:
                        pos_score += weight
            
            # Check for negative words
            elif clean_word in self.negative_words:
                weight = self.negative_words[clean_word]
                
                # Check for negation
                negated = False
                for j in range(max(0, i-3), i):
                    if words[j] in self.negation_words:
                        negated = True
                        break
                
                if negated:
                    # Negation flips to positive
                    pos_score += weight * 0.8
                else:
                    # Check for intensifiers
                    intensified = any(words[j] in self.intensifiers for j in range(max(0, i-2), i))
                    if intensified:
                        neg_score += weight * 1.3
                    else:
                        neg_score += weight
        
        # Normalize to -1 to 1 range
        total_score = pos_score + neg_score
        if total_score == 0:
            return 0.0
        
        # Calculate normalized sentiment
        sentiment = (pos_score - neg_score) / total_score
        
        # Clamp to -1 to 1
        return max(-1.0, min(1.0, sentiment))
    
    def _average_sentiment(self, scores: List[float]) -> float:
        """Calculate average sentiment"""
        if not scores:
            return 0.0
        return round(sum(scores) / len(scores), 3)
    
    def _extract_topics(self, text: str) -> List[str]:
        """Extract topic keywords from text"""
        topics = []
        
        # Topic patterns
        patterns = {
            'injury': ['injured', 'hurt', 'IR', 'questionable'],
            'contract': ['contract', 'deal', 'extension', 'salary'],
            'trade': ['trade', 'traded', 'rumors'],
            'performance': ['touchdown', 'yards', 'record', 'stats'],
            'controversy': ['suspended', 'fine', 'arrest', 'investigation']
        }
        
        text_lower = text.lower()
        for topic, keywords in patterns.items():
            if any(kw in text_lower for kw in keywords):
                topics.append(topic)
        
        return topics
    
    def _get_top_items(self, items: List, n: int) -> List:
        """Get top N most frequent items"""
        from collections import Counter
        counter = Counter(items)
        return [item for item, count in counter.most_common(n)]

