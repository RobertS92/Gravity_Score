def _get_nfl_sitemap_roster_regex(collector: NFLPlayerCollector, team_name: str) -> List[Dict]:
    """Get roster from NFL.com sitemap using regex extraction (fallback method)"""
    logger.info(f"NFL sitemap regex extraction called for team: '{team_name}'")
    team_slug = _get_team_slug_for_nfl(team_name)
    current_year = datetime.now().year
    roster_url = f"https://www.nfl.com/sitemap/html/rosters/{current_year}/{team_slug}"
    logger.info(f"NFL sitemap regex: team='{team_name}' -> slug='{team_slug}' -> URL={roster_url}")
    
    try:
        logger.info(f"Regex extraction: Scraping NFL sitemap roster {roster_url}")
        result = _scrape_with_timeout(collector.scraper, roster_url, timeout=30000)
        if result and 'markdown' in result:
            text = result['markdown']
            if text and len(text) > 100:
                logger.info(f"Regex extraction: Got {len(text)} chars of text")
                
                # The sitemap roster has a table with Jersey # and Player columns
                # Pattern: Jersey number (optional) followed by player name link
                # Example: "51 | Will Anderson Jr." or "[ Azeez Al-Shaair](/players/azeez-al-shaair/)"
                players = []
                seen_players = set()
                
                # Pattern 1: Table row with jersey number and player link
                # Matches: "51 | [ Will Anderson Jr.](/players/will-anderson-jr/)"
                pattern1 = r'(\d{1,2})\s*\|\s*\[?\s*([A-Z][a-zA-Z\.\'\-\s]+(?:Jr\.|Sr\.|III|II)?)\s*\]?\(/players/[^/]+/\)'
                matches = re.finditer(pattern1, text, re.MULTILINE)
                for match in matches:
                    jersey = match.group(1).strip()
                    name = match.group(2).strip()
                    name = re.sub(r'\s+', ' ', name).strip()
                    
                    if len(name.split()) >= 2 and name not in seen_players:
                        seen_players.add(name)
                        # Extract player slug from the link to construct URL
                        link_match = re.search(r'/players/([^/]+)/', match.group(0))
                        player_slug = link_match.group(1) if link_match else None
                        player_url = f"https://www.nfl.com/players/{player_slug}/" if player_slug else _construct_player_url(name)
                        
                        players.append({
                            'name': name,
                            'position': 'UNK',  # Will be filled from player page
                            'jersey_number': int(jersey) if jersey.isdigit() else None,
                            'team': team_name,
                            'player_url': player_url
                        })
                        logger.debug(f"Sitemap regex: {name} (#{jersey})")
                
                # Pattern 2: Player link without jersey number
                # Matches: "[ Azeez Al-Shaair](/players/azeez-al-shaair/)"
                pattern2 = r'\[?\s*([A-Z][a-zA-Z\.\'\-\s]+(?:Jr\.|Sr\.|III|II)?)\s*\]?\(/players/([^/]+)/\)'
                matches = re.finditer(pattern2, text, re.MULTILINE)
                for match in matches:
                    name = match.group(1).strip()
                    player_slug = match.group(2).strip()
                    name = re.sub(r'\s+', ' ', name).strip()
                    
                    if len(name.split()) >= 2 and name not in seen_players:
                        seen_players.add(name)
                        player_url = f"https://www.nfl.com/players/{player_slug}/"
                        
                        players.append({
                            'name': name,
                            'position': 'UNK',  # Will be filled from player page
                            'jersey_number': None,
                            'team': team_name,
                            'player_url': player_url
                        })
                        logger.debug(f"Sitemap regex: {name} (no jersey)")
                
                logger.info(f"Regex extraction: Extracted {len(players)} players from sitemap")
                return players
            else:
                logger.warning(f"Regex extraction: Text too short ({len(text) if text else 0} chars)")
        else:
            logger.warning(f"Regex extraction: No markdown in result")
    except Exception as e:
        logger.error(f"NFL sitemap regex extraction failed: {e}")
        import traceback
        logger.debug(f"Traceback: {traceback.format_exc()}")
    
    return []

