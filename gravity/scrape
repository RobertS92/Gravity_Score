    def analyze_risk(self, player_name: str, position: str, age: int = None) -> RiskData:
        """Comprehensive risk analysis with enhanced data collection"""
        risk_data = RiskData()
        
        # 1. Injury history - enhanced collection (always collect all data)
        injuries = self._get_injury_history(player_name)
        risk_data.injury_history = injuries
        
        # Calculate injury metrics - ensure all fields are populated
        if injuries:
            risk_data.games_missed_career = sum(inj.get('games_missed', 0) for inj in injuries)
            
            # Recent injuries (last season and current year)
            current_year = datetime.now().year
            recent_injuries = [
                inj for inj in injuries 
                if str(current_year) in str(inj.get('date', '')) or 
                   str(current_year - 1) in str(inj.get('date', ''))
            ]
            risk_data.games_missed_last_season = sum(inj.get('games_missed', 0) for inj in recent_injuries)
            
            # Current injury status
            if recent_injuries:
                latest_injury = max(recent_injuries, key=lambda x: x.get('date', ''))
                risk_data.current_injury_status = latest_injury.get('type', 'unknown')
            
            # Calculate risk score
            risk_data.injury_risk_score = self._calculate_injury_risk(injuries, position, age)
        else:
            # Even with no injuries, set baseline values
            risk_data.games_missed_career = 0
            risk_data.games_missed_last_season = 0
            risk_data.injury_risk_score = self._calculate_injury_risk([], position, age)
            risk_data.current_injury_status = "healthy"
        
        # Position-based injury rate (always set)
        risk_data.position_injury_rate = self.position_injury_rates.get(position, 40)
        
        # 2. Controversies - enhanced collection (always collect all data)
        controversies = self._get_controversies(player_name)
        risk_data.controversies = controversies
        
        # Extract specific types - ensure lists are populated
        for cont in controversies:
            desc = cont.get('description', '').lower()
            if 'suspend' in desc or 'suspension' in desc:
                risk_data.suspensions.append(cont)
            elif 'fine' in desc or 'fined' in desc:
                risk_data.fines.append(cont)
            elif 'arrest' in desc or 'arrested' in desc or 'charge' in desc:
                risk_data.arrests.append(cont)
        
        # Calculate controversy risk - always set a value
        risk_data.controversy_risk_score = self._calculate_controversy_risk(controversies)
        
        # Reputation score based on controversies
        if controversies:
            risk_data.reputation_score = max(0, 100 - (risk_data.controversy_risk_score * 1.5))
        else:
            risk_data.reputation_score = 100.0
        
        # 3. Contract status - enhanced collection with fallbacks
        contract_info = self._get_contract_status(player_name)
        risk_data.contract_status = contract_info.get('status', 'unknown')
        risk_data.free_agency_year = contract_info.get('free_agency_year')
        risk_data.franchise_tag_candidate = contract_info.get('franchise_tag_candidate', False)
        risk_data.holdout_risk = contract_info.get('holdout_risk', False)
        
        # 4. Age risk - always calculate if age available
        if age:
            risk_data.age_risk = self._calculate_age_risk(age, position)
        else:
            # Default age risk if age not available
            risk_data.age_risk = 30.0  # Moderate baseline
        
        # 5. Performance volatility - calculate from position and age
        risk_data.performance_volatility = self._calculate_performance_volatility(position, age, risk_data.injury_risk_score)
        
        logger.info(f"Risk analysis for {player_name}: Injury score: {risk_data.injury_risk_score}, "
                   f"Controversy score: {risk_data.controversy_risk_score}, Age risk: {risk_data.age_risk}")
        
        return risk_data
    
    def _calculate_performance_volatility(self, position: str, age: int = None, injury_score: float = 0) -> float:
        """Calculate performance volatility score"""
        volatility = 20.0  # Base volatility
        
        # Position-based volatility
        high_volatility_positions = ['RB', 'WR', 'CB']
        if position in high_volatility_positions:
            volatility += 15.0
        
        # Age factor
        if age:
            if age > 30:
                volatility += (age - 30) * 2
            elif age < 25:
                volatility += 5.0  # Young players can be volatile
        
        # Injury factor
        volatility += min(injury_score * 0.3, 20.0)
        
        return min(100.0, round(volatility, 1))
    
