                        # Just take first player from roster
                        players.append(roster[0])
                        break
    
    elif selection == "player":
        # Single player mode from args/env
        player_name = os.getenv("PLAYER_NAME") or (sys.argv[2] if len(sys.argv) > 2 else None)
        team = os.getenv("PLAYER_TEAM") or (sys.argv[3] if len(sys.argv) > 3 else None)
