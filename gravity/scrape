        if result and 'markdown' in result:
            text = result['markdown']
            
            # Extract bio info
            height_match = re.search(r"(\d+)'(\d+)\"", text)
            if height_match:
                data['height'] = f"{height_match.group(1)}'{height_match.group(2)}\""
            
            weight_match = re.search(r'(\d{3})\s*lbs', text)
            if weight_match:
                data['weight'] = int(weight_match.group(1))
            
            # Draft info
            draft_match = re.search(r'(\d{4})\s+Round\s+(\d+)', text)
            if draft_match:
                data['draft_year'] = int(draft_match.group(1))
                data['draft_round'] = int(draft_match.group(2))
        
        return data

    def _get_wikipedia_draft_info(self, player_name: str) -> Dict:
        """Lightweight Wikipedia draft scraper (HTML)"""
        try:
            import requests
            from bs4 import BeautifulSoup
            url = f"https://en.wikipedia.org/wiki/{player_name.replace(' ', '_')}"
            resp = requests.get(url, timeout=10, headers={'User-Agent': 'Mozilla/5.0'})
            if resp.status_code != 200:
                return {}
            soup = BeautifulSoup(resp.text, 'html.parser')
            text = soup.get_text(separator=" ")
            info = {}
            # Drafted by ... in the 4th round of the 2012 NFL Draft with the 102nd pick
            pattern = r'(\\d{4}).{0,40}(?:drafted|draft).*?\\b(\\d+)(?:st|nd|rd|th)\\b.*?round.*?\\b(\\d+)(?:st|nd|rd|th)\\b.*?pick'
            match = re.search(pattern, text, re.IGNORECASE)
            if match:
                info['year'] = int(match.group(1))
                info['round'] = int(match.group(2))
                info['pick'] = int(match.group(3))
                return info
            # Simpler pattern: 2012 NFL Draft, 4th round, 102nd overall
            pattern2 = r'(\\d{4}).{0,20}NFL Draft.{0,40}\\b(\\d+)\\w*\\s+round.{0,40}\\b(\\d+)\\w*\\s+overall'
            match2 = re.search(pattern2, text, re.IGNORECASE)
            if match2:
                info['year'] = int(match2.group(1))
                info['round'] = int(match2.group(2))
                info['pick'] = int(match2.group(3))
                return info
            return {}
        except Exception as e:
            logger.debug(f"Wikipedia draft scrape failed: {e}")
            return {}

