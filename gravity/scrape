    def _search_endorsements(self, player_name: str) -> Dict:
        """Search for endorsement deals using LLM verification"""
        results = {
            'endorsements': [],
            'total_value': None
        }
        
        # Search query
        search_query = f"{player_name} endorsement deals sponsors brand ambassador"
        search_url = f"https://www.google.com/search?q={quote(search_query)}"
        
        result = self.scraper.scrape(search_url)
        
        if result and 'markdown' in result:
            text = result['markdown']
            
            # Use LLM to extract and verify real endorsements
            if Config.USE_LLM_PARSING and Config.OPENAI_API_KEY:
                try:
                    extraction_schema = {
                        "endorsements": "List of actual endorsement deals with brands. Only include confirmed, real endorsements - not speculation or false positives. Each should have: brand name, type (deal/ambassador/sponsor), and estimated annual value if available.",
                        "total_endorsement_value": "Total estimated annual endorsement value in USD as a number (e.g., 500000 for $500k, 2000000 for $2M)"
                    }
                    
                    llm_data = self.scraper.scrape_with_llm_parsing(search_url, extraction_schema)
                    
                    if llm_data:
                        # Process LLM-extracted endorsements
                        if 'endorsements' in llm_data and isinstance(llm_data['endorsements'], list):
                            for endorsement in llm_data['endorsements']:
                                if isinstance(endorsement, dict) and 'brand' in endorsement:
                                    brand = endorsement['brand']
                                    # Verify it's a real brand (not garbage)
                                    if brand and len(brand) > 1 and brand.lower() not in ['nfl', 'the', 'and', 'for', 'football']:
                                        results['endorsements'].append(brand)
                        
                        if 'total_endorsement_value' in llm_data and llm_data['total_endorsement_value']:
                            results['total_value'] = float(llm_data['total_endorsement_value'])
                        
                        logger.info(f"LLM extracted {len(results['endorsements'])} verified endorsements for {player_name}")
                        
                        # If we got good LLM data, return it
                        if results['endorsements']:
                            return results
                except Exception as e:
                    logger.debug(f"LLM endorsement extraction failed: {e}, falling back to regex")
            
            # Fallback to regex-based extraction (original method)
            found_brands = set()
            
            for brand in self.major_brands:
                if brand.lower() in text.lower():
                    # Verify it's in endorsement context
                    pattern = f'({brand}[^.]*(?:deal|endorsement|ambassador|partnership|sponsor))'
                    match = re.search(pattern, text, re.IGNORECASE)
                    
                    if match and brand not in found_brands:
                        # Filter out garbage text
                        context = match.group(1)
                        garbage_indicators = ['choose what you', 'delete', 'see more', 'report inappropriate', 
                                            'quick settings', '[ai mode]', 'scheduled upcoming', 'sca_esv=']
                        if not any(indicator in context.lower() for indicator in garbage_indicators):
                            found_brands.add(brand)
                            results['endorsements'].append(brand)
            
            # Look for deal values
            value_pattern = r'\$(\d+(?:\.\d+)?)\s*(million|M|thousand|K)'
            value_matches = re.findall(value_pattern, text)
            
            if value_matches:
                total_value = 0
                for match in value_matches:
                    value = float(match[0])
                    if 'million' in match[1].lower() or match[1] == 'M':
                        value *= 1_000_000
                    elif 'thousand' in match[1].lower() or match[1] == 'K':
                        value *= 1_000
                    total_value += value
                
                results['total_value'] = total_value
        
        # If no value found but we have endorsements, use AI to estimate
        if results['endorsements'] and not results['total_value'] and Config.USE_LLM_PARSING and Config.OPENAI_API_KEY:
            try:
                from openai import OpenAI
                client = OpenAI(api_key=Config.OPENAI_API_KEY)
                
                prompt = f"""Estimate the total annual endorsement value for NFL player {player_name} who has endorsements with: {', '.join(results['endorsements'])}.

Consider:
- Player's position and performance level
- Number of endorsements
- Typical endorsement values for NFL players of similar caliber
- Market rates for these brands

Return ONLY a number representing the estimated total annual endorsement value in USD (e.g., 500000 for $500k, 2000000 for $2M)."""
                
                response = client.chat.completions.create(
                    model="gpt-4o-mini",
                    messages=[{"role": "user", "content": prompt}],
                    temperature=0.3,
                    max_tokens=100
                )
                
                value_text = response.choices[0].message.content.strip()
                # Extract number
                value_match = re.search(r'[\d.]+', value_text.replace(',', ''))
                if value_match:
                    estimated_value = float(value_match.group())
                    # If it's less than 1000, assume it's in millions
                    if estimated_value < 1000:
                        estimated_value *= 1_000_000
                    results['total_value'] = estimated_value
                    logger.info(f"AI estimated endorsement value for {player_name}: ${results['total_value']:,.0f}")
            except Exception as e:
                logger.debug(f"AI endorsement value estimation failed: {e}")
        
        return results
    
    def _search_business_ventures(self, player_name: str) -> Dict:
        """Search for business ventures and investments"""
        results = {
            'ventures': [],
            'investments': []
        }
        
        # Search queries
        queries = [
            f"{player_name} company founder CEO entrepreneur",
            f"{player_name} invested investment startup",
