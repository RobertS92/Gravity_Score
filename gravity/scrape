        ]
        
        for query in queries:
            search_url = f"https://www.google.com/search?q={quote(query)}"
            result = self.scraper.scrape(search_url)
            
            if result and 'markdown' in result:
                text = result['markdown']
                
                # Extract business mentions
                patterns = [
                    r'(?:founded|launched|started|owns)\s+([A-Z][A-Za-z\s&]+(?:LLC|Inc|Corp)?)',
                    r'invested in\s+([A-Z][A-Za-z\s&]+)',
                    r'([A-Z][A-Za-z\s&]+)\s+(?:founder|co-founder|CEO)'
                ]
                
                for pattern in patterns:
                    matches = re.findall(pattern, text)
                    for match in matches:
                        business_name = match.strip()
                        
                        if 3 < len(business_name) < 50:
                            if 'invested' in pattern:
                                results['investments'].append(business_name)
                            else:
                                results['ventures'].append(business_name)
            
            time.sleep(Config.REQUEST_DELAY)
        
        # Remove duplicates
        results['ventures'] = list(set(results['ventures']))[:5]
