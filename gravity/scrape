            if not stats.get("career_passing_yards") and not stats.get("career_rushing_yards") and not stats.get("career_receiving_yards"):
                logger.info(f"📋 PFR Fallback: Collecting stats for {player_name} ({position})...")
                pfr_stats = self._get_pfr_stats(player_name, position)
