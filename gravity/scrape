        # Method 2: Picuki (Instagram viewer) - Firecrawl fallback built into _scrape_with_requests
        if not data.get('instagram_followers'):
            try:
                picuki_url = f"https://www.picuki.com/profile/{handle}"
                html = self._scrape_with_requests(picuki_url)
                if html:
                    # Look for follower count
                    followers_match = re.search(r'([\d,KM]+)\s*Followers', html, re.IGNORECASE)
