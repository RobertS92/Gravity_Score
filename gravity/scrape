        try:
            result = {
                "identity": {},
                "stats": {"current_season": {}, "by_year": {}, "career": {}, "college": {"by_year": {}, "career": {}}},
                "awards": [],
                "injuries": []
            }
            
            # Step 1: Search for player in WNBA
            player_id = self._search_espn_wnba_player(player_name, team)
            if not player_id:
                logger.warning(f"⚠️ ESPN WNBA: Player not found: {player_name}")
                return {}
            
            logger.info(f"🔍 ESPN WNBA: Found {player_name} (ID: {player_id})")
            
            # Step 2: Get player identity from core API
            core_url = f"https://sports.core.api.espn.com/v2/sports/basketball/leagues/wnba/athletes/{player_id}"
            core_resp = self.session.get(core_url, headers=self.espn_headers, timeout=15)
            
            if core_resp.status_code == 200:
                player = core_resp.json()
                
                # Get team ref
                team_ref = player.get("team", {}).get("$ref", "")
                team_name = ""
                if team_ref:
                    try:
                        team_resp = self.session.get(team_ref, headers=self.espn_headers, timeout=5)
                        if team_resp.status_code == 200:
                            team_data = team_resp.json()
                            team_name = team_data.get("displayName", "")
                    except:
                        pass
                
                # Get college name
                college_ref = player.get("college", {}).get("$ref", "") if isinstance(player.get("college"), dict) else ""
                college_name = ""
                if college_ref:
                    try:
                        college_resp = self.session.get(college_ref, headers=self.espn_headers, timeout=5)
                        if college_resp.status_code == 200:
                            college_data = college_resp.json()
                            college_name = college_data.get("name", "")
                    except:
                        pass
                
                # Parse draft info
                draft = player.get("draft", {})
                draft_year = draft.get("year")
                draft_round = draft.get("round")
                draft_pick = draft.get("selection")
                
                # Parse birth place
                birth_place = player.get("birthPlace", {})
                birth_place_str = self._format_birth_place(birth_place)
                
                result["identity"] = {
                    "name": player.get("fullName", ""),
                    "position": player.get("position", {}).get("abbreviation", "") if player.get("position") else "",
                    "jersey": player.get("jersey", ""),
                    "height": player.get("displayHeight", ""),
                    "weight": player.get("displayWeight", ""),
                    "age": player.get("age", 0),
                    "birth_date": player.get("dateOfBirth", ""),
                    "birth_place": birth_place_str,
                    "team": team_name,
                    "college": college_name,
                    "experience": self._get_experience(player.get("experience")),
                    "draft_year": draft_year,
                    "draft_round": draft_round,
                    "draft_pick": draft_pick,
                    "headshot_url": player.get("headshot", {}).get("href", "") if player.get("headshot") else ""
                }
                
                # Parse awards
                for award in player.get("awards", []):
                    result["awards"].append({
                        "name": award.get("name", ""),
                        "year": award.get("year", ""),
                        "type": award.get("type", {}).get("name", "") if isinstance(award.get("type"), dict) else ""
                    })
                
                # Parse injuries
                for injury in player.get("injuries", []):
                    result["injuries"].append({
                        "type": injury.get("type", {}).get("description", ""),
                        "status": injury.get("status", ""),
                        "date": injury.get("date", ""),
                        "details": injury.get("longComment", "")
                    })
            
            # Step 3: Get AWARDS from overview API
            overview_url = f"https://site.api.espn.com/apis/common/v3/sports/basketball/wnba/athletes/{player_id}/overview"
            overview_resp = self.session.get(overview_url, headers=self.espn_headers, timeout=10)
            
            if overview_resp.status_code == 200:
                overview_data = overview_resp.json()
                awards_sections = overview_data.get("awards", [])
                
                for section in awards_sections:
                    award_name = section.get("name", "")
                    seasons = section.get("seasons", [])
                    
                    for year in seasons:
                        result["awards"].append({
                            "name": award_name,
                            "year": int(year) if year else None,
                            "type": award_name
                        })
                    
                    if not seasons and award_name:
                        result["awards"].append({
                            "name": award_name,
                            "count": 1,
                            "type": award_name
                        })
                
                logger.info(f"🏆 WNBA Awards API: Found {len(result['awards'])} award instances for {player_name}")
            
            # Step 4: Get ALL WNBA season-by-season stats
            current_year = datetime.now().year
            draft_year = result["identity"].get("draft_year") or 2020
            start_year = max(draft_year, 2015)  # WNBA data from ~2015+
            
            seasons_found = 0
            consecutive_empty = 0
            
            for season in range(current_year, start_year - 1, -1):
                try:
                    splits_url = f"https://site.api.espn.com/apis/common/v3/sports/basketball/wnba/athletes/{player_id}/splits?season={season}"
                    splits_resp = self.session.get(splits_url, headers=self.espn_headers, timeout=10)
                    
                    if splits_resp.status_code == 200:
                        splits_data = splits_resp.json()
                        season_stats = self._parse_espn_nba_season_stats(splits_data)  # Same format
                        
                        if season_stats and season_stats.get("gamesPlayed", 0):
                            result["stats"]["by_year"][str(season)] = season_stats
                            seasons_found += 1
                            consecutive_empty = 0
                            
                            if season == current_year and not result["stats"]["current_season"]:
                                result["stats"]["current_season"] = season_stats
                        else:
                            consecutive_empty += 1
                    else:
                        consecutive_empty += 1
                    
                    if seasons_found > 0 and consecutive_empty >= 3:
                        break
                        
                except Exception as e:
                    logger.debug(f"Failed to get WNBA {season} stats for {player_name}: {e}")
                    consecutive_empty += 1
            
            logger.info(f"📊 WNBA Stats: Found {seasons_found} WNBA seasons for {player_name}")
            
            # Step 5: Get COLLEGE stats (Women's College Basketball)
            # ESPN uses the same player ID for college and pro careers!
            college_name = result["identity"].get("college", "")
            
            if college_name:
                college_seasons_found = 0
                draft_year = result["identity"].get("draft_year") or 2020
                
                for season in range(draft_year, draft_year - 6, -1):
                    try:
                        college_url = f"https://site.api.espn.com/apis/common/v3/sports/basketball/womens-college-basketball/athletes/{player_id}/splits?season={season}"
                        college_resp = self.session.get(college_url, headers=self.espn_headers, timeout=10)
                        
                        if college_resp.status_code == 200:
                            college_data = college_resp.json()
                            college_stats = self._parse_espn_nba_season_stats(college_data)
                            
                            if college_stats and college_stats.get("gamesPlayed", 0):
                                result["stats"]["college"]["by_year"][str(season)] = college_stats
                                college_seasons_found += 1
                    except Exception as e:
                        logger.debug(f"Failed to get WNCAAB {season} stats for {player_name}: {e}")
                
                if college_seasons_found > 0:
                    result["stats"]["college"]["career"] = self._calculate_nba_career_from_years(result["stats"]["college"]["by_year"])
                    logger.info(f"🎓 College Stats: Found {college_seasons_found} seasons at {college_name}")
            
            # Step 6: Calculate WNBA career totals
            result["stats"]["career"] = self._calculate_nba_career_from_years(result["stats"]["by_year"])
            
            # Count WNBA-specific awards
            award_names = [a.get("name", "").lower() for a in result["awards"]]
            
            result["all_star_selections"] = sum(1 for a in award_names if "all-star" in a and "mvp" not in a)
            result["all_wnba_selections"] = sum(1 for a in award_names if "all-wnba" in a)
            result["all_wnba_first_team"] = sum(1 for a in award_names if "all-wnba 1st" in a)
            result["championships"] = sum(1 for a in award_names if "champion" in a)
            result["mvp_awards"] = sum(1 for a in award_names if a == "mvp" or "wnba mvp" in a)
            result["dpoy_awards"] = sum(1 for a in award_names if "defensive player" in a)
            result["finals_mvp"] = sum(1 for a in award_names if "finals mvp" in a)
            result["all_defensive"] = sum(1 for a in award_names if "all-defensive" in a)
            result["rookie_of_year"] = sum(1 for a in award_names if "rookie of the year" in a)
            
            logger.info(f"📊 WNBA Awards: MVP={result['mvp_awards']}, Finals MVP={result['finals_mvp']}, All-WNBA={result['all_wnba_selections']}")
            
            # Cache and return
            if result["identity"].get("name"):
                self.cache.set(cache_key, result)
                logger.info(f"✅ ESPN API: Complete WNBA data for {player_name} - {result['identity'].get('team', '?')}")
            
            return result
            
        except Exception as e:
            logger.error(f"ESPN complete WNBA data failed for {player_name}: {e}")
            return {}
    
    def _search_espn_wnba_player(self, player_name: str, team: str = None) -> Optional[str]:
        """Search ESPN for WNBA player ID"""
        try:
            # First try direct search
            search_url = f"https://site.web.api.espn.com/apis/common/v3/search?query={quote(player_name)}&limit=10&type=player"
            response = self.session.get(search_url, headers=self.espn_headers, timeout=10)
            
            if response.status_code == 200:
                data = response.json()
                items = data.get("items", [])
                
                for item in items:
                    if item.get("type") == "player":
                        player_id = item.get("id")
                        
                        # Verify by checking WNBA endpoint
                        if player_id:
                            verify_url = f"https://sports.core.api.espn.com/v2/sports/basketball/leagues/wnba/athletes/{player_id}"
                            verify_resp = self.session.get(verify_url, headers=self.espn_headers, timeout=5)
                            if verify_resp.status_code == 200:
                                verify_data = verify_resp.json()
                                if verify_data.get("fullName"):
                                    logger.info(f"✅ ESPN WNBA: Verified {player_name} (ID: {player_id})")
                                    return player_id
            
            # Fallback: search with team name
            if team:
                search_url2 = f"https://site.web.api.espn.com/apis/common/v3/search?query={quote(f'{player_name} {team}')}&limit=10&type=player"
                response2 = self.session.get(search_url2, headers=self.espn_headers, timeout=10)
                
                if response2.status_code == 200:
                    data2 = response2.json()
                    for item in data2.get("items", []):
                        if item.get("type") == "player":
                            player_id = item.get("id")
                            if player_id:
                                verify_url = f"https://sports.core.api.espn.com/v2/sports/basketball/leagues/wnba/athletes/{player_id}"
                                verify_resp = self.session.get(verify_url, headers=self.espn_headers, timeout=5)
                                if verify_resp.status_code == 200:
                                    return player_id
            
            return None
        except Exception as e:
            logger.debug(f"ESPN WNBA search failed: {e}")
            return None
    
