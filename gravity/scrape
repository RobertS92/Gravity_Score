        logger.info(f"Loaded {len(players)} players from {file_path}")
    
    else:
        logger.error(f"Unknown selection mode: {selection}")
        return []
    
    return players

def parse_player_list_from_file(file_path: str) -> List[Dict]:
    """
    Parse player list from text file format:
    Team Name
    - Player Name
    - Player Name
    ...
    
    Or CSV format: Name,Team,Position
    """
    players = []
    current_team = None
    
    try:
        with open(file_path, 'r', encoding='utf-8') as f:
            lines = f.readlines()
        
        for line in lines:
            line = line.strip()
            if not line:
                continue
            
            # Check if it's a team name (no dash prefix, and not a player name pattern)
            if not line.startswith('-') and not ',' in line:
                # This might be a team name
                # Check if next line starts with dash (player list format)
                current_team = line
                continue
            
            # Check if it's CSV format (Name,Team,Position)
            if ',' in line and not line.startswith('-'):
                parts = [p.strip() for p in line.split(',')]
                if len(parts) >= 2:
                    name = parts[0]
                    team = parts[1] if len(parts) > 1 else current_team or "Unknown"
                    position = parts[2] if len(parts) > 2 else "UNK"
                    players.append({
                        "name": name,
                        "team": team,
                        "position": position
                    })
                continue
            
            # Check if it's dash-prefixed player name (text file format)
            if line.startswith('-'):
                player_name = line[1:].strip()
                if player_name and current_team:
                    # Try to get player URL from NFL.com sitemap format
                    # Convert player name to slug format: "Aaron Brewer" -> "aaron-brewer"
                    player_slug = player_name.lower().replace(' ', '-').replace("'", '').replace('.', '')
                    player_url = f"https://www.nfl.com/players/{player_slug}/"
                    
                    players.append({
                        "name": player_name,
                        "team": current_team,
                        "position": "UNK",  # Will be filled from player page if available
                        "player_url": player_url if player_url else _construct_player_url(player_name)  # Add URL for scraping individual player page
                    })
                continue
            
            # If we have a current team and this looks like a player name (two words)
            if current_team and len(line.split()) >= 2:
                players.append({
                    "name": line,
                    "team": current_team,
                    "position": "UNK",
                    "player_url": _construct_player_url(line)  # Construct URL for scraping individual player page
                })
    
    except Exception as e:
        logger.error(f"Error parsing player list file {file_path}: {e}")
        import traceback
        logger.debug(f"Traceback: {traceback.format_exc()}")
    
    return players

