    def _collect_identity(self, player_name: str, team: str, position: str) -> IdentityData:
        """Collect identity data - Uses ESPN API ONLY (no Firecrawl)"""
        identity = IdentityData()
        
        # =====================================================================
        # ESPN API ONLY - Complete player data from ESPN (no Firecrawl)
        # =====================================================================
        try:
            api = get_direct_api()
            espn_data = api.get_complete_nfl_player_data(player_name, team)
            
            if espn_data and espn_data.get("identity"):
                id_data = espn_data["identity"]
                logger.info(f"✅ ESPN API: Complete identity for {player_name} - {id_data.get('team', '?')}")
                
                # Log ESPN data keys for debugging
                logger.debug(f"   ESPN id_data keys: {list(id_data.keys())[:30]}")
                if "displayDraft" in id_data:
                    logger.info(f"   ESPN displayDraft value: '{id_data.get('displayDraft')}'")
                
                # Map ESPN identity data
                identity.age = id_data.get("age")
                identity.birth_date = id_data.get("birth_date", "")
                identity.nationality = "USA"  # Default for NFL players
                
                # Fallback: compute age from birth_date
                if (not identity.age) and identity.birth_date:
                    try:
                        birth_str = identity.birth_date.split('T')[0] if 'T' in identity.birth_date else identity.birth_date
                        from datetime import datetime
                        birth = datetime.strptime(birth_str, '%Y-%m-%d')
                        today = datetime.now()
                        identity.age = today.year - birth.year - ((today.month, today.day) < (birth.month, birth.day))
                        logger.info(f"   ✓ Calculated age from birth_date: {identity.age}")
                    except Exception as e:
                        logger.debug(f"Age calculation failed: {e}")
                
                # Fallback: estimate birth_date from age
                if (not identity.birth_date) and identity.age:
                    try:
                        from datetime import datetime
                        current_year = datetime.now().year
                        estimated_birth_year = current_year - int(identity.age)
                        identity.birth_date = f"{estimated_birth_year}-06-15"
                    except Exception as e:
                        logger.debug(f"Birth date estimation failed: {e}")
                
                # Validate hometown to filter out garbage data
                raw_hometown = id_data.get("birth_place", "")
                identity.hometown = api._validate_hometown(raw_hometown)
                
                identity.height = id_data.get("height", "")
                
                # Parse weight (remove 'lbs' suffix)
                weight_str = str(id_data.get("weight", ""))
                weight_match = re.search(r'(\d+)', weight_str)
                identity.weight = int(weight_match.group(1)) if weight_match else None
                
                identity.college = id_data.get("college", "")
                identity.jersey_number = id_data.get("jersey_number")
                identity.headshot_url = id_data.get("headshot_url", "")
                
                # Draft info - mark as "Undrafted" if missing
                # ================================
                # DRAFT INFO - multi-source
                # ================================
                draft_year = id_data.get("draft_year")
                draft_round = id_data.get("draft_round")
                draft_pick = id_data.get("draft_pick")
                
                # CRITICAL: Reset to None if "Undrafted" string to allow parsing attempts
                if draft_year == "Undrafted" or draft_year == 0:
                    draft_year = None
                    draft_round = None
                    draft_pick = None
                    logger.debug(f"   Resetting draft fields from 'Undrafted' to allow new parsing")
                
                # Source 2: ESPN core data if available in espn_data
                core_draft = espn_data.get("core", {}).get("draft", {}) if isinstance(espn_data.get("core", {}), dict) else {}
                if not draft_year and core_draft:
                    draft_year = core_draft.get("year") or draft_year
                    draft_round = core_draft.get("round") or draft_round
                    draft_pick = core_draft.get("selection") or draft_pick
                
                # Source 2.5: Try displayDraft field (PRIORITY - most reliable)
                if not draft_year:
                    display_draft = id_data.get("displayDraft", "") or id_data.get("draft_display", "")
                    logger.debug(f"   Checking displayDraft field: '{display_draft}'")
                    if display_draft and display_draft != "Undrafted":
                        # Parse "2017: Rd 1, Pk 10 (KC)" format
                        draft_match = re.match(r'(\d{4}):\s*Rd\s*(\d+),\s*Pk\s*(\d+)', display_draft)
                        if draft_match:
                            draft_year = int(draft_match.group(1))
                            draft_round = int(draft_match.group(2))
                            draft_pick = int(draft_match.group(3))
                            logger.info(f"   📋 Draft from displayDraft: {draft_year} Rd {draft_round}, Pk {draft_pick}")
                
                # Source 3: PFR fallback (enhanced with direct HTML parsing)
                if not draft_year:
                    try:
                        # First try the stats_collector method
                        pfr_draft = self.stats_collector._get_pfr_draft_info(player_name)
                        if pfr_draft:
                            draft_year = pfr_draft.get("year") or draft_year
                            draft_round = pfr_draft.get("round") or draft_round
                            draft_pick = pfr_draft.get("pick") or draft_pick
                            if draft_year:
                                logger.info(f"   📋 Draft from PFR API: {draft_year} Rd {draft_round}, Pk {draft_pick}")
                    except Exception:
                        pass
                    
                    # If still no data, try direct PFR HTML scraping
                    if not draft_year:
                        try:
                            last_name_initial = player_name.split()[-1][0].upper()
                            pfr_slug = player_name.replace(' ', '')[0:8].lower()
                            pfr_url = f"https://www.pro-football-reference.com/players/{last_name_initial}/{pfr_slug}01.htm"
                            
                            response = self.session.get(pfr_url, timeout=10)
                            if response.status_code == 200:
                                html = response.text
                                # Look for draft info patterns in HTML
                                # Pattern 1: "Draft: 2017 / Round: 1 / Pick: 10"
                                draft_match = re.search(r'Draft:\s*(\d{4})\s*/\s*Round:\s*(\d+)\s*/\s*Pick:\s*(\d+)', html)
                                if draft_match:
                                    draft_year = int(draft_match.group(1))
                                    draft_round = int(draft_match.group(2))
                                    draft_pick = int(draft_match.group(3))
                                    logger.info(f"   📋 Draft from PFR HTML: {draft_year} Rd {draft_round}, Pk {draft_pick}")
                        except Exception as e:
                            logger.debug(f"PFR HTML draft lookup failed: {e}")
                
                # Source 4: Wikipedia fallback
                if not draft_year:
                    try:
                        wiki_draft = self.stats_collector._get_wikipedia_draft_info(player_name)
                        if wiki_draft:
                            draft_year = wiki_draft.get("year") or draft_year
                            draft_round = wiki_draft.get("round") or draft_round
                            draft_pick = wiki_draft.get("pick") or draft_pick
                    except Exception:
                        pass
                
                # Final assignment - keep as int/None (convert to "Undrafted" string at end of collection)
                if draft_year and isinstance(draft_year, (int, str)) and str(draft_year).isdigit():
                    identity.draft_year = int(draft_year)
                    identity.draft_round = int(draft_round) if draft_round and str(draft_round).isdigit() else None
                    identity.draft_pick = int(draft_pick) if draft_pick and str(draft_pick).isdigit() else None
                else:
                    identity.draft_year = None  # Keep as None for now, convert to "Undrafted" at end
                    identity.draft_round = None
                    identity.draft_pick = None
                
                # Experience - multiple fallback strategies
                experience_years = id_data.get("experience_years", 0)
                
                # If ESPN says 0 but we have draft year, calculate it
                if experience_years == 0 and identity.draft_year and isinstance(identity.draft_year, int):
                    experience_years = datetime.now().year - identity.draft_year
                
                # If still 0 and player has age, estimate (most enter NFL at 21-22)
                if experience_years == 0 and identity.age and identity.age > 21:
                    estimated_draft_age = 22
                    experience_years = identity.age - estimated_draft_age
                    if experience_years < 0:
                        experience_years = 0
                
                identity.years_in_league = experience_years
                
                # Store team for later use
                identity.current_team = id_data.get("team", team)
                
                # Store complete ESPN data for use by other collectors
                self._espn_player_data = espn_data
                
                # =====================================================================
                # RECRUITING DATA - Get college recruiting info (FREE APIs)
                # =====================================================================
                if identity.college:
                    try:
                        draft_year_for_recruiting = identity.draft_year
                        
                        # Estimate draft year if missing but we have age
                        if not draft_year_for_recruiting and identity.age and identity.age > 21:
                            estimated_draft_age = 22  # Most NFL players drafted at 22-23
                            draft_year_for_recruiting = datetime.now().year - (identity.age - estimated_draft_age)
                            logger.info(f"   📅 Estimated draft year {draft_year_for_recruiting} from age {identity.age}")
                        
                        if draft_year_for_recruiting:
                            from gravity.recruiting_collector import RecruitingCollector
                            recruiting_collector = RecruitingCollector()
                            
                            recruiting_data = recruiting_collector.collect_recruiting_data(
                                player_name=player_name,
                                college=identity.college,
                                draft_year=draft_year_for_recruiting,
                                sport='nfl'
                            )
                            
                            # Add recruiting data to identity
                            if recruiting_data:
                                identity.recruiting_stars = recruiting_data.get('recruiting_stars')
                                identity.recruiting_ranking = recruiting_data.get('recruiting_ranking')
                                identity.recruiting_state_ranking = recruiting_data.get('recruiting_state_ranking')
                                identity.recruiting_position_ranking = recruiting_data.get('recruiting_position_ranking')
                                identity.eligibility_year = recruiting_data.get('eligibility_year')
                                logger.info(f"   ⭐ Recruiting: {identity.recruiting_stars}★, Rank #{identity.recruiting_ranking}")
                            
                    except Exception as e:
                        logger.debug(f"Recruiting data collection failed: {e}")
                
                # =====================================================================
                # CONTRACT DATA - Get current contract details (FREE - Spotrac/OTC)
                # =====================================================================
                try:
                    from gravity.contract_collector import ContractCollector
                    contract_collector = ContractCollector()
                    
                    contract_data = contract_collector.collect_contract_data(
                        player_name=player_name,
                        team=team,
                        sport='nfl'
                    )
                    
                    # Map contract data to identity
                    if contract_data:
                        # Contract length in years
                        years = contract_data.get('contract_years')
                        identity.current_contract_length = int(years) if years is not None else None
                        # Total contract value (in dollars)
                        value = contract_data.get('contract_value')
                        identity.contract_value = float(value) if value is not None else None
                        
                    # Store career earnings for later use in proof section
                    self._career_earnings_from_contract = contract_data.get('career_earnings')
                    self._agent_from_contract = contract_data.get('agent')
                    self._management_from_contract = contract_data.get('management_company')
                        
                    if identity.contract_value:
                        logger.info(f"   💰 Contract: {identity.current_contract_length} years, "
                                   f"${identity.contract_value:,}")
                        if self._agent_from_contract:
                            logger.info(f"   🤝 Agent: {self._agent_from_contract}")
                        if self._career_earnings_from_contract:
                            logger.info(f"   💵 Career Earnings: ${self._career_earnings_from_contract:,}")
                    else:
                        logger.warning(f"   ⚠️  No contract data found for {player_name} - will use fallback estimates")
                        
                except Exception as e:
                    logger.warning(f"Contract data collection failed for {player_name}: {e}")
                    import traceback
                    logger.debug(traceback.format_exc())
                
                return identity
                
        except Exception as e:
            logger.warning(f"ESPN API failed for {player_name}: {e}")
        
        # =====================================================================
        # NO FIRECRAWL FALLBACK - ESPN API is the only source for identity
        # If ESPN fails, return what we have (mostly empty)
        # =====================================================================
        
        # Set default nationality for NFL players
        if not identity.nationality:
            identity.nationality = "American"
        
        # Calculate years in league if we have draft year (skip if "Undrafted" string)
        if identity.draft_year and isinstance(identity.draft_year, int):
            identity.years_in_league = datetime.now().year - identity.draft_year
        elif identity.age and identity.age > 21:
            # Estimate: most players enter NFL around age 22-23
            estimated_draft_age = 22
            identity.years_in_league = max(0, identity.age - estimated_draft_age)
        elif not identity.years_in_league:
            identity.years_in_league = 0
        
        return identity
    
    def _validate_and_fill_missing_data(self, player_data: PlayerData, player_name: str, team: str, position: str) -> PlayerData:
        """
        Validate collected data using LLM and fill missing/null fields from fallback sites
        
        Args:
            player_data: Collected player data
            player_name: Player name
            team: Team name
            position: Player position
        
        Returns:
            PlayerData with validated and filled data
        """
        if not Config.USE_LLM_PARSING:
            logger.info("LLM parsing disabled, skipping validation")
            return player_data
        
        # Identify missing/null fields using LLM validation
        missing_fields = self._identify_missing_fields(player_data, player_name)
        
        if not missing_fields:
            logger.info("✓ All critical fields are present, no validation needed")
            return player_data
        
        logger.info(f"⚠️  Found {len(missing_fields)} missing/null fields: {', '.join(str(f) for f in missing_fields)}")
        logger.info("🔍 Attempting to fill missing data from fallback sites...")
        
        # Try fallback sites in order of preference
        fallback_sites = self._get_fallback_sites(player_name, team, position)
        
        for site_name, site_url, extraction_schema in fallback_sites:
            try:
                logger.info(f"Trying fallback site: {site_name} ({site_url[:60]}...)")
                
                # Scrape with Firecrawl + LLM parsing
                llm_data = self.scraper.scrape_with_llm_parsing(site_url, extraction_schema)
                
                if llm_data:
                    # Fill missing fields from this site
                    filled_count = self._fill_missing_fields(player_data, llm_data, missing_fields)
                    
                    if filled_count > 0:
                        logger.info(f"✓ Filled {filled_count} missing fields from {site_name}")
                        missing_fields = [f for f in missing_fields if not self._is_field_filled(player_data, f)]
                        
                        # If all missing fields are filled, we're done
                        if not missing_fields:
                            logger.info("✅ All missing fields have been filled!")
                            break
            except Exception as e:
                logger.debug(f"Failed to get data from {site_name}: {e}")
                continue
        
        # Log final status
        remaining_missing = [f for f in missing_fields if not self._is_field_filled(player_data, f)]
        if remaining_missing:
            logger.warning(f"⚠️  Could not fill {len(remaining_missing)} fields: {', '.join(str(f) for f in remaining_missing)}")
        else:
            logger.info("✅ Successfully filled all missing fields!")
        
        return player_data
    
    def _identify_missing_fields(self, player_data: PlayerData, player_name: str) -> List[str]:
        """
        Use LLM to identify missing or null fields in collected data
        
        Returns:
            List of field names that are missing or null
        """
        # Convert player data to dict for LLM analysis
        data_dict = {
            "identity": {
                "age": player_data.identity.age,
                "height": player_data.identity.height,
                "weight": player_data.identity.weight,
                "college": player_data.identity.college,
                "jersey_number": player_data.identity.jersey_number,
                "birth_date": player_data.identity.birth_date,
                "draft_year": player_data.identity.draft_year,
                "draft_round": player_data.identity.draft_round,
                "draft_pick": player_data.identity.draft_pick,
                "hometown": player_data.identity.hometown,
                "years_in_league": player_data.identity.years_in_league
            },
            "brand": {
                "instagram_followers": player_data.brand.instagram_followers,
                "twitter_followers": player_data.brand.twitter_followers,
                "tiktok_followers": player_data.brand.tiktok_followers,
                "youtube_subscribers": player_data.brand.youtube_subscribers
            },
            "proof": {
                "career_stats": bool(player_data.proof.career_stats),
                "current_season_stats": bool(player_data.proof.current_season_stats),
                "pro_bowls": getattr(player_data.proof, 'pro_bowls', 0) if hasattr(player_data.proof, 'pro_bowls') else getattr(player_data.proof, 'all_star_selections', 0),
                "all_pro_selections": getattr(player_data.proof, 'all_pro_selections', 0) if hasattr(player_data.proof, 'all_pro_selections') else getattr(player_data.proof, 'all_nba_selections', 0)
            }
        }
        
        # Use LLM to identify missing fields
        try:
            # Create a prompt for LLM validation
            data_json = json.dumps(data_dict, indent=2, default=str)
            prompt = f"""Analyze this NFL player data for {player_name} and identify missing or invalid fields:

{data_json}

Return a JSON object with a "missing_fields" array containing field paths that are null, empty, or invalid (e.g., ["identity.height", "identity.weight"]).
Only include fields that are actually missing or invalid, not fields that are legitimately 0 or empty."""
            
            # Call Ollama API
            ollama_url = f"{Config.OLLAMA_BASE_URL}/api/generate"
            payload = {
                "model": Config.OLLAMA_MODEL,
                "prompt": prompt,
                "stream": False,
                "format": "json"
            }
            
            response = requests.post(ollama_url, json=payload, timeout=30)
            
            if response.status_code == 200:
                result = response.json()
                response_text = result.get("response", "")
                
                try:
                    validation_result = json.loads(response_text.strip())
                    missing_fields = validation_result.get("missing_fields", [])
                    if missing_fields:
                        return missing_fields
                except json.JSONDecodeError:
                    pass
            
            # Fallback: manually check for missing fields
            return self._manual_missing_field_check(player_data)
        except Exception as e:
            logger.debug(f"LLM validation failed: {e}, using manual check")
            return self._manual_missing_field_check(player_data)
    
    def _manual_missing_field_check(self, player_data: PlayerData) -> List[str]:
        """Manually check for missing fields (fallback if LLM fails)"""
        missing = []
        
        # Check identity fields
        if not player_data.identity.height:
            missing.append("identity.height")
        if not player_data.identity.weight:
            missing.append("identity.weight")
        if not player_data.identity.college:
            missing.append("identity.college")
        if not player_data.identity.jersey_number:
            missing.append("identity.jersey_number")
        if not player_data.identity.age:
            missing.append("identity.age")
        if not player_data.identity.birth_date:
            missing.append("identity.birth_date")
        if not player_data.identity.draft_year:
            missing.append("identity.draft_year")
        if not player_data.identity.hometown:
            missing.append("identity.hometown")
        
        # Check brand fields (optional, but good to have)
        if not player_data.brand.instagram_followers and not player_data.brand.twitter_followers:
            missing.append("brand.social_media")
        
        # Check proof fields
        if not player_data.proof.career_stats and not player_data.proof.current_season_stats:
            missing.append("proof.stats")
        
        return missing
    
