        r'([A-Z][a-z]+\s+[A-Z][a-z]+),?\s+([A-Z]{1,4}),?\s+(\d{1,2})',
        # Generic: Any capitalized name followed by position (more permissive)
        r'\b([A-Z][a-z]+\s+[A-Z][a-z]+)\s+([A-Z]{2,4})\b',
        # More permissive: First Last followed by position code
        r'([A-Z][a-z]{2,}\s+[A-Z][a-z]{2,})\s+([A-Z]{2,4})',
        # Pattern with commas: "Name, Position #Number" or "Name, Position"
        r'([A-Z][a-z]+\s+[A-Z][a-z]+),?\s+([A-Z]{1,4})\s*#?(\d{1,2})?',
    ]
    
    valid_positions = ['QB', 'RB', 'WR', 'TE', 'OL', 'C', 'G', 'T', 
                      'DL', 'DE', 'DT', 'LB', 'ILB', 'OLB', 
                      'DB', 'CB', 'S', 'FS', 'SS', 'K', 'P', 'LS',
                      'NT', 'EDGE', 'HB', 'FB', 'OT', 'OG', 'LS', 'OLB', 'ILB']
    
    seen_players = set()
    
    # Try full text with more specific patterns (more aggressive)
    logger.info(f"Trying {len(player_patterns)} extraction patterns for {team_name}...")
    for idx, pattern in enumerate(player_patterns):
        pattern_matches = 0
        matches = re.finditer(pattern, text, re.MULTILINE | re.IGNORECASE)
        for match in matches:
            groups = match.groups()
            if len(groups) == 3:
                # Safely check if groups are digits
                group0_str = str(groups[0]) if groups[0] is not None else ""
                group2_str = str(groups[2]) if groups[2] is not None else ""
                
                if group0_str and (group0_str.isdigit() or group0_str.startswith('#')):
                    number = group0_str.replace('#', '').strip()
                    name = str(groups[1]).strip() if groups[1] else ""
                    position = str(groups[2]).strip().upper() if groups[2] else ""
                elif group2_str and group2_str.isdigit():
                    name = str(groups[0]).strip() if groups[0] else ""
                    position = str(groups[1]).strip().upper() if groups[1] else ""
                    number = group2_str.strip()
                else:
                    name = str(groups[0]).strip() if groups[0] else ""
                    position = str(groups[1]).strip().upper() if groups[1] else ""
                    number = None
                    if groups[2] is not None:
                        try:
                            group2_str = str(groups[2])
                            if group2_str.isdigit():
                                number = group2_str.strip()
                        except:
                            number = None
            elif len(groups) == 2:
                name = groups[0].strip()
                position = groups[1].strip().upper()
                number = None
            else:
                continue
            
            # Clean and validate
            name = re.sub(r'\s+', ' ', name).strip()
            position = position.strip().upper()
            
            # Skip if name is too short or doesn't look like a name
            name_parts = name.split()
            if len(name_parts) < 2 or len(name) < 4:
                continue
            
            # Validate position (more lenient - allow 2-4 char positions)
            if position not in valid_positions and len(position) < 2:
                continue
            
            # Skip common false positives
            false_positives = ['Team', 'Player', 'Roster', 'Name', 'Position', 'Number', 
                             'Offense', 'Defense', 'Special', 'Team', 'Total', 'Active',
                             'Inactive', 'Reserve', 'Practice', 'Squad', 'State', 'University',
                             'College', 'School', 'Alabama', 'Texas', 'Florida', 'Georgia',
                             'California', 'Ohio', 'Michigan', 'Pennsylvania', 'North', 'South',
                             'East', 'West', 'Central', 'Southern', 'Northern', 'Western',
                             'Eastern', 'Tech', 'A&M', 'State', 'Carolina', 'Tennessee']
            if any(fp.lower() in name.lower() for fp in false_positives):
                continue
            
            # Skip if it looks like a college name (common patterns)
            if 'state' in name.lower() and len(name.split()) <= 3:
                continue
            if 'university' in name.lower() or 'college' in name.lower():
                continue
            
            # Only accept valid NFL positions - be strict
            valid_positions = ['QB', 'RB', 'WR', 'TE', 'OL', 'C', 'G', 'T', 'DL', 'DE', 'DT', 
                              'LB', 'ILB', 'OLB', 'DB', 'CB', 'S', 'FS', 'SS', 'K', 'P', 'LS', 
                              'NT', 'EDGE', 'HB', 'FB', 'OT', 'OG']
            invalid_positions = ['DEFE', 'OFFE', 'SPEC', 'TOTA', 'ACTI', 'INAC', 'RESE', 'PRAC', 
                               'SQUA', 'TEAM', 'PLAY', 'ROST', 'NAME', 'POSI', 'NUMB']
            
            if position in invalid_positions:
                continue
            
            # Only accept if position is in valid list
            if position in valid_positions:
                player_key = f"{name}_{position}"
                if player_key not in seen_players:
                    seen_players.add(player_key)
                    players.append({
                        'name': name,
                        'position': position,
                        'jersey_number': int(number) if number and number.isdigit() else None,
                        'team': team_name,
                        'player_url': _construct_player_url(name)  # Construct URL for scraping individual player page
                    })
                    pattern_matches += 1
        
        if pattern_matches > 0:
            logger.debug(f"Pattern {idx+1} found {pattern_matches} new players")
    
    logger.info(f"✓ Extracted {len(players)} total players from text for {team_name}")
    
    # Filter out false positives from final list
    logger.info(f"Before filtering: {len(players)} players extracted")
    filtered_players = []
    valid_positions = ['QB', 'RB', 'WR', 'TE', 'OL', 'C', 'G', 'T', 'DL', 'DE', 'DT', 
                      'LB', 'ILB', 'OLB', 'DB', 'CB', 'S', 'FS', 'SS', 'K', 'P', 'LS', 
                      'NT', 'EDGE', 'HB', 'FB', 'OT', 'OG']
    
    for player in players:
        name = player.get('name', '')
        position = player.get('position', '')
        
        # Skip if name contains college/team words
        skip_patterns = ['state', 'university', 'college', 'school', 'tech', 'a&m']
        if any(pattern in name.lower() for pattern in skip_patterns):
            logger.debug(f"Filtered out (college/team name): {name}")
            continue
        
        # Skip if position is invalid
        if position not in valid_positions:
            logger.debug(f"Filtered out (invalid position '{position}'): {name}")
            continue
        
        # Skip if name is too short or doesn't look like a real player name
        name_parts = name.split()
        if len(name_parts) < 2 or len(name) < 6:
            logger.debug(f"Filtered out (name too short): {name}")
            continue
        
        # Skip common false positives
        if any(word in name.lower() for word in ['team', 'player', 'roster', 'total', 'active', 'inactive']):
            logger.debug(f"Filtered out (false positive): {name}")
            continue
        
        filtered_players.append(player)
    
    players = filtered_players
    logger.info(f"After filtering: {len(players)} valid players")
    
    logger.info(f"Final extraction result: {len(players)} players for {team_name}")
    return players

