    def _get_pfr_stats(self, player_name: str, position: str) -> Dict:
        """Get comprehensive stats from Pro Football Reference - career, previous year, current year, and weekly"""
        data = {}
        
        # Try multiple PFR URL patterns
        pfr_urls = []
        
        # Method 1: Generate player code (first 4 letters of last name + first 2 of first)
        parts = player_name.split()
        if len(parts) >= 2:
            last_name = parts[-1]
            first_name = parts[0]
            code = (last_name[:4] + first_name[:2]).title() + "00"
            pfr_urls.append(f"https://www.pro-football-reference.com/players/{code[0]}/{code}.htm")
            
            # Also try with just first letter of first name
            code2 = (last_name[:4] + first_name[0]).title() + "00"
            if code2 != code:
                pfr_urls.append(f"https://www.pro-football-reference.com/players/{code2[0]}/{code2}.htm")
        
        # Method 2: Try search page
        search_url = f"https://www.pro-football-reference.com/search/search.fcgi?search={quote(player_name)}"
        pfr_urls.append(search_url)
        
        for url in pfr_urls:
            try:
                # Try LLM extraction first (more reliable)
                if Config.USE_LLM_PARSING:
                    logger.info(f"Attempting LLM extraction from PFR for {player_name}")
                    llm_data = self.scraper.scrape_with_llm_parsing(
                        url,
                        extraction_schema=self._get_pfr_extraction_schema(position)
                    )
                    if llm_data:
                        # Map LLM extracted data to our format
                        for key, value in llm_data.items():
                            if value is not None:
                                # Handle historical_seasons specially
                                if key == 'historical_seasons' and isinstance(value, list):
                                    data['historical_seasons'] = value
                                # Handle both career_ and current_season_ prefixes
                                elif key.startswith('career_'):
                                    data[key] = value
                                elif key.startswith('current_season_'):
                                    data[key] = value
                                elif key.startswith('last_season_'):
                                    data[key] = value
                                else:
                                    # Try to infer prefix based on context
                                    if 'career' in key.lower() or 'total' in key.lower():
                                        data[f'career_{key}'] = value
                                    else:
                                        current_year = datetime.now().year
                                        data[f'current_season_{key}'] = value
                        
                        # If we got good LLM data, use it
                        if any(v is not None and v != {} and v != [] for v in data.values()):
                            logger.info(f"LLM extraction successful for {player_name}: {len([v for v in data.values() if v is not None])} stats found")
                            if 'historical_seasons' in data and data['historical_seasons']:
                                logger.info(f"Extracted {len(data['historical_seasons'])} historical seasons")
                            break
                
                # Fallback to regex extraction
                result = self.scraper.scrape(url)
                
                if result and 'markdown' in result:
                    text = result['markdown']
                    current_year = datetime.now().year
                    previous_year = current_year - 1
                    
                    # Get position-specific stat patterns
                    position_stats = self._get_position_stat_patterns(position)
                    
                    # Extract career totals with enhanced patterns
                    career_data = self._extract_career_stats_enhanced(text, position, position_stats)
                    data.update(career_data)
                    
                    # Extract previous year stats (last complete season)
                    prev_year_stats = self._extract_season_stats(text, str(previous_year), position, position_stats)
                    for key, value in prev_year_stats.items():
                        if value is not None:
                            data[f'last_season_{key}'] = value
                    
                    # Extract current year stats
                    current_year_stats = self._extract_season_stats(text, str(current_year), position, position_stats)
                    for key, value in current_year_stats.items():
                        if value is not None:
                            data[f'current_season_{key}'] = value
                    
                    # Extract weekly stats for current season (for velocity)
                    weekly_stats = self._extract_weekly_stats(text, str(current_year), position)
                    if weekly_stats:
                        data['weekly_stats'] = weekly_stats
                    
                    # Extract all historical seasons
                    historical_seasons = self._extract_all_seasons(text, position, position_stats)
                    if historical_seasons:
                        data['historical_seasons'] = historical_seasons
                    
                    # If we got good data, break
                    if career_data or prev_year_stats or current_year_stats:
                        break
                
                time.sleep(Config.REQUEST_DELAY)
            except Exception as e:
                logger.debug(f"PFR scrape failed for {url[:50]}: {e}")
                continue
        
        return data
    
    def _extract_career_stats_enhanced(self, text: str, position: str, position_stats: Dict) -> Dict:
        """Enhanced career stats extraction with multiple patterns"""
