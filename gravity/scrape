                        break
        
        return result
    
    def _calculate_career_from_years(self, by_year: Dict) -> Dict:
        """Calculate career totals from year-by-year stats"""
        career = {}
        
        # Stats that should be summed
        sum_stats = [
            "rushingAttempts", "rushingYards", "rushingTouchdowns",
            "receptions", "receivingYards", "receivingTouchdowns",
            "passingAttempts", "passingCompletions", "passingYards", "passingTouchdowns",
            "sacks", "interceptions", "tackles", "forcedFumbles",
            "fumbles", "fumblesLost"
        ]
        
        # Stats that should be averaged
        avg_stats = ["yardsPerRushAttempt", "yardsPerReception"]
        
        for year, stats in by_year.items():
            for stat_name, stat_value in stats.items():
                try:
                    if stat_name in sum_stats:
                        career[stat_name] = career.get(stat_name, 0) + float(stat_value)
                except (ValueError, TypeError):
                    pass
        
        # Calculate averages
        if career.get("rushingAttempts", 0) > 0:
            career["yardsPerRushAttempt"] = round(career.get("rushingYards", 0) / career["rushingAttempts"], 1)
        if career.get("receptions", 0) > 0:
            career["yardsPerReception"] = round(career.get("receivingYards", 0) / career["receptions"], 1)
        
        return career
    
