    def _extract_season_stats(self, text: str, year: str, position: str, patterns: Dict) -> Dict:
        """Extract stats for a specific season with comprehensive coverage"""
        stats = {}
        
        # Look for the year in the text - try multiple patterns
        year_patterns = [
            rf'{year}[^\n]*\n(.*?)(?=\d{{4}}|$)',
            rf'{year}\s+(.*?)(?=\d{{4}}|$)',
            rf'Year\s+{year}[^\n]*\n(.*?)(?=\d{{4}}|$)'
        ]
        
        section_text = ""
        for pattern in year_patterns:
            year_match = re.search(pattern, text, re.DOTALL)
            if year_match:
                section_text = year_match.group(1)
                break
        
        if section_text:
            # Extract stats using position-specific patterns
            for stat_name, pattern in patterns.get('season', {}).items():
                # Adjust pattern to work with year section
                simple_pattern = pattern.replace(rf'(\d{{4}})[^\n]*', '')
                value = self._extract_number(section_text, simple_pattern)
                if value is not None:
                    stats[stat_name] = value
            
            # Also extract common stats that apply to all positions
            # Games played
            if 'games_played' not in stats:
                games_match = re.search(r'G[:\s]+(\d+)', section_text)
                if games_match:
                    stats['games_played'] = int(games_match.group(1))
            
            # Games started
            if 'games_started' not in stats:
                gs_match = re.search(r'GS[:\s]+(\d+)', section_text)
                if gs_match:
                    stats['games_started'] = int(gs_match.group(1))
            
            # Position-specific extractions
            if position == 'QB':
                # Passing stats
                for stat_key, patterns_list in [
                    ('pass_attempts', [r'Att[:\s]+([\d,]+)', r'Attempts[:\s]+([\d,]+)']),
                    ('pass_completions', [r'Cmp[:\s]+([\d,]+)', r'Completions[:\s]+([\d,]+)']),
                    ('pass_yards', [r'Yds[:\s]+([\d,]+)', r'Yards[:\s]+([\d,]+)']),
                    ('pass_tds', [r'TD[:\s]+(\d+)', r'Touchdowns[:\s]+(\d+)']),
                    ('interceptions', [r'Int[:\s]+(\d+)', r'INT[:\s]+(\d+)']),
                    ('passer_rating', [r'Rate[:\s]+([\d.]+)', r'Rating[:\s]+([\d.]+)'])
                ]:
                    if stat_key not in stats:
                        for pattern in patterns_list:
                            match = re.search(pattern, section_text)
                            if match:
                                try:
                                    stats[stat_key] = float(match.group(1).replace(',', ''))
                                    break
                                except:
                                    pass
            
            elif position in ['RB', 'WR', 'TE']:
                # Rushing/Receiving stats
                for stat_key, patterns_list in [
                    ('yards', [r'Yds[:\s]+([\d,]+)', r'Yards[:\s]+([\d,]+)']),
                    ('touchdowns', [r'TD[:\s]+(\d+)', r'Touchdowns[:\s]+(\d+)']),
                    ('receptions', [r'Rec[:\s]+(\d+)', r'Receptions[:\s]+(\d+)']),
                    ('targets', [r'Tgt[:\s]+(\d+)', r'Targets[:\s]+(\d+)'])
                ]:
                    if stat_key not in stats:
                        for pattern in patterns_list:
                            match = re.search(pattern, section_text)
                            if match:
                                try:
                                    stats[stat_key] = int(match.group(1).replace(',', ''))
                                    break
                                except:
                                    pass
            
            elif position in ['DL', 'DE', 'DT', 'LB', 'ILB', 'OLB', 'DB', 'CB', 'S']:
                # Defensive stats
                for stat_key, patterns_list in [
                    ('tackles', [r'Tkl[:\s]+(\d+)', r'Tackles[:\s]+(\d+)']),
                    ('sacks', [r'Sack[:\s]+([\d.]+)', r'Sacks[:\s]+([\d.]+)']),
                    ('interceptions', [r'Int[:\s]+(\d+)', r'INT[:\s]+(\d+)']),
                    ('passes_defended', [r'PD[:\s]+(\d+)', r'Passes Defended[:\s]+(\d+)'])
                ]:
                    if stat_key not in stats:
                        for pattern in patterns_list:
                            match = re.search(pattern, section_text)
                            if match:
                                try:
                                    stats[stat_key] = float(match.group(1).replace(',', ''))
                                    break
                                except:
                                    pass
        
        return stats
    
    def _extract_all_seasons(self, text: str, position: str, patterns: Dict) -> List[Dict]:
        """Extract stats for all historical seasons"""
        seasons = []
        
        # Find all year entries in stats table
        year_matches = re.finditer(r'(\d{4})\s+', text)
        for match in year_matches:
            year = match.group(1)
            if year.isdigit() and 2000 <= int(year) <= datetime.now().year:
                season_stats = self._extract_season_stats(text, year, position, patterns)
                if season_stats:
                    season_stats['year'] = int(year)
                    seasons.append(season_stats)
        
        return seasons
    
    def _organize_stats_by_season(self, stats: Dict, position: str) -> Dict:
        """Organize stats into current_season_stats, last_season_stats, career_stats, and year-by-year breakdowns"""
        organized = {
            'career_stats': {},
            'current_season_stats': {},
            'last_season_stats': {},
            'historical_seasons': []  # List of {year: int, stats: dict}
        }
        
        current_year = datetime.now().year
        previous_year = current_year - 1
        
        # Separate stats by prefix
        for key, value in stats.items():
            if value is None or value == {} or value == []:
                continue
                
            if key.startswith('career_'):
                # Remove 'career_' prefix
                stat_key = key.replace('career_', '')
                organized['career_stats'][stat_key] = value
            elif key.startswith(f'current_season_{current_year}_'):
                # Handle format: current_season_2025_pass_yards -> pass_yards
                stat_key = key.replace(f'current_season_{current_year}_', '')
                organized['current_season_stats'][stat_key] = value
            elif key.startswith('current_season_'):
                # Handle format: current_season_pass_yards -> pass_yards
                stat_key = key.replace('current_season_', '')
                # Remove year suffix if present (e.g., current_season_2025_pass_yards)
                if stat_key.startswith(f'{current_year}_'):
                    stat_key = stat_key.replace(f'{current_year}_', '')
                organized['current_season_stats'][stat_key] = value
            elif key.startswith(f'last_season_{previous_year}_'):
                # Handle format: last_season_2024_pass_yards -> pass_yards
                stat_key = key.replace(f'last_season_{previous_year}_', '')
                organized['last_season_stats'][stat_key] = value
            elif key.startswith('last_season_'):
                # Handle format: last_season_pass_yards -> pass_yards
                stat_key = key.replace('last_season_', '')
                # Remove year suffix if present
                if stat_key.startswith(f'{previous_year}_'):
                    stat_key = stat_key.replace(f'{previous_year}_', '')
                organized['last_season_stats'][stat_key] = value
            elif key == 'historical_seasons' and isinstance(value, list):
                # Keep historical seasons list
                organized['historical_seasons'] = value
            elif key == 'weekly_stats' and isinstance(value, list):
                # Keep weekly stats
                organized['weekly_stats'] = value
            else:
                # Keep other stats (awards, bio, etc.)
                organized[key] = value
        
        return organized
    
