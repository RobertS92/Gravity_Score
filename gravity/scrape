            if not stats:
                continue
            
            games = parse_num(stats.get('gamesPlayed', 0))
            total_games += games
            
            # Get per-game averages and multiply by games
            ppg = parse_num(stats.get('avgPoints', 0))
            rpg = parse_num(stats.get('avgRebounds', 0))
            apg = parse_num(stats.get('avgAssists', 0))
            spg = parse_num(stats.get('avgSteals', 0))
            bpg = parse_num(stats.get('avgBlocks', 0))
            mpg = parse_num(stats.get('avgMinutes', 0))
            
            total_points += ppg * games
            total_rebounds += rpg * games
            total_assists += apg * games
            total_steals += spg * games
            total_blocks += bpg * games
            total_minutes += mpg * games
        
        career['career_games'] = int(total_games)
        career['career_points'] = int(total_points)
        career['career_rebounds'] = int(total_rebounds)
        career['career_assists'] = int(total_assists)
        career['career_steals'] = int(total_steals)
        career['career_blocks'] = int(total_blocks)
        career['career_minutes'] = int(total_minutes)
        
        # Calculate career averages
        if total_games > 0:
            career['career_ppg'] = round(total_points / total_games, 1)
            career['career_rpg'] = round(total_rebounds / total_games, 1)
            career['career_apg'] = round(total_assists / total_games, 1)
            career['career_spg'] = round(total_steals / total_games, 1)
            career['career_bpg'] = round(total_blocks / total_games, 1)
            career['career_mpg'] = round(total_minutes / total_games, 1)
        
        return career
    
