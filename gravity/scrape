                return result
        
        return result
    
    def _repair_json(self, json_str: str) -> Optional[Dict]:
        """Attempt to repair common JSON issues like unterminated strings."""
        try:
            # First, try to extract JSON from text if wrapped
            json_match = re.search(r'\{.*\}', json_str, re.DOTALL)
            if json_match:
                json_str = json_match.group()
            
            # Try direct parse first
            try:
                return json.loads(json_str.strip())
            except json.JSONDecodeError:
                pass
            
            # Try to fix common issues
            # Fix unterminated strings by closing them
            lines = json_str.split('\n')
            fixed_lines = []
            in_string = False
            escape_next = False
            
            for i, line in enumerate(lines):
                fixed_line = line
                for j, char in enumerate(line):
                    if escape_next:
                        escape_next = False
                        continue
                    if char == '\\':
                        escape_next = True
                        continue
                    if char == '"':
                        in_string = not in_string
                
                # If we're still in a string at end of line, close it
                if in_string and i < len(lines) - 1:
                    # Find last quote position and add closing quote
                    last_quote_idx = fixed_line.rfind('"')
                    if last_quote_idx >= 0:
                        # Check if it's actually closing a string
                        before_quote = fixed_line[:last_quote_idx]
                        if before_quote.count('"') % 2 == 1:  # Odd number means we opened a string
                            # Try to close it intelligently
                            fixed_line = fixed_line.rstrip() + '"'
                            in_string = False
                
                fixed_lines.append(fixed_line)
            
            fixed_json = '\n'.join(fixed_lines)
            try:
                return json.loads(fixed_json)
            except json.JSONDecodeError:
                pass
            
            # Last resort: try to extract just the first valid JSON object
            # Find the first { and try to parse incrementally
            start_idx = json_str.find('{')
            if start_idx >= 0:
                for end_idx in range(len(json_str), start_idx, -1):
                    try:
                        candidate = json_str[start_idx:end_idx]
                        if candidate.count('{') == candidate.count('}'):
                            return json.loads(candidate)
                    except json.JSONDecodeError:
                        continue
            
            return None
        except Exception as e:
            logger.debug(f"JSON repair failed: {e}")
            return None
    
    def _convert_page_to_json(self, scrape_result: Dict) -> Dict:
        """Convert scraped page to JSON format for LLM parsing - use FULL markdown from Firecrawl"""
        # Use the full markdown from Firecrawl - don't truncate
        # Firecrawl provides clean markdown that's perfect for LLM parsing
        markdown_content = scrape_result.get("markdown", "")
        
        json_data = {
            "url": scrape_result.get("url", scrape_result.get("sourceURL", "")),
            "title": scrape_result.get("metadata", {}).get("title", ""),
            "description": scrape_result.get("metadata", {}).get("description", ""),
            "markdown": markdown_content,  # Full markdown - not truncated
            "links": scrape_result.get("links", []),
            "screenshot": scrape_result.get("screenshot", None)
        }
        
        # Include HTML snippet if markdown is empty or very short (fallback)
        if "html" in scrape_result and (not markdown_content or len(markdown_content) < 100):
            json_data["html_snippet"] = scrape_result["html"][:10000]  # More HTML if needed
        
        return json_data
    
    def _llm_parse_page(self, page_json: Dict, extraction_schema: Dict = None) -> Dict:
        """
        Use LLM to parse structured data from page JSON
        
        Strategy:
        1. Try OpenAI first (faster, more reliable, better JSON parsing)
           - Uses gpt-4o-mini (fast and cost-effective)
           - Has JSON mode for reliable parsing
           - Handles larger content (15k-30k chars)
        2. Fall back to Ollama if OpenAI fails or isn't available
           - Free, runs locally
           - Slower, may timeout on large content
           - Uses smaller content chunks (10k-20k chars)
        3. If both fail, returns empty dict (triggers regex fallback)
        
        Args:
            page_json: Page data from Firecrawl (with markdown)
            extraction_schema: Schema defining what to extract
        
        Returns:
            Parsed structured data as dict
        """
        if not Config.USE_LLM_PARSING:
            return {}
        
        try:
            # Default extraction schema for social media
            if not extraction_schema:
                extraction_schema = {
                    "twitter_followers": "Extract Twitter/X follower count as integer",
                    "instagram_followers": "Extract Instagram follower count as integer",
                    "tiktok_followers": "Extract TikTok follower count as integer",
                    "youtube_subscribers": "Extract YouTube subscriber count as integer",
                    "verified": "Extract verification status as boolean",
                    "handle": "Extract social media handle"
                }
            
            # Build prompt for LLM - use FULL markdown from Firecrawl
            # Firecrawl markdown is clean and perfect for LLM parsing
            markdown_content = page_json.get("markdown", "")
            url = page_json.get("url", "")
            title = page_json.get("title", "")
            
            # Limit markdown size to avoid timeouts
            # For roster pages, use smaller chunks (15k chars max for OpenAI, 10k for Ollama)
            # For other pages, use 30k chars max for OpenAI, 20k for Ollama
            is_roster = "roster" in url.lower() or "players" in url.lower()
            max_chars_openai = 15000 if is_roster else 30000
            max_chars_ollama = 10000 if is_roster else 20000
            
            # Truncate markdown intelligently
            def truncate_content(content: str, max_len: int) -> str:
                if len(content) <= max_len:
                    return content
                truncated = content[:max_len]
                last_newline = truncated.rfind('\n')
                if last_newline > max_len * 0.8:  # If we can find a newline in the last 20%
                    return truncated[:last_newline] + "\n\n[Content truncated...]"
                return truncated + "\n\n[Content truncated...]"
            
            schema_str = json.dumps(extraction_schema, indent=2)
            
            # Optimize prompt for roster pages (shorter, more focused)
            if is_roster:
                prompt = f"""Extract player roster data from this NFL team roster page.

URL: {url}

Roster Content (Markdown):
{truncate_content(markdown_content, max_chars_openai)}

Extraction Schema:
{schema_str}

IMPORTANT: Extract ALL players from the roster table/list. Return ONLY valid JSON with the "players" array.
Each player should have: name, position (or 'UNK'), and jersey_number (if available).
Return only the JSON, no other text."""
            else:
                prompt = f"""Extract the following data from this webpage. The page content is provided as clean markdown from Firecrawl.

URL: {url}
Title: {title}

Page Content (Markdown):
{truncate_content(markdown_content, max_chars_openai)}

Extraction Schema:
{schema_str}

Please extract the requested data and return ONLY a valid JSON object with the extracted values. 
If a value is not found, use null. Return only the JSON, no other text.
Focus on the actual content - ignore navigation, headers, footers, and ads."""

            # Try OpenAI first (faster, more reliable) if enabled
            if Config.OPENAI_API_KEY and Config.PREFER_OPENAI:
                try:
                    logger.debug("Trying OpenAI for LLM parsing...")
                    from openai import OpenAI
                    
                    client = OpenAI(api_key=Config.OPENAI_API_KEY)
                    
                    # Retry logic for OpenAI (up to 2 attempts)
                    for openai_attempt in range(2):
                        try:
                            # Use OpenAI with JSON mode for better parsing
                            response = client.chat.completions.create(
                                model="gpt-4o-mini",  # Faster and cheaper than gpt-4o
                                messages=[
                                    {
                                        "role": "system",
                                        "content": "You are a data extraction assistant. Extract structured data from web pages and return ONLY valid JSON. Do not include any explanatory text. Ensure all strings are properly escaped and closed."
                                    },
                                    {
                                        "role": "user",
                                        "content": prompt
                                    }
                                ],
                                response_format={"type": "json_object"},  # Force JSON output
                                temperature=0.1,  # Low temperature for consistent extraction
                                max_tokens=4000 if is_roster else 2000
                            )
                            
                            response_text = response.choices[0].message.content
                            
                            # Try to parse JSON response
                            parsed = None
                            
                            # First, try direct parse
                            try:
                                parsed = json.loads(response_text.strip())
                                logger.info(f"✓ OpenAI successfully parsed JSON from {url[:50]}")
                                return parsed
                            except json.JSONDecodeError:
                                # Try JSON repair
                                logger.debug(f"OpenAI JSON parse failed, attempting repair (attempt {openai_attempt + 1})...")
                                parsed = self._repair_json(response_text)
                                if parsed:
                                    logger.info(f"✓ OpenAI JSON repaired and parsed from {url[:50]}")
                                    return parsed
                            
                            # If repair failed, try extracting JSON from response text
                            if not parsed:
                                json_match = re.search(r'\{.*\}', response_text, re.DOTALL)
                                if json_match:
                                    try:
                                        parsed = json.loads(json_match.group())
                                        logger.info(f"✓ OpenAI extracted JSON from response text")
                                        return parsed
                                    except json.JSONDecodeError:
                                        # Try repairing the extracted JSON
                                        parsed = self._repair_json(json_match.group())
                                        if parsed:
                                            logger.info(f"✓ OpenAI repaired extracted JSON")
                                            return parsed
                            
                            # If we get here, parsing failed
                            if openai_attempt == 0:
                                logger.warning(f"OpenAI returned invalid JSON on attempt 1, retrying...")
                                # Wait a bit before retry
                                time.sleep(0.5)
                            else:
                                logger.warning(f"OpenAI returned invalid JSON after 2 attempts: {response_text[:200]}")
                                # Fall through to Ollama
                                
                        except Exception as e:
                            if openai_attempt == 0:
                                logger.warning(f"OpenAI request failed on attempt 1: {e}, retrying...")
                                time.sleep(0.5)
                                continue
                            else:
                                logger.warning(f"OpenAI request failed after 2 attempts: {e}, falling back to Ollama")
                                break
                    
                    # If we exhausted retries, fall through to Ollama
                    
                except ImportError:
                    logger.debug("OpenAI library not available, using Ollama")
                except Exception as e:
                    logger.warning(f"OpenAI parsing failed: {e}, falling back to Ollama")
                    # Fall through to Ollama fallback
            
            # Fallback to Ollama if OpenAI failed or isn't available
            logger.debug("Using Ollama for LLM parsing (OpenAI unavailable or failed)")
            ollama_url = f"{Config.OLLAMA_BASE_URL}/api/generate"
            
            # Use smaller content for Ollama (it's slower)
            ollama_markdown = truncate_content(markdown_content, max_chars_ollama)
            if is_roster:
                ollama_prompt = f"""Extract player roster data from this NFL team roster page.

URL: {url}

Roster Content (Markdown):
{ollama_markdown}

Extraction Schema:
{schema_str}

IMPORTANT: Extract ALL players from the roster table/list. Return ONLY valid JSON with the "players" array.
Each player should have: name, position (or 'UNK'), and jersey_number (if available).
Return only the JSON, no other text."""
            else:
                ollama_prompt = f"""Extract the following data from this webpage. The page content is provided as clean markdown from Firecrawl.

URL: {url}
Title: {title}

Page Content (Markdown):
{ollama_markdown}

Extraction Schema:
{schema_str}

Please extract the requested data and return ONLY a valid JSON object with the extracted values. 
If a value is not found, use null. Return only the JSON, no other text.
Focus on the actual content - ignore navigation, headers, footers, and ads."""
            
            payload = {
                "model": Config.OLLAMA_MODEL,
                "prompt": ollama_prompt,
                "stream": False,
                "format": "json"
            }
            
            # Retry logic for Ollama API calls with adaptive timeout
            base_timeout = 30 if is_roster else 45
            response = None
            
            for attempt in range(2):  # Reduced to 2 attempts to fail faster and use regex fallback
                try:
                    # Increase timeout on retry
                    timeout = base_timeout + (attempt * 15)
                    response = requests.post(ollama_url, json=payload, timeout=timeout)
                    if response.status_code == 200:
                        break
                    elif response.status_code == 429:
                        wait_time = (2 ** attempt) * 2
                        logger.warning(f"Ollama rate limited, waiting {wait_time}s...")
                        time.sleep(wait_time)
                        continue
                    else:
                        logger.warning(f"Ollama returned {response.status_code}, attempt {attempt + 1}/2")
                        if attempt < 1:
                            time.sleep(1)
                            continue
                except requests.exceptions.Timeout:
                    logger.warning(f"Ollama timeout on attempt {attempt + 1}/2 (timeout={timeout}s)")
                    # On timeout, return empty dict immediately to trigger regex fallback
                    if attempt == 1:  # Last attempt
                        logger.warning("Ollama timeout - will use regex fallback")
                        return {}
                    time.sleep(1)
                    continue
                except Exception as e:
                    logger.warning(f"Ollama request error on attempt {attempt + 1}/2: {e}")
                    if attempt < 1:
                        time.sleep(1)
                        continue
            
            if not response or response.status_code != 200:
                logger.warning(f"LLM parsing failed after 2 attempts - will use regex fallback")
                return {}
            
            if response.status_code == 200:
                result = response.json()
                response_text = result.get("response", "")
                
                # Try to parse JSON from response
                try:
                    # Try to parse as complete JSON first
                    try:
                        parsed = json.loads(response_text.strip())
                        logger.info(f"✓ Ollama parsed complete JSON from {url[:50]}")
                        return parsed
                    except json.JSONDecodeError:
                        # Try to extract JSON from response (might have extra text)
                        json_match = re.search(r'\{.*\}', response_text, re.DOTALL)
                        if json_match:
                            parsed = json.loads(json_match.group())
                            logger.info(f"✓ Ollama parsed JSON from response text")
                            return parsed
                except json.JSONDecodeError as e:
                    logger.warning(f"Failed to parse Ollama JSON response: {e}")
                    logger.warning(f"Response text (first 500 chars): {response_text[:500]}")
            
        except Exception as e:
            logger.warning(f"LLM parsing failed: {e}")
        
        return {}

