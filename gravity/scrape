class PlayerDatabase:
    """SQLite database for storing player data efficiently"""
    
    def __init__(self, db_path: str = None):
        self.db_path = db_path or Config.DATABASE_PATH
        self._init_db()
    
    def _init_db(self):
        """Initialize database schema"""
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        
        # Create players table
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS players (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                player_name TEXT NOT NULL,
                team TEXT,
                position TEXT,
                collection_timestamp TEXT,
                data_json TEXT,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                UNIQUE(player_name, team)
            )
        ''')
        
        # Create index for faster lookups
        cursor.execute('''
            CREATE INDEX IF NOT EXISTS idx_player_team 
            ON players(player_name, team)
        ''')
        
        conn.commit()
        conn.close()
        logger.info(f"Database initialized at {self.db_path}")
    
    def insert_or_replace(self, player_data: Dict):
        """Insert or replace player data"""
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        
        player_name = player_data.get('player_name', '')
        team = player_data.get('team', '')
        position = player_data.get('position', '')
        collection_timestamp = player_data.get('collection_timestamp', datetime.now().isoformat())
        data_json = json.dumps(player_data, default=str)
        
        cursor.execute('''
            INSERT OR REPLACE INTO players 
            (player_name, team, position, collection_timestamp, data_json, updated_at)
            VALUES (?, ?, ?, ?, ?, CURRENT_TIMESTAMP)
        ''', (player_name, team, position, collection_timestamp, data_json))
        
        conn.commit()
        conn.close()
    
    def bulk_insert(self, players_data: List[Dict]):
        """Bulk insert for better performance"""
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        
        data_tuples = []
        for player_data in players_data:
            player_name = player_data.get('player_name', '')
            team = player_data.get('team', '')
            position = player_data.get('position', '')
            collection_timestamp = player_data.get('collection_timestamp', datetime.now().isoformat())
            data_json = json.dumps(player_data, default=str)
            data_tuples.append((player_name, team, position, collection_timestamp, data_json))
        
        cursor.executemany('''
            INSERT OR REPLACE INTO players 
            (player_name, team, position, collection_timestamp, data_json, updated_at)
            VALUES (?, ?, ?, ?, ?, CURRENT_TIMESTAMP)
        ''', data_tuples)
        
        conn.commit()
        conn.close()
        logger.info(f"Bulk inserted {len(players_data)} players into database")
    
    def get_player(self, player_name: str, team: str = None) -> Optional[Dict]:
        """Get player data from database"""
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        
        if team:
            cursor.execute('''
                SELECT data_json FROM players 
                WHERE player_name = ? AND team = ?
            ''', (player_name, team))
        else:
            cursor.execute('''
                SELECT data_json FROM players 
                WHERE player_name = ?
                ORDER BY updated_at DESC
                LIMIT 1
            ''', (player_name,))
        
        row = cursor.fetchone()
        conn.close()
        
        if row:
            return json.loads(row[0])
        return None
    
    def get_all_players(self) -> List[Dict]:
        """Get all players from database"""
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        
        cursor.execute('SELECT data_json FROM players')
        rows = cursor.fetchall()
        conn.close()
        
        return [json.loads(row[0]) for row in rows]

