            'follower_growth_rate_30d': True,
            'follower_growth_rate_7d': True,
            'media_buzz_surge': True,
            'current_injury_status': True,
            'contract_status': True,
            'endorsements': True,  # New deals can happen
            'endorsement_value': True,
        }
        
        # Stable fields (reuse if quality is good)
        stable_fields = {
            'identity': ['birth_date', 'height', 'weight', 'college', 'draft_year', 'draft_round', 
                        'draft_pick', 'hometown', 'nationality', 'years_in_league'],
            'career_stats': True,  # Historical stats don't change
            'career_stats_by_year': True,
            'pro_bowls_by_year': True,
            'super_bowl_wins_by_year': True,
            'all_pro_selections_by_year': True,
            'playoff_appearances_by_year': True,
        }
        
        # Check age of data
        try:
            old_timestamp = old_data.get('collection_timestamp', '')
            if old_timestamp and date_parser:
                old_date = date_parser.parse(old_timestamp)
                if old_date.tzinfo:
                    old_date = old_date.replace(tzinfo=None)
                days_old = (datetime.now() - old_date).days
            elif old_timestamp:
                # Fallback parsing
                try:
                    old_date = datetime.fromisoformat(old_timestamp.replace('Z', '+00:00'))
                    if old_date.tzinfo:
                        old_date = old_date.replace(tzinfo=None)
                    days_old = (datetime.now() - old_date).days
                except:
                    days_old = 999
            else:
                days_old = 999
        except:
            days_old = 999
        
        # If data is very recent (< 7 days), be more selective about updates
        if days_old < 7:
            # Only update truly time-sensitive fields
            for field in time_sensitive_fields:
                update_flags[field] = True
            # Reuse stable fields
            for field in stable_fields:
                if isinstance(stable_fields[field], list):
                    for subfield in stable_fields[field]:
                        update_flags[f"{field}.{subfield}"] = False
                else:
                    update_flags[field] = False
        else:
            # Data is older, update more fields but still reuse stable historical data
            for field in time_sensitive_fields:
                update_flags[field] = True
            # Reuse historical data
            for field in ['career_stats', 'career_stats_by_year', 'pro_bowls_by_year', 
                         'super_bowl_wins_by_year', 'all_pro_selections_by_year', 
                         'playoff_appearances_by_year']:
                update_flags[field] = False
        
        return update_flags
    
    def _merge_old_and_new_data(self, old_data: Dict, new_data: PlayerData, update_flags: Dict[str, bool]) -> PlayerData:
        """Merge old and new data, reusing stable fields from old data"""
        # Convert old data to PlayerData if needed
        try:
            # Reuse stable identity fields
            if not update_flags.get('identity', {}):
                old_identity = old_data.get('identity', {})
                if old_identity and new_data.identity:
                    # Only reuse if new data is missing these fields
                    # IMPORTANT: Exclude draft fields to allow new parsing attempts (displayDraft, PFR, etc.)
                    for field in ['birth_date', 'height', 'weight', 'college', 'hometown', 'nationality']:
                        if not getattr(new_data.identity, field, None) and old_identity.get(field):
                            setattr(new_data.identity, field, old_identity[field])
                            logger.debug(f"   Reused {field} from previous data")
            
            # Reuse historical stats
            if not update_flags.get('career_stats', True) and old_data.get('proof', {}):
                old_proof = old_data.get('proof', {})
                if old_proof and new_data.proof:
                    # Reuse career stats if new ones are empty or incomplete
                    if not new_data.proof.career_stats or len(new_data.proof.career_stats) < 5:
                        if old_proof.get('career_stats'):
                            new_data.proof.career_stats = old_proof['career_stats']
                            logger.info("   Reused career_stats from previous data")
                    
                    # Reuse year-by-year data
                    for year_field in ['career_stats_by_year', 'pro_bowls_by_year', 
                                      'super_bowl_wins_by_year', 'all_pro_selections_by_year',
                                      'playoff_appearances_by_year']:
                        if not update_flags.get(year_field, True):
                            if old_proof.get(year_field) and not getattr(new_data.proof, year_field, {}):
                                setattr(new_data.proof, year_field, old_proof[year_field])
                                logger.info(f"   Reused {year_field} from previous data")
        except Exception as e:
            logger.warning(f"Error merging old data: {e}")
        
        return new_data
    
    def collect_player_data(self, player_name: str, team: str, position: str) -> PlayerData:
        """
        Collect ALL data for a player using parallel execution for speed
        Checks previous scrapes and only updates time-sensitive data
        
        Args:
            player_name: Player's full name
            team: Current NFL team
            position: Player position (QB, RB, WR, etc.)
        
        Returns:
            Complete PlayerData object
        """
        logger.info(f"{'='*70}")
        logger.info(f"Starting comprehensive data collection for {player_name}")
        logger.info(f"Team: {team}, Position: {position}")
        logger.info(f"{'='*70}")
        
        # Check for previous data
        old_data = self._find_previous_player_data(player_name)
        if old_data:
            logger.info(f"📦 Found previous data, will merge with new collection")
            # Assess what needs updating
            # (We'll create update_flags after collecting new data to compare)
        
        # Initialize player data
        player_data = PlayerData(
            player_name=player_name,
            team=team,
            position=position
        )
        
        # Store position and team for enhanced social collector validation
        self._current_position = position
        self._current_team = team
        
        try:
            # STEP 1: Collect Identity first (needed for age in Velocity and Risk)
            logger.info("📋 Collecting identity data...")
            identity_data = self._collect_identity(player_name, team, position)
            player_data.identity = identity_data
            age = identity_data.age if identity_data else None
            
            # If we have old data, merge stable identity fields
            if old_data:
                old_identity = old_data.get('identity', {})
                if old_identity:
                    # Reuse stable fields if new collection is missing them
                    # IMPORTANT: Exclude draft fields to allow new parsing attempts (displayDraft, PFR, etc.)
                    for field in ['birth_date', 'height', 'weight', 'college', 'hometown', 'nationality']:
                        if not getattr(identity_data, field, None) and old_identity.get(field):
                            setattr(identity_data, field, old_identity[field])
                            logger.info(f"   ✓ Reused {field} from previous data")
            
            player_data.identity = identity_data
            
            # STEP 2: Collect all other data categories in parallel
            logger.info("🚀 Starting parallel data collection...")
            
            # Prepare parallel tasks (increased workers for speed)
            max_workers = Config.MAX_CONCURRENT_DATA_COLLECTORS
            with ThreadPoolExecutor(max_workers=max_workers) as executor:
                # Submit all independent tasks
                future_brand = executor.submit(self._collect_brand, player_name)
                future_proof = executor.submit(self._collect_proof, player_name, position)
                future_proximity = executor.submit(self._collect_proximity, player_name, 
                                                    getattr(self, '_agent_from_contract', None),
                                                    getattr(self, '_management_from_contract', None),
                                                    None,  # team_captain - to be implemented
                                                    None)  # leadership_role - to be implemented
                future_velocity = executor.submit(self._collect_velocity, player_name, age, position)
                future_risk = executor.submit(self._collect_risk, player_name, position, age)
                
                # Collect results as they complete
                results = {}
                futures_map = {
                    'brand': future_brand,
                    'proof': future_proof,
                    'proximity': future_proximity,
                    'velocity': future_velocity,
                    'risk': future_risk
                }
                
                # Wait for all to complete and collect results
                for category, future in futures_map.items():
                    try:
                        logger.info(f"⏳ Waiting for {category} data...")
                        result = future.result(timeout=300)  # 5 minute timeout per category
                        results[category] = result
                        logger.info(f"✅ {category.capitalize()} data collected")
                    except Exception as e:
                        logger.error(f"❌ Error collecting {category} data: {e}")
                        # Still create empty data structure - never skip
                        if category == 'brand':
                            results[category] = BrandData()
                        elif category == 'proof':
                            results[category] = ProofData()
                        elif category == 'proximity':
                            results[category] = ProximityData()
                        elif category == 'velocity':
                            results[category] = VelocityData()
                        elif category == 'risk':
                            results[category] = RiskData()
                        player_data.collection_errors.append(f"{category}: {str(e)}")
            
            # Assign results to player_data
            player_data.brand = results.get('brand', BrandData())
            player_data.proof = results.get('proof', ProofData())
            player_data.proximity = results.get('proximity', ProximityData())
            player_data.velocity = results.get('velocity', VelocityData())
            player_data.risk = results.get('risk', RiskData())
            
            # Calculate data quality score
            player_data.data_quality_score = self._calculate_quality_score(player_data)
            
            # STEP 3: Validate data with LLM and fill missing/null fields from fallback sites
            logger.info("🔍 Validating collected data and filling missing fields...")
            player_data = self._validate_and_fill_missing_data(player_data, player_name, team, position)
            
        except Exception as e:
            logger.error(f"Error collecting data: {str(e)}")
            player_data.collection_errors.append(str(e))
            # Ensure all data structures exist even on error
            if not player_data.identity:
                player_data.identity = IdentityData()
            if not player_data.brand:
                player_data.brand = BrandData()
            if not player_data.proof:
                player_data.proof = ProofData()
            if not player_data.proximity:
                player_data.proximity = ProximityData()
            if not player_data.velocity:
                player_data.velocity = VelocityData()
            if not player_data.risk:
                player_data.risk = RiskData()
        
        logger.info(f"{'='*70}")
        logger.info(f"✅ Data collection complete for {player_name}")
        logger.info(f"Data quality score: {player_data.data_quality_score}%")
        logger.info(f"{'='*70}")
        
        # AI Fallback for draft data (verify "Undrafted" players)
        if player_data.identity and self.perplexity and self.perplexity.enabled:
            if (player_data.identity.draft_year is None or 
                player_data.identity.draft_year == 0 or
                player_data.identity.draft_year == "Undrafted"):
                
                logger.info(f"🤖 AI verifying draft status for {player_name}...")
                context = {
                    'position': position,
                    'team': team,
                    'college': player_data.identity.college
                }
                
                ai_draft = self.perplexity.search_missing_field(
                    player_name, 'draft_year', 'NFL', context
                )
                
                if ai_draft and ai_draft != "Undrafted":
                    player_data.identity.draft_year = ai_draft
                    player_data.identity.draft_round = self.perplexity.search_missing_field(
                        player_name, 'draft_round', 'NFL', context
                    )
                    player_data.identity.draft_pick = self.perplexity.search_missing_field(
                        player_name, 'draft_pick', 'NFL', context
                    )
                    logger.info(f"✅ AI corrected draft: {ai_draft} Rd {player_data.identity.draft_round}")
        
        # FINAL STEP: AI Fallback for ALL remaining missing fields
        if self.perplexity and self.perplexity.enabled and Config.USE_AI_FALLBACK:
            logger.info(f"🤖 Running comprehensive AI fallback for {player_name}...")
            
            fields_filled = self.perplexity.check_all_missing_fields(
                player_data, 
                player_name, 
                sport='NFL',
                max_cost=Config.AI_FALLBACK_MAX_COST_PER_PLAYER
            )
            
            if fields_filled > 0:
                stats = self.perplexity.get_stats()
                logger.info(f"💰 AI Fallback: Filled {fields_filled} fields, "
                           f"${stats['estimated_cost']:.3f} total cost, "
                           f"{stats['calls_made']} API calls")
        
        # Final step: Convert None draft values to "Undrafted" strings for output
        if player_data.identity:
            if player_data.identity.draft_year is None or player_data.identity.draft_year == 0:
                player_data.identity.draft_year = "Undrafted"
                player_data.identity.draft_round = "Undrafted"
                player_data.identity.draft_pick = "Undrafted"
        
        return player_data
    
