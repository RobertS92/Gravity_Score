    def _search_espn_nba_player(self, player_name: str, team: str = None) -> Optional[str]:
        """Search ESPN for NBA player ID"""
        try:
            search_url = f"https://site.web.api.espn.com/apis/common/v3/search?query={quote(player_name)}&limit=10&type=player"
            response = self.session.get(search_url, headers=self.espn_headers, timeout=10)
            
            if response.status_code == 200:
                data = response.json()
                items = data.get("items", [])
                
                for item in items:
                    if item.get("type") == "player":
                        player_id = item.get("id")
                        details = item.get("details", {})
                        sport = details.get("sport", "") or ""
                        
                        # Check if sport is basketball/nba
                        if sport and ("basketball" in sport.lower() or "nba" in sport.lower()):
                            return player_id
                        
                        # If sport is empty/None, verify by checking NBA endpoint
                        if player_id and not sport:
                            # Try NBA endpoint to verify it's an NBA player
                            verify_url = f"https://site.api.espn.com/apis/common/v3/sports/basketball/nba/athletes/{player_id}"
                            verify_resp = self.session.get(verify_url, headers=self.espn_headers, timeout=5)
                            if verify_resp.status_code == 200:
                                logger.info(f"✅ ESPN NBA: Verified {player_name} (ID: {player_id})")
                                return player_id
            return None
        except Exception as e:
            logger.debug(f"ESPN NBA search failed: {e}")
            return None
    
    def _parse_espn_nba_player(self, data: Dict) -> Dict:
        """Parse ESPN NBA player response"""
        athlete = data.get("athlete", data)
        
        result = {
            "espn_id": athlete.get("id"),
            "name": athlete.get("displayName", ""),
            "first_name": athlete.get("firstName", ""),
            "last_name": athlete.get("lastName", ""),
            "position": athlete.get("position", {}).get("abbreviation", ""),
            "jersey_number": athlete.get("jersey", ""),
            "height": athlete.get("height", ""),
            "weight": athlete.get("weight", ""),
            "age": athlete.get("age"),
            "birth_date": athlete.get("dateOfBirth", ""),
            "college": athlete.get("college", {}).get("name", "") if isinstance(athlete.get("college"), dict) else "",
            "experience": athlete.get("experience", {}).get("years", 0) if isinstance(athlete.get("experience"), dict) else 0,
            "draft_info": {},
            "headshot_url": athlete.get("headshot", {}).get("href", ""),
            "team": {},
            "statistics": {},
            "injuries": []
        }
        
        # Parse team
        team = athlete.get("team", {})
        if team:
            result["team"] = {
                "id": team.get("id"),
                "name": team.get("displayName", ""),
                "abbreviation": team.get("abbreviation", "")
            }
        
        # Parse draft info
        draft = athlete.get("draft", {})
        if draft:
            result["draft_info"] = {
                "year": draft.get("year"),
                "round": draft.get("round"),
                "pick": draft.get("selection")
            }
        
        return result
    
