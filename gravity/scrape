                                jersey = player.get('jersey_number') or player.get('jersey') or player.get('number')
                                
                                # Convert jersey to int if possible
                                if jersey is not None:
                                    try:
                                        if isinstance(jersey, str):
                                            jersey = int(jersey.replace('#', '').strip())
                                        else:
                                            jersey = int(jersey)
                                    except (ValueError, TypeError):
                                        jersey = None
                                
                                # Position validation - allow UNK for all sources (will be filled later)
                                valid_positions = ['QB', 'RB', 'WR', 'TE', 'OL', 'C', 'G', 'T', 'DL', 'DE', 'DT', 
                                                  'LB', 'ILB', 'OLB', 'DB', 'CB', 'S', 'FS', 'SS', 'K', 'P', 'LS', 
                                                  'NT', 'EDGE', 'HB', 'FB', 'OT', 'OG']
                                invalid_positions = ['DEFE', 'OFFE', 'SPEC', 'TOTA', 'ACTI', 'INAC', 'RESE', 'PRAC', 
                                                   'SQUA', 'TEAM', 'PLAY', 'ROST', 'NAME', 'POSI', 'NUMB']
                                
                                # Skip only truly invalid positions (not UNK)
                                if position in invalid_positions:
                                    logger.debug(f"Skipping LLM player (invalid position '{position}'): {name}")
                                    continue
                                
                                # If position is not valid and not UNK, set to UNK (will be filled later)
                                if position not in valid_positions and position != 'UNK':
                                    logger.debug(f"Setting position to UNK for {name} (got '{position}')")
                                    position = 'UNK'
                                
                                # Skip if name looks like a college/team (more specific check)
                                skip_patterns = ['university', 'college', 'school', 'tech', 'a&m']
                                # Only skip if the entire name matches these patterns
                                name_lower = name.lower()
                                if any(pattern == name_lower or name_lower.endswith(' ' + pattern) for pattern in skip_patterns):
                                    logger.debug(f"Skipping LLM player (looks like college): {name}")
                                    continue
                                
                                # Skip if name is too short (relaxed: allow names like "C.J.")
                                if len(name.split()) < 2:
                                    logger.debug(f"Skipping LLM player (name too short - only {len(name.split())} part(s)): {name}")
                                    continue
                                
                                # Construct player URL for all sources (not just sitemap)
                                # This ensures we can scrape each player's individual page later
                                player_url = _construct_player_url(name)
                                
                                players.append({
                                    'name': name,
                                    'position': position,
                                    'jersey_number': jersey,
                                    'team': team_name,
                                    'player_url': player_url  # Store URL for scraping individual player page
                                })
                                logger.debug(f"LLM player {idx+1}: {name} ({position})" + (f" [URL: {player_url}]" if player_url else ""))
                        elif isinstance(player, str):
                            # Try to parse string format like "Name, Position, #Number" or "Name Position"
                            parts = [p.strip() for p in player.split(',')]
                            if len(parts) >= 2:
                                name = parts[0].strip()
                                position = parts[1].strip().upper() if len(parts) > 1 else 'UNK'
                                jersey = None
                                if len(parts) > 2:
                                    try:
                                        jersey = int(parts[2].replace('#', '').strip())
                                    except:
                                        pass
                                
                                if name and len(name.split()) >= 2:  # Must have first and last name
                                    players.append({
                                        'name': name,
                                        'position': position,
                                        'jersey_number': jersey,
                                        'team': team_name
                                    })
                    except Exception as parse_error:
                        logger.debug(f"Error parsing player {idx}: {parse_error}")
                        continue
                
                if players:
                    logger.info(f"✓ LLM extracted {len(players)} players from {source_name}")
                    return players
                else:
                    logger.warning(f"LLM returned {len(players_list) if players_list else 0} items but no valid players extracted")
                    if players_list:
                        logger.warning(f"Sample items: {players_list[:3]}")
                        logger.warning(f"First item type: {type(players_list[0]) if players_list else 'N/A'}")
                        logger.warning(f"First item: {players_list[0] if players_list else 'N/A'}")
            else:
