class TrendsAnalyzer:
    """Analyze Google Trends data with multiple methods and fallbacks"""
    
    def __init__(self, scraper: FirecrawlScraper):
        self.scraper = scraper
        self.news_analyzer = None  # Will be set if available for fallback
    
    def set_news_analyzer(self, news_analyzer):
        """Set news analyzer for fallback trends calculation"""
        self.news_analyzer = news_analyzer
    
    def get_trends_data(self, player_name: str) -> Dict:
        """Get Google Trends data for player using multiple methods"""
        data = {
            'trends_score': None,
            'trends_momentum': 'stable',
            'peak_interest_date': None,
            'related_queries': []
        }
        
        # Method 1: Try Google Trends scraping with enhanced parsing
        trends_data = self._scrape_google_trends(player_name)
        if trends_data.get('trends_score') is not None:
            data.update(trends_data)
            logger.info(f"Trends data from Google Trends: Score: {data['trends_score']}, "
                       f"Momentum: {data['trends_momentum']}")
            return data
        
        # Method 2: Try alternative trends services
        alt_trends = self._get_alternative_trends(player_name)
        if alt_trends.get('trends_score') is not None:
            data.update(alt_trends)
            logger.info(f"Trends data from alternative source: Score: {data['trends_score']}, "
                       f"Momentum: {data['trends_momentum']}")
            return data
        
        # Method 3: Calculate trends from news data (fallback)
        if self.news_analyzer:
            calculated_trends = self._calculate_trends_from_news(player_name)
            if calculated_trends.get('trends_score') is not None:
                data.update(calculated_trends)
                logger.info(f"Trends data calculated from news: Score: {data['trends_score']}, "
                           f"Momentum: {data['trends_momentum']}")
                return data
        
        # Method 4: Use search volume as proxy
        search_trends = self._estimate_from_search_volume(player_name)
        if search_trends.get('trends_score') is not None:
            data.update(search_trends)
            logger.info(f"Trends data estimated from search: Score: {data['trends_score']}, "
                       f"Momentum: {data['trends_momentum']}")
            return data
        
        # Default: Set stable momentum if nothing found
        data['trends_momentum'] = 'stable'
        logger.info(f"Trends data for {player_name}: Score: {data['trends_score']}, "
                   f"Momentum: {data['trends_momentum']} (no data found)")
        
        return data
    
    def _scrape_google_trends(self, player_name: str) -> Dict:
        """Enhanced Google Trends scraping with better parsing"""
        data = {
            'trends_score': None,
            'trends_momentum': 'stable',
            'peak_interest_date': None,
            'related_queries': []
        }
        
        # Try multiple Google Trends URLs
        trends_urls = [
            f"https://trends.google.com/trends/explore?q={quote(player_name)}&geo=US&date=today%201-m",
            f"https://trends.google.com/trends/explore?q={quote(player_name + ' NFL')}&geo=US&date=today%201-m",
            f"https://www.google.com/search?q={quote(player_name + ' trends')}&tbm=nws"
        ]
        
        for trends_url in trends_urls:
            try:
                result = self.scraper.scrape(trends_url)
                
                if result and 'markdown' in result:
                    text = result['markdown']
                    
                    # Enhanced pattern matching for trends score
                    score_patterns = [
                        r'(\d+)%?\s*(?:interest|popularity|score)',
                        r'score[:\s]+(\d+)',
                        r'interest[:\s]+(\d+)',
                        r'(\d+)\s*out of\s*\d+',
                        r'peak[:\s]+(\d+)',
                        r'max[:\s]+(\d+)',
                        r'(\d{2,3})\s*(?:points?|score)'
                    ]
                    
                    for pattern in score_patterns:
                        score_match = re.search(pattern, text, re.IGNORECASE)
                        if score_match:
                            try:
                                score = int(score_match.group(1))
                                if 0 <= score <= 100:
                                    data['trends_score'] = score
                                    break
                            except:
                                continue
                    
                    # Enhanced momentum detection
                    momentum_indicators = {
                        'rising': ['rising', 'increasing', 'up', 'growing', 'surge', 'spike', 'peak', 'trending up'],
                        'declining': ['falling', 'declining', 'decreasing', 'down', 'dropping', 'fall', 'decline'],
                        'stable': ['stable', 'steady', 'consistent', 'unchanged', 'flat']
                    }
                    
                    text_lower = text.lower()
                    for momentum, keywords in momentum_indicators.items():
                        if any(keyword in text_lower for keyword in keywords):
                            data['trends_momentum'] = momentum
                            break
                    
                    # Extract related queries with better patterns
                    related_patterns = [
                        r'Related (?:queries|topics)[:\s]*(.*?)(?:\n\n|\n[A-Z]|$)',
                        r'Related searches[:\s]*(.*?)(?:\n\n|\n[A-Z]|$)',
                        r'People also search for[:\s]*(.*?)(?:\n\n|\n[A-Z]|$)'
                    ]
                    
                    for pattern in related_patterns:
                        related_match = re.search(pattern, text, re.IGNORECASE | re.DOTALL)
                        if related_match:
                            related_text = related_match.group(1)
                            # Extract individual queries
                            queries = re.findall(r'([A-Za-z\s]{3,30})', related_text)
                            data['related_queries'] = [q.strip() for q in queries[:5] 
                                                      if len(q.strip()) > 3 and q.strip().lower() != player_name.lower()]
                            if data['related_queries']:
                                break
                    
                    # Extract peak date if available
                    date_patterns = [
                        r'peak[:\s]+(\d{1,2}[/-]\d{1,2}[/-]\d{4})',
                        r'highest[:\s]+(\d{1,2}[/-]\d{1,2}[/-]\d{4})',
                        r'(\d{1,2}[/-]\d{1,2}[/-]\d{4})[:\s]+peak'
                    ]
                    
                    for pattern in date_patterns:
                        date_match = re.search(pattern, text, re.IGNORECASE)
                        if date_match:
                            data['peak_interest_date'] = date_match.group(1)
                            break
                    
                    # If we got a score, return early
                    if data['trends_score'] is not None:
                        return data
                
                time.sleep(Config.REQUEST_DELAY)
            except Exception as e:
                logger.debug(f"Google Trends scrape failed for {trends_url[:50]}: {e}")
                continue
        
        return data
    
    def _get_alternative_trends(self, player_name: str) -> Dict:
        """Try alternative methods to get trends data"""
        data = {
            'trends_score': None,
            'trends_momentum': 'stable'
        }
        
        # Try searching for "player name trending" to get current interest
        search_query = f"{player_name} trending NFL"
        search_url = f"https://www.google.com/search?q={quote(search_query)}&tbm=nws"
        
        try:
            result = self.scraper.scrape(search_url)
            if result and 'markdown' in result:
                text = result['markdown']
                
                # Count mentions of "trending" or "viral" as proxy for interest
                trending_mentions = len(re.findall(r'trending|viral|popular|buzz', text, re.IGNORECASE))
                
                if trending_mentions > 0:
                    # Calculate score based on mentions (0-100 scale)
                    data['trends_score'] = min(100, trending_mentions * 10)
                    
                    # Determine momentum based on recent activity
                    if 'today' in text.lower() or 'hours ago' in text.lower():
                        data['trends_momentum'] = 'rising'
                    elif 'week ago' in text.lower() or 'days ago' in text.lower():
                        data['trends_momentum'] = 'stable'
        except Exception as e:
            logger.debug(f"Alternative trends method failed: {e}")
        
        return data
    
    def _calculate_trends_from_news(self, player_name: str) -> Dict:
        """Calculate trends score from news article volume and recency"""
        data = {
            'trends_score': None,
            'trends_momentum': 'stable'
        }
        
        if not self.news_analyzer:
            return data
        
        try:
            # Get news data
            news_data = self.news_analyzer.analyze_news(player_name, days=30)
            
            count_30d = news_data.get('news_headline_count_30d', 0)
            count_7d = news_data.get('news_headline_count_7d', 0)
            
            if count_30d > 0:
                # Calculate trends score based on article volume
                # Scale: 0-50 articles = 0-50 score, 50+ articles = 50-100 score
                if count_30d <= 50:
                    data['trends_score'] = count_30d
                else:
                    data['trends_score'] = min(100, 50 + ((count_30d - 50) / 10))
                
                # Calculate momentum from 7d vs 30d ratio
                if count_7d > 0:
                    ratio = count_7d / (count_30d / 30 * 7)  # Expected 7d count
                    if ratio > 1.5:
                        data['trends_momentum'] = 'rising'
                    elif ratio < 0.5:
                        data['trends_momentum'] = 'declining'
                    else:
                        data['trends_momentum'] = 'stable'
                else:
                    data['trends_momentum'] = 'declining'
                
                logger.info(f"Calculated trends from news: {count_30d} articles (30d), "
                           f"{count_7d} articles (7d), score: {data['trends_score']}")
        except Exception as e:
            logger.debug(f"News-based trends calculation failed: {e}")
        
        return data
    
    def _estimate_from_search_volume(self, player_name: str) -> Dict:
        """Estimate trends from search result volume"""
        data = {
            'trends_score': None,
            'trends_momentum': 'stable'
        }
        
        try:
            # Search for player name and count results
            search_url = f"https://www.google.com/search?q={quote(player_name + ' NFL')}"
            result = self.scraper.scrape(search_url)
            
            if result and 'markdown' in result:
                text = result['markdown']
                
                # Look for result count
                result_patterns = [
                    r'About ([\d,]+) results',
                    r'([\d,]+) results',
                    r'([\d,]+)\s*results found'
                ]
                
                for pattern in result_patterns:
                    match = re.search(pattern, text, re.IGNORECASE)
                    if match:
                        try:
                            result_count = int(match.group(1).replace(',', ''))
                            # Scale result count to 0-100 (logarithmic scale)
                            if result_count > 0:
                                # Log scale: 1M results = ~100, 100K = ~50, 10K = ~25
                                data['trends_score'] = min(100, int(10 * math.log10(result_count / 1000)))
                                data['trends_momentum'] = 'stable'
                                break
                        except:
                            continue
        except Exception as e:
            logger.debug(f"Search volume estimation failed: {e}")
        
        return data

