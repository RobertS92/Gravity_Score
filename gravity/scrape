    def _parse_espn_nfl_full_stats(self, stats_data: Dict, result: Dict) -> Dict:
        """Parse ESPN statistics response into structured format"""
        # Handle different response formats
        splits = stats_data.get("splits", {})
        categories = splits.get("categories", [])
        
        for category in categories:
            cat_name = category.get("name", "").lower()
            stats_list = category.get("stats", [])
            
            for stat in stats_list:
                stat_name = stat.get("name", "")
                stat_value = stat.get("value", 0)
                display_value = stat.get("displayValue", str(stat_value))
                
                # Map to our format
                if cat_name in ["passing", "rushing", "receiving", "defense", "kicking", "punting", "returning"]:
                    if cat_name not in result["current_season_stats"]:
                        result["current_season_stats"][cat_name] = {}
                    result["current_season_stats"][cat_name][stat_name] = display_value
        
        # Also check for season-by-season in splits
        seasons = stats_data.get("seasons", [])
        for season in seasons:
            season_stats = {
                "year": season.get("year"),
                "team": season.get("team", {}).get("displayName", ""),
                "stats": {}
            }
            
            for cat in season.get("categories", []):
                cat_name = cat.get("name", "").lower()
                season_stats["stats"][cat_name] = {}
                for stat in cat.get("stats", []):
                    season_stats["stats"][cat_name][stat.get("name", "")] = stat.get("displayValue", "")
            
            if season_stats["stats"]:
                result["season_by_season"].append(season_stats)
        
        # Calculate career totals from season_by_season if available
        if result["season_by_season"] and not result["career_stats"]:
            result["career_stats"] = self._calculate_career_totals(result["season_by_season"])
        
        return result
    
    def _calculate_career_totals(self, seasons: List[Dict]) -> Dict:
        """Calculate career totals from season-by-season stats"""
        career = {}
        
        # Stats that should be summed (include defensive stats)
        sum_stats = [
            "passingYards", "rushingYards", "receivingYards", "passingTouchdowns",
            "rushingTouchdowns", "receivingTouchdowns", "receptions", "targets",
            "sacks", "interceptions", "forcedFumbles", "tackles", "fieldGoalsMade",
            "passesDefended", "soloTackles", "assistedTackles", "tacklesForLoss", "qbHits"
        ]
        
        for season in seasons:
            for cat_name, cat_stats in season.get("stats", {}).items():
                if cat_name not in career:
                    career[cat_name] = {}
                for stat_name, stat_value in cat_stats.items():
                    try:
                        val = float(str(stat_value).replace(",", ""))
                        if stat_name in sum_stats:
                            career[cat_name][stat_name] = career[cat_name].get(stat_name, 0) + val
                    except (ValueError, TypeError):
                        pass
        
        return career
    
