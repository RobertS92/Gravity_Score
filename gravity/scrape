                    return sentiment
            except ImportError:
                logger.debug("OpenAI not available for sentiment, using Ollama")
            except Exception as e:
                logger.debug(f"OpenAI sentiment failed: {e}, falling back to Ollama")
        
        # Fallback to Ollama
        if not self.ollama_available:
