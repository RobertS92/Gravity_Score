def get_season_identifier(sport: str) -> str:
    """
    Get current season identifier for each sport
    
    Args:
        sport: 'nfl', 'nba', 'cfb', 'ncaab', 'wnba', 'wncaab'
    
    Returns:
        Season identifier string (e.g., "2025", "2025-26", etc.)
    """
    current_date = datetime.now()
    current_year = current_date.year
    current_month = current_date.month
    
    if sport in ['nfl', 'cfb']:
        # Calendar year format
        return str(current_year)
    
    elif sport in ['nba', 'wnba']:
        # Format: "2024-25" for 2024-25 season
        # Season starts in October, so:
        # - Oct-Dec 2024: 2024-25 season
        # - Jan-Sep 2025: 2024-25 season (still current)
        # - Oct-Dec 2025: 2025-26 season
        
        if current_month >= 10:  # October onwards = new season
            # We're in the new season (e.g., Oct 2025 = 2025-26 season)
            season_start = current_year
        else:
            # We're still in previous season (e.g., Jan 2025 = 2024-25 season)
            season_start = current_year - 1
        
        season_end = str(season_start + 1)[-2:]  # Last 2 digits
        return f"{season_start}-{season_end}"
    
    elif sport in ['ncaab', 'wncaab']:
        # Calendar year format, but season spans two years
        # 2025 = 2024-25 season, 2026 = 2025-26 season
        # Season starts in November, so:
        # - Nov-Dec 2024: 2024-25 season (use "2025")
        # - Jan-Oct 2025: 2024-25 season (use "2025")
        # - Nov-Dec 2025: 2025-26 season (use "2026")
        
        if current_month >= 11:  # November onwards = new season
            # We're in the new season (e.g., Nov 2025 = 2025-26 season)
            return str(current_year + 1)
        else:
            # We're still in previous season (e.g., Jan 2025 = 2024-25 season)
            return str(current_year)
    
    else:
        # Default to calendar year
        return str(current_year)


# ============================================================================
# PERSISTENT CACHE
# ============================================================================

class PersistentCache:
    """Persistent cache with TTL support using pickle"""
    
    def __init__(self, cache_dir: str = None, ttl_hours: int = None):
        self.cache_dir = Path(cache_dir or Config.CACHE_DIR)
        self.ttl = timedelta(hours=ttl_hours or Config.CACHE_TTL_HOURS)
        self.cache_dir.mkdir(parents=True, exist_ok=True)
    
    def _get_cache_file(self, key: str) -> Path:
        """Get cache file path for a key"""
        # Use hash to avoid filesystem issues with special characters
        key_hash = hashlib.md5(key.encode()).hexdigest()
        return self.cache_dir / f"{key_hash}.pkl"
    
    def get(self, key: str):
        """Get cached value if it exists and hasn't expired"""
        cache_file = self._get_cache_file(key)
        if not cache_file.exists():
            return None
        
        try:
            with open(cache_file, 'rb') as f:
                data, timestamp = pickle.load(f)
                if datetime.now() - timestamp < self.ttl:
                    logger.debug(f"Cache hit for {key[:50]}")
                    return data
                else:
                    # Expired - delete file
                    cache_file.unlink()
                    logger.debug(f"Cache expired for {key[:50]}")
                    return None
        except Exception as e:
            logger.warning(f"Error reading cache for {key[:50]}: {e}")
            return None
    
    def set(self, key: str, value):
        """Set cached value with current timestamp"""
        cache_file = self._get_cache_file(key)
        try:
            with open(cache_file, 'wb') as f:
                pickle.dump((value, datetime.now()), f)
            logger.debug(f"Cached {key[:50]}")
        except Exception as e:
            logger.warning(f"Error writing cache for {key[:50]}: {e}")
    
    def clear(self):
        """Clear all cache files"""
        for cache_file in self.cache_dir.glob("*.pkl"):
            try:
                cache_file.unlink()
            except Exception as e:
                logger.warning(f"Error deleting cache file {cache_file}: {e}")

