    # =========================================================================
    # ESPN NBA Complete Player Data (Identity + Stats + Awards in one call)
    # =========================================================================
    
    def get_complete_nba_player_data(self, player_name: str, team: str = None) -> Dict:
        """
        Get ALL NBA player data from ESPN APIs.
        Uses CORE API for draft/birthplace + OVERVIEW API for awards + STATS API for statistics.
        
        Returns complete data for:
        - Identity (name, team, position, height, weight, age, college, draft, hometown)
        - Stats (current season, career, year-by-year)
        - Awards (All-Star, All-NBA, Championships, MVP, DPOY, etc.)
        - Injuries (current and history)
        """
        cache_key = f"espn_complete_nba_{player_name}"
        cached = self.cache.get(cache_key)
        if cached:
            logger.info(f"⚡ ESPN Cache hit for NBA player {player_name}")
            return cached
        
        try:
            # Step 1: Find player ID
            player_id = self._search_espn_nba_player(player_name, team)
            if not player_id:
                logger.warning(f"ESPN: NBA player not found: {player_name}")
                return {}
            
            result = {
                "espn_id": player_id,
                "source": "espn_api",
                "identity": {},
                "stats": {
                    "current_season": {},
                    "career": {},
                    "by_year": {}
                },
                "awards": [],
                "injuries": []
            }
            
            # Step 2: Get CORE API data (has draft, birthPlace, college, experience)
            core_url = f"https://sports.core.api.espn.com/v2/sports/basketball/leagues/nba/athletes/{player_id}"
            core_resp = self.session.get(core_url, headers=self.espn_headers, timeout=10)
            
            if core_resp.status_code == 200:
                core_data = core_resp.json()
                
                # Parse draft info from core API
                draft = core_data.get("draft", {})
                birth_place = core_data.get("birthPlace", {})
                position = core_data.get("position", {})
                
                result["identity"] = {
                    "name": core_data.get("fullName", core_data.get("displayName", "")),
                    "first_name": core_data.get("firstName", ""),
                    "last_name": core_data.get("lastName", ""),
                    "jersey_number": core_data.get("jersey"),
                    "position": position.get("abbreviation", ""),
                    "position_name": position.get("displayName", position.get("name", "")),
                    "height": core_data.get("displayHeight", ""),
                    "weight": core_data.get("displayWeight", ""),
                    "age": core_data.get("age"),
                    "birth_date": core_data.get("dateOfBirth"),
                    "birth_city": birth_place.get("city", ""),
                    "birth_state": birth_place.get("state", ""),
                    "birth_country": birth_place.get("country", ""),
                    "birth_place": f"{birth_place.get('city', '')}, {birth_place.get('state', '')}".strip(", "),
                    "hometown": f"{birth_place.get('city', '')}, {birth_place.get('state', '')}".strip(", "),
                    "draft_year": draft.get("year"),
                    "draft_round": draft.get("round"),
                    "draft_pick": draft.get("selection"),
                    "draft_display": draft.get("displayText", ""),
                    "experience_years": core_data.get("experience", {}).get("years") if isinstance(core_data.get("experience"), dict) else core_data.get("experience"),
                    "active": core_data.get("active", True),
                    "status": "Active" if core_data.get("active", True) else "Inactive"
                }
                
                logger.info(f"🏀 Core API: {result['identity']['name']} - Draft: {draft.get('year')} R{draft.get('round')} P{draft.get('selection')}, From: {result['identity']['hometown']}")
            
            # Step 3: Get team info from common API
            player_url = f"https://site.api.espn.com/apis/common/v3/sports/basketball/nba/athletes/{player_id}"
            resp = self.session.get(player_url, headers=self.espn_headers, timeout=10)
            
            if resp.status_code == 200:
                data = resp.json()
                player = data.get("athlete", data)
                
                # Add team info (not in core API)
                result["identity"]["team"] = player.get("team", {}).get("displayName", "")
                result["identity"]["team_abbrev"] = player.get("team", {}).get("abbreviation", "")
                result["identity"]["headshot_url"] = player.get("headshot", {}).get("href", "")
                
                # Get college if available (may not be in core API)
                if not result["identity"].get("college"):
                    college = player.get("college", {})
                    result["identity"]["college"] = college.get("name", "") if isinstance(college, dict) else str(college) if college else ""
                
                # Parse injuries
                for injury in player.get("injuries", []):
                    result["injuries"].append({
                        "type": injury.get("type", {}).get("description", ""),
                        "status": injury.get("status", ""),
                        "date": injury.get("date", ""),
                        "details": injury.get("longComment", "")
                    })
            
            # Step 4: Get AWARDS from overview API
            overview_url = f"https://site.api.espn.com/apis/common/v3/sports/basketball/nba/athletes/{player_id}/overview"
            overview_resp = self.session.get(overview_url, headers=self.espn_headers, timeout=10)
            
            if overview_resp.status_code == 200:
                overview_data = overview_resp.json()
                awards_sections = overview_data.get("awards", [])
                
                # Each section IS an award with name, displayCount, and seasons
                for section in awards_sections:
                    award_name = section.get("name", "")
                    display_count = section.get("displayCount", "1x")
                    seasons = section.get("seasons", [])
                    
                    # Parse count from displayCount (e.g., "4x" -> 4)
                    try:
                        count = int(display_count.replace("x", ""))
                    except:
                        count = len(seasons) if seasons else 1
                    
                    # Add each award instance
                    for year in seasons:
                        result["awards"].append({
                            "name": award_name,
                            "year": int(year) if year else None,
                            "type": award_name
                        })
                    
                    # If no seasons listed, still add the award
                    if not seasons and award_name:
                        result["awards"].append({
                            "name": award_name,
                            "count": count,
                            "type": award_name
                        })
                
                logger.info(f"🏆 Awards API: Found {len(result['awards'])} award instances for {player_name}")
            
            # Step 5: Get statistics (current and career)
            stats_url = f"https://site.api.espn.com/apis/common/v3/sports/basketball/nba/athletes/{player_id}/statistics"
            stats_resp = self.session.get(stats_url, headers=self.espn_headers, timeout=15)
            
            if stats_resp.status_code == 200:
                stats_data = stats_resp.json()
                splits = stats_data.get("splits", {})
                categories = splits.get("categories", [])
                
                for category in categories:
                    stats_list = category.get("stats", [])
                    for stat in stats_list:
                        stat_name = stat.get("name", "")
                        display_value = stat.get("displayValue", "")
                        result["stats"]["current_season"][stat_name] = display_value
            
            # Step 6: Get ALL season-by-season stats (complete career history)
            # Dynamically discover all seasons with data
            current_year = datetime.now().year
            draft_year = result["identity"].get("draft_year") or 2000  # Go back to at least 2000
            start_year = max(draft_year, 1996)  # NBA API generally has data from mid-90s
            
            seasons_found = 0
            consecutive_empty = 0
            
            for season in range(current_year, max(start_year, 1996) - 1, -1):
                try:
                    splits_url = f"https://site.api.espn.com/apis/common/v3/sports/basketball/nba/athletes/{player_id}/splits?season={season}"
                    splits_resp = self.session.get(splits_url, headers=self.espn_headers, timeout=10)
                    
                    if splits_resp.status_code == 200:
                        splits_data = splits_resp.json()
                        season_stats = self._parse_espn_nba_season_stats(splits_data)
                        
                        if season_stats and season_stats.get("gamesPlayed", 0):
                            result["stats"]["by_year"][str(season)] = season_stats
                            seasons_found += 1
                            consecutive_empty = 0
                            
                            if season == current_year and not result["stats"]["current_season"]:
                                result["stats"]["current_season"] = season_stats
                        else:
                            consecutive_empty += 1
                    else:
                        consecutive_empty += 1
                    
                    # Only stop if we've gone way back (before 1996) AND no data found
                    # This ensures we get ALL available historical data
                    if season < 1996 and consecutive_empty >= 5:
                        break
                    # Also stop if we've found seasons and hit 5 consecutive empty years (more lenient)
                    if seasons_found > 0 and consecutive_empty >= 5 and season < start_year + 5:
                        break
                        
                except Exception as e:
                    logger.debug(f"Failed to get NBA {season} stats for {player_name}: {e}")
                    consecutive_empty += 1
            
            logger.info(f"📊 NBA Stats: Found {seasons_found} seasons of data for {player_name}")
            
            # Step 7: Get COLLEGE stats if player went to college
            # ESPN uses the same player ID for college and pro careers!
            result["stats"]["college"] = {"by_year": {}, "career": {}}
            college_name = result["identity"].get("college", "")
            
            if college_name:
                college_seasons_found = 0
                draft_year = result["identity"].get("draft_year") or 2020
                
                # Check men's college basketball for years before draft
                for season in range(draft_year, draft_year - 6, -1):
                    try:
                        college_url = f"https://site.api.espn.com/apis/common/v3/sports/basketball/mens-college-basketball/athletes/{player_id}/splits?season={season}"
                        college_resp = self.session.get(college_url, headers=self.espn_headers, timeout=10)
                        
                        if college_resp.status_code == 200:
                            college_data = college_resp.json()
                            college_stats = self._parse_espn_nba_season_stats(college_data)  # Same format
                            
                            if college_stats and college_stats.get("gamesPlayed", 0):
                                result["stats"]["college"]["by_year"][str(season)] = college_stats
                                college_seasons_found += 1
                    except Exception as e:
                        logger.debug(f"Failed to get college {season} stats for {player_name}: {e}")
                
                if college_seasons_found > 0:
                    result["stats"]["college"]["career"] = self._calculate_nba_career_from_years(result["stats"]["college"]["by_year"])
                    logger.info(f"🎓 College Stats: Found {college_seasons_found} seasons at {college_name}")
            
            # Step 8: Calculate career totals from year-by-year (NBA only)
            result["stats"]["career"] = self._calculate_nba_career_from_years(result["stats"]["by_year"])
            
            # Count NBA-specific awards
            award_names = [a.get("name", "").lower() for a in result["awards"]]
            
            # Count each award type
            result["all_star_selections"] = sum(1 for a in award_names if "all-star" in a and "mvp" not in a)
            result["all_star_mvp"] = sum(1 for a in award_names if "all-star mvp" in a)
            result["all_nba_selections"] = sum(1 for a in award_names if "all-nba" in a)
            result["all_nba_first_team"] = sum(1 for a in award_names if "all-nba 1st" in a)
            result["championships"] = sum(1 for a in award_names if "champion" in a)
            result["mvp_awards"] = sum(1 for a in award_names if a == "mvp")  # Regular season MVP
            result["dpoy_awards"] = sum(1 for a in award_names if "defensive player" in a)
            result["finals_mvp"] = sum(1 for a in award_names if "finals mvp" in a)
            result["all_defensive"] = sum(1 for a in award_names if "all-defensive" in a)
            result["all_defensive_first"] = sum(1 for a in award_names if "all-defensive 1st" in a)
            result["scoring_titles"] = sum(1 for a in award_names if "scoring" in a)
            result["rookie_of_year"] = sum(1 for a in award_names if "rookie of the year" in a)
            result["nba_cup_mvp"] = sum(1 for a in award_names if "nba cup mvp" in a)
            
            logger.info(f"📊 Awards: MVP={result['mvp_awards']}, Finals MVP={result['finals_mvp']}, All-NBA={result['all_nba_selections']}, All-Defense={result['all_defensive']}")
            
            # Step 9: Get gamelog for current season (ALL games)
            logger.info(f"📊 Attempting gamelog collection for {player_name} (ID: {player_id})...")
            current_year = datetime.now().year
            current_season_gamelog = self.get_espn_nba_gamelog(player_id, season=current_year)
            logger.info(f"   Tried {current_year} season: {len(current_season_gamelog) if current_season_gamelog else 0} games")
            
            # If no data for current season, try previous season (fallback)
            gamelog_season = current_year
            if not current_season_gamelog:
                logger.info(f"   No gamelog for {current_year} season, trying {current_year - 1}...")
                current_season_gamelog = self.get_espn_nba_gamelog(player_id, season=current_year - 1)
                logger.info(f"   Tried {current_year - 1} season: {len(current_season_gamelog) if current_season_gamelog else 0} games")
                gamelog_season = current_year - 1
            
            if current_season_gamelog:
                # Store ALL current season games
                result["current_season_gamelog"] = current_season_gamelog
                result["recent_games"] = current_season_gamelog[-5:]  # Last 5 for quick reference
                result["games_played_current_season"] = len(current_season_gamelog)
                logger.info(f"✅ Gamelog: {len(current_season_gamelog)} games from {gamelog_season} season")
                
                # Also get historical gamelogs for previous seasons (last 3 years before gamelog_season)
                result["gamelog_by_year"] = {}
                for year in range(gamelog_season - 1, gamelog_season - 4, -1):
                    if year > 2000:  # Sanity check
                        historical_gamelog = self.get_espn_nba_gamelog(player_id, season=year)
                        if historical_gamelog:
                            result["gamelog_by_year"][str(year)] = historical_gamelog
                
                if result["gamelog_by_year"]:
                    total_historical = sum(len(games) for games in result["gamelog_by_year"].values())
                    logger.info(f"✅ Historical: {total_historical} games across {len(result['gamelog_by_year'])} seasons")
            else:
                logger.warning(f"⚠️  No gamelog data found for {player_name} (tried {current_year} and {current_year - 1})")
            
            # Cache and return
            if result["identity"].get("name"):
                self.cache.set(cache_key, result)
                logger.info(f"✅ ESPN API: Complete NBA data for {player_name} - {result['identity'].get('team', '?')}")
            
            return result
            
        except Exception as e:
            logger.error(f"ESPN complete NBA data failed for {player_name}: {e}")
            return {}
    
    def _parse_espn_nba_season_stats(self, stats_data: Dict) -> Dict:
        """Parse ESPN NBA/WNBA/College splits response to get season stats"""
        result = {}
        names = stats_data.get("names", [])
        
        split_categories = stats_data.get("splitCategories", [])
        
        for cat in split_categories:
            if cat.get("displayName") == "split":
                # First try to find "All Splits"
                all_splits_found = False
                for split in cat.get("splits", []):
                    if split.get("displayName") == "All Splits":
                        stats = split.get("stats", [])
                        for i, stat_value in enumerate(stats):
                            if i < len(names):
                                result[names[i]] = stat_value
                        all_splits_found = True
                        break
                
                # If no "All Splits", combine Home and Away (college basketball format)
                if not all_splits_found:
                    home_stats = {}
                    away_stats = {}
                    
                    for split in cat.get("splits", []):
                        split_name = split.get("displayName", "").lower()
                        stats = split.get("stats", [])
                        
                        if "home" in split_name:
                            for i, stat_value in enumerate(stats):
                                if i < len(names):
                                    home_stats[names[i]] = stat_value
                        elif "away" in split_name:
                            for i, stat_value in enumerate(stats):
                                if i < len(names):
                                    away_stats[names[i]] = stat_value
                    
                    # Combine Home and Away stats
                    if home_stats or away_stats:
                        result = self._combine_home_away_stats(home_stats, away_stats, names)
                break
        
        # Parse per-game stats from combined fields like "avgFieldGoalsMade-avgFieldGoalsAttempted"
        for key in list(result.keys()):
            if "-" in str(result.get(key, "")):
                try:
                    val = str(result[key]).split("-")
                    if len(val) == 2:
                        if "avgFieldGoalsMade" in key or "avgFieldGoals" in key.lower():
                            result["avgFieldGoalsMade"] = float(val[0])
                            result["avgFieldGoalsAttempted"] = float(val[1])
                        elif "avgThreePoint" in key or "threePoint" in key.lower():
                            result["avgThreePointMade"] = float(val[0])
                            result["avgThreePointAttempted"] = float(val[1])
                        elif "Free Throws" in key or "freethrow" in key.lower():
                            result["avgFreeThrowsMade"] = float(val[0])
                            result["avgFreeThrowsAttempted"] = float(val[1])
                except:
                    pass
        
        return result
    
    def _combine_home_away_stats(self, home: Dict, away: Dict, names: List) -> Dict:
        """Combine Home and Away stats for college basketball"""
        result = {}
        
        def parse_num(val):
            if val is None:
                return 0
            if isinstance(val, (int, float)):
                return val
            try:
                return float(str(val).replace(',', ''))
            except:
                return 0
        
        # Games played is summed
        home_games = parse_num(home.get("gamesPlayed", 0))
        away_games = parse_num(away.get("gamesPlayed", 0))
        total_games = home_games + away_games
        result["gamesPlayed"] = int(total_games)
        
        if total_games == 0:
            return result
        
        # Per-game stats are weighted averages
        avg_stats = [
            "avgMinutes", "avgPoints", "avgRebounds", "avgAssists", 
            "avgSteals", "avgBlocks", "avgTurnovers",
            "avgOffensiveRebounds", "avgDefensiveRebounds"
        ]
        
        for stat in avg_stats:
            home_val = parse_num(home.get(stat, 0))
            away_val = parse_num(away.get(stat, 0))
            
            # Weighted average based on games played
            if home_games + away_games > 0:
                weighted = (home_val * home_games + away_val * away_games) / total_games
                result[stat] = round(weighted, 1)
        
        # Percentage stats - calculate from combined totals where possible
        # For now, use simple average (more accurate would need attempts data)
        pct_stats = ["fieldGoalPct", "threePointFieldGoalPct", "freeThrowPct"]
        for stat in pct_stats:
            home_pct = parse_num(home.get(stat, 0))
            away_pct = parse_num(away.get(stat, 0))
            if home_pct or away_pct:
                weighted = (home_pct * home_games + away_pct * away_games) / total_games
                result[stat] = round(weighted, 1)
        
        # Copy combined shooting stats if present
        for key in home.keys():
            if key not in result and "-" in str(home.get(key, "")):
                # This is a combined field like "10.6-22.5"
                home_val = str(home.get(key, "0-0")).split("-")
                away_val = str(away.get(key, "0-0")).split("-")
                try:
                    made = (parse_num(home_val[0]) * home_games + parse_num(away_val[0]) * away_games) / total_games
                    att = (parse_num(home_val[1]) * home_games + parse_num(away_val[1]) * away_games) / total_games
                    result[key] = f"{round(made, 1)}-{round(att, 1)}"
                except:
                    pass
        
        return result
    
    def _calculate_nba_career_from_years(self, by_year: Dict) -> Dict:
        """Calculate NBA/WNBA career totals from year-by-year stats"""
        career = {}
        
        def parse_num(val):
            if val is None:
                return 0
            if isinstance(val, (int, float)):
                return val
            try:
                return float(str(val).replace(',', ''))
            except ValueError:
                return 0
        
        total_games = 0
        total_minutes = 0
        total_points = 0
        total_rebounds = 0
        total_assists = 0
        total_steals = 0
        total_blocks = 0
        total_turnovers = 0
        total_fgm = 0
        total_fga = 0
        total_3pm = 0
        total_3pa = 0
        total_ftm = 0
        total_fta = 0
        
        for season, stats in by_year.items():
            if not stats:
                continue
            
            # Get games played - handle both formats
            games = parse_num(stats.get('gamesPlayed', stats.get('GP', 0)))
            if not games:
                continue
            
            total_games += games
            
            # Calculate totals from per-game averages (ESPN returns averages)
            mpg = parse_num(stats.get('avgMinutes', stats.get('MPG', 0)))
            ppg = parse_num(stats.get('avgPoints', stats.get('PPG', 0)))
            rpg = parse_num(stats.get('avgRebounds', stats.get('RPG', 0)))
            apg = parse_num(stats.get('avgAssists', stats.get('APG', 0)))
            spg = parse_num(stats.get('avgSteals', stats.get('SPG', 0)))
            bpg = parse_num(stats.get('avgBlocks', stats.get('BPG', 0)))
            topg = parse_num(stats.get('avgTurnovers', stats.get('TOPG', 0)))
            
            total_minutes += mpg * games
            total_points += ppg * games
            total_rebounds += rpg * games
            total_assists += apg * games
            total_steals += spg * games
            total_blocks += bpg * games
            total_turnovers += topg * games
            
            # Field goals
            fgm_pg = parse_num(stats.get('avgFieldGoalsMade', 0))
            fga_pg = parse_num(stats.get('avgFieldGoalsAttempted', 0))
            total_fgm += fgm_pg * games
            total_fga += fga_pg * games
            
            # 3 pointers
            tpm_pg = parse_num(stats.get('avgThreePointMade', 0))
            tpa_pg = parse_num(stats.get('avgThreePointAttempted', 0))
            total_3pm += tpm_pg * games
            total_3pa += tpa_pg * games
            
            # Free throws
            ftm_pg = parse_num(stats.get('avgFreeThrowsMade', 0))
            fta_pg = parse_num(stats.get('avgFreeThrowsAttempted', 0))
            total_ftm += ftm_pg * games
            total_fta += fta_pg * games
        
        # Set career totals
        career['career_games'] = int(total_games)
        career['career_minutes'] = int(total_minutes)
        career['career_points'] = int(total_points)
        career['career_rebounds'] = int(total_rebounds)
        career['career_assists'] = int(total_assists)
        career['career_steals'] = int(total_steals)
        career['career_blocks'] = int(total_blocks)
        career['career_turnovers'] = int(total_turnovers)
        
        # Calculate career averages
        if total_games > 0:
            career['career_ppg'] = round(total_points / total_games, 1)
            career['career_rpg'] = round(total_rebounds / total_games, 1)
            career['career_apg'] = round(total_assists / total_games, 1)
            career['career_spg'] = round(total_steals / total_games, 1)
            career['career_bpg'] = round(total_blocks / total_games, 1)
            career['career_topg'] = round(total_turnovers / total_games, 1)
            career['career_mpg'] = round(total_minutes / total_games, 1)
            
            # Calculate shooting percentages
            if total_fga > 0:
                career['career_fg_pct'] = round(total_fgm / total_fga * 100, 1)
            if total_3pa > 0:
                career['career_3p_pct'] = round(total_3pm / total_3pa * 100, 1)
            if total_fta > 0:
                career['career_ft_pct'] = round(total_ftm / total_fta * 100, 1)
        
        return career
    
