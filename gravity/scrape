    def _parse_number(self, text: str) -> int:
        """Convert '5.2M' to 5200000"""
        text = str(text).upper().strip().replace(',', '')
        
        multipliers = {'K': 1_000, 'M': 1_000_000, 'B': 1_000_000_000}
        
        for suffix, multiplier in multipliers.items():
            if suffix in text:
                try:
                    number = float(text.replace(suffix, ''))
                    return int(number * multiplier)
                except:
                    return 0
        
        try:
            return int(float(text))
        except:
            return 0
    
    def _scrape_with_requests(self, url: str, timeout: int = 10) -> Optional[str]:
        """Scrape URL directly with requests, with Firecrawl as fallback"""
        try:
            response = self.session.get(url, timeout=timeout, allow_redirects=True)
            if response.status_code == 200:
                return response.text
        except Exception as e:
            logger.debug(f"Direct request failed for {url[:50]}: {e}")
        
        # Fallback: Try Firecrawl if direct request fails
        try:
            logger.debug(f"Trying Firecrawl as fallback for {url[:50]}")
            result = self.scraper.scrape(url)
            if result and 'markdown' in result:
                return result['markdown']
            elif result and 'html' in result:
                return result['html']
        except Exception as e:
            logger.debug(f"Firecrawl fallback also failed for {url[:50]}: {e}")
        
        return None
    
    def collect_instagram_from_aggregators(self, handle: str) -> Dict:
        """Collect Instagram data from third-party aggregator sites with Firecrawl fallback"""
        data = {}
        
