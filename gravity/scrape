def save_checkpoint(data: List[Dict], checkpoint_name: str):
    """Save checkpoint data to file"""
    checkpoint_dir = Path(Config.PROGRESSIVE_CHECKPOINT_DIR)
    checkpoint_dir.mkdir(parents=True, exist_ok=True)
    checkpoint_file = checkpoint_dir / f"{checkpoint_name}.json"
    
    with open(checkpoint_file, 'w') as f:
        json.dump(data, f, indent=2, default=str)
    
    logger.info(f"Checkpoint saved: {checkpoint_file}")

def load_checkpoint(checkpoint_name: str) -> Optional[List[Dict]]:
    """Load checkpoint data from file"""
    checkpoint_file = Path(Config.PROGRESSIVE_CHECKPOINT_DIR) / f"{checkpoint_name}.json"
    
    if checkpoint_file.exists():
        with open(checkpoint_file, 'r') as f:
            data = json.load(f)
        logger.info(f"Checkpoint loaded: {checkpoint_file}")
        return data
    return None

def collect_all_teams_progressive(collector):
    """
    Progressive data collection in waves:
    Wave 1: Just names and positions (fast)
    Wave 2: Current stats (medium)
    Wave 3: Social media and enrichment (can run separately)
    """
    logger.info("🚀 Starting progressive data collection...")
    
    # Wave 1: Collect basic rosters (names and positions)
    logger.info("\n=== Wave 1: Collecting Basic Rosters ===")
    checkpoint_name = "wave1_rosters"
    
    # Try to load checkpoint
    all_rosters = load_checkpoint(checkpoint_name)
    if not all_rosters:
        logger.info("Collecting rosters from all teams...")
        all_rosters = []
        teams = {
            "Arizona Cardinals": "ARI", "Atlanta Falcons": "ATL", "Baltimore Ravens": "BAL",
            "Buffalo Bills": "BUF", "Carolina Panthers": "CAR", "Chicago Bears": "CHI",
            "Cincinnati Bengals": "CIN", "Cleveland Browns": "CLE", "Dallas Cowboys": "DAL",
            "Denver Broncos": "DEN", "Detroit Lions": "DET", "Green Bay Packers": "GB",
            "Houston Texans": "HOU", "Indianapolis Colts": "IND", "Jacksonville Jaguars": "JAX",
            "Kansas City Chiefs": "KC", "Las Vegas Raiders": "LV", "Los Angeles Chargers": "LAC",
            "Los Angeles Rams": "LAR", "Miami Dolphins": "MIA", "Minnesota Vikings": "MIN",
            "New England Patriots": "NE", "New Orleans Saints": "NO", "New York Giants": "NYG",
            "New York Jets": "NYJ", "Philadelphia Eagles": "PHI", "Pittsburgh Steelers": "PIT",
            "San Francisco 49ers": "SF", "Seattle Seahawks": "SEA", "Tampa Bay Buccaneers": "TB",
            "Tennessee Titans": "TEN", "Washington Commanders": "WSH"
        }
        
        def collect_team_roster(team_info):
            team_name, team_abbr = team_info
            try:
                roster = get_team_roster(collector, team_name)
                return roster
            except Exception as e:
                logger.error(f"Failed to collect roster for {team_name}: {e}")
                return []
        
        max_concurrent_teams = min(Config.MAX_CONCURRENT_PLAYERS, len(teams))
        with ThreadPoolExecutor(max_workers=max_concurrent_teams) as executor:
            team_rosters = list(executor.map(collect_team_roster, teams.items()))
        
        for roster in team_rosters:
            all_rosters.extend(roster)
        
        save_checkpoint(all_rosters, checkpoint_name)
    
    logger.info(f"✓ Wave 1 complete: {len(all_rosters)} players")
    
    # Wave 2: Current stats (parallel processing)
    logger.info("\n=== Wave 2: Collecting Current Stats ===")
    checkpoint_name = "wave2_stats"
    
    stats_data = load_checkpoint(checkpoint_name)
    if not stats_data:
        logger.info(f"Collecting stats for {len(all_rosters)} players...")
        stats_data = []
        
        def collect_player_stats(player_info):
            player_name = player_info.get('name', '')
            team = player_info.get('team', '')
            position = player_info.get('position', 'UNK')
            
            try:
                # Only collect proof data (stats)
                proof_data = collector._collect_proof(player_name, position)
                return {
                    'player_name': player_name,
                    'team': team,
                    'position': position,
                    'proof': asdict(proof_data) if proof_data else {}
                }
            except Exception as e:
                logger.debug(f"Failed to collect stats for {player_name}: {e}")
                return None
        
        with ThreadPoolExecutor(max_workers=50) as executor:
            stats_futures = [executor.submit(collect_player_stats, p) for p in all_rosters]
        
        for future in as_completed(stats_futures):
            result = future.result()
            if result:
                stats_data.append(result)
        
        save_checkpoint(stats_data, checkpoint_name)
    
    logger.info(f"✓ Wave 2 complete: {len(stats_data)} players with stats")
    
    # Wave 3: Social media and enrichment (can run separately)
    logger.info("\n=== Wave 3: Collecting Social Media & Enrichment ===")
    logger.info("This wave can be run separately if needed")
    
    return all_rosters, stats_data

def get_all_social_media_once(player_name: str, scraper) -> Dict:
    """
    Single search to find all social profiles (reduces API calls)
    """
    search_query = f"{player_name} NFL site:instagram.com OR site:twitter.com OR site:tiktok.com"
    search_url = f"https://www.google.com/search?q={quote(search_query)}"
    
    try:
        result = scraper.scrape(search_url)
        if result and 'markdown' in result:
            text = result['markdown']
            
            # Extract all social handles from one result
            social_data = {
                'instagram_handle': None,
                'twitter_handle': None,
                'tiktok_handle': None
            }
            
            # Extract Instagram
            instagram_match = re.search(r'instagram\.com/([a-zA-Z0-9_.]+)', text, re.IGNORECASE)
            if instagram_match:
                social_data['instagram_handle'] = instagram_match.group(1)
            
            # Extract Twitter/X
            twitter_match = re.search(r'(?:twitter|x)\.com/([a-zA-Z0-9_]+)', text, re.IGNORECASE)
            if twitter_match:
                social_data['twitter_handle'] = twitter_match.group(1)
            
            # Extract TikTok
            tiktok_match = re.search(r'tiktok\.com/@([a-zA-Z0-9_.]+)', text, re.IGNORECASE)
            if tiktok_match:
                social_data['tiktok_handle'] = tiktok_match.group(1)
            
            return social_data
    except Exception as e:
        logger.debug(f"Failed to get social media for {player_name}: {e}")
    
    return {}

