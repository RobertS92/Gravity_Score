    def _collect_risk(self, player_name: str, position: str, age: int) -> RiskData:
        """
        Collect comprehensive risk data using analyzers + ESPN injury history
        """
        # First, use the standard risk analyzer
        risk = self.risk_analyzer.analyze_risk(player_name, position, age)
        
        # Then, enhance with ESPN injury data if available
        if hasattr(self, '_espn_player_data') and self._espn_player_data:
            espn_injury_history = self._espn_player_data.get("injury_history", [])
            
            if espn_injury_history:
                # Merge ESPN injuries with existing injury history
                existing_injuries = risk.injury_history or []
                
                # Add ESPN injuries that aren't duplicates
                for espn_injury in espn_injury_history:
                    # Simple deduplication by type and date
                    injury_key = f"{espn_injury.get('type', '')}_{espn_injury.get('date', '')}"
                    existing_keys = [f"{inj.get('type', '')}_{inj.get('date', '')}" for inj in existing_injuries]
                    
                    if injury_key not in existing_keys:
                        existing_injuries.append(espn_injury)
                
                risk.injury_history = existing_injuries
                
                # Organize injuries by year
                injury_by_year = {}
                current_year = datetime.now().year
                current_season_injuries = []
                
                for injury in existing_injuries:
                    # Extract year from date (format: "YYYY-MM-DD" or similar)
                    injury_date = injury.get("date", "")
                    year = None
                    
                    if injury_date:
                        # Try to parse year from date string
                        year_match = re.search(r'(\d{4})', str(injury_date))
                        if year_match:
                            year = year_match.group(1)
                    
                    if year:
                        if year not in injury_by_year:
                            injury_by_year[year] = []
                        injury_by_year[year].append(injury)
                        
                        # Track current season injuries (current year and last year for ongoing season)
                        if int(year) >= current_year - 1:
                            current_season_injuries.append(injury)
                    else:
                        # No year found, put in "Unknown" category
                        if "Unknown" not in injury_by_year:
                            injury_by_year["Unknown"] = []
                        injury_by_year["Unknown"].append(injury)
                
                risk.injury_history_by_year = injury_by_year
                risk.current_season_injuries = current_season_injuries
                
                # Recalculate games missed if we have more injury data
                games_missed = 0
                for injury in espn_injury_history:
                    # Extract game count from details if available
                    details = injury.get("details", "")
                    match = re.search(r'(\d+)\s+game', details, re.IGNORECASE)
                    if match:
                        games_missed += int(match.group(1))
                
                if games_missed > 0:
                    risk.games_missed_career = max(risk.games_missed_career or 0, games_missed)
                
                logger.info(f"   📋 Enhanced risk data: {len(espn_injury_history)} total injuries, "
                           f"{len(injury_by_year)} years, {len(current_season_injuries)} current season")
        
        return risk
    
    def _calculate_performance_trend_from_weekly(self, player_name: str, position: str) -> Optional[Dict]:
        """Calculate performance trend from weekly stats"""
        # Get stats that were collected
        stats = self.stats_collector.collect_stats(player_name, position)
        weekly_stats = stats.get('weekly_stats', [])
        
        if not weekly_stats or len(weekly_stats) < 3:
            return None
        
        # Sort by week (most recent first)
        weekly_stats_sorted = sorted(weekly_stats, key=lambda x: x.get('week', 0), reverse=True)
        
        # Get last 4 weeks vs previous 4 weeks
        recent_weeks = weekly_stats_sorted[:4]
        previous_weeks = weekly_stats_sorted[4:8] if len(weekly_stats_sorted) >= 8 else []
        
        # Calculate average performance for each period
        recent_avg = self._calculate_weekly_average(recent_weeks, position)
        previous_avg = self._calculate_weekly_average(previous_weeks, position) if previous_weeks else None
        
        if not recent_avg:
            return None
        
        # Determine trend
        if previous_avg:
            # Compare recent vs previous
            improvement_pct = 0.0
            if position == 'QB':
                if previous_avg.get('pass_yards', 0) > 0:
                    improvement_pct = ((recent_avg.get('pass_yards', 0) - previous_avg.get('pass_yards', 0)) / previous_avg.get('pass_yards', 0)) * 100
            elif position == 'RB':
                if previous_avg.get('rush_yards', 0) > 0:
                    improvement_pct = ((recent_avg.get('rush_yards', 0) - previous_avg.get('rush_yards', 0)) / previous_avg.get('rush_yards', 0)) * 100
            elif position in ['WR', 'TE']:
                if previous_avg.get('rec_yards', 0) > 0:
                    improvement_pct = ((recent_avg.get('rec_yards', 0) - previous_avg.get('rec_yards', 0)) / previous_avg.get('rec_yards', 0)) * 100
            elif position in ['DL', 'LB', 'DB']:
                if previous_avg.get('tackles', 0) > 0:
                    improvement_pct = ((recent_avg.get('tackles', 0) - previous_avg.get('tackles', 0)) / previous_avg.get('tackles', 0)) * 100
            
            if improvement_pct > 10:
                trend = 'improving'
            elif improvement_pct < -10:
                trend = 'declining'
            else:
                trend = 'stable'
        else:
            # Only recent data available, assume stable
            trend = 'stable'
            improvement_pct = 0.0
        
        return {
            'trend': trend,
            'improvement_pct': round(improvement_pct, 1),
            'recent_avg': recent_avg,
            'previous_avg': previous_avg
        }
    
    def _calculate_weekly_average(self, weeks: List[Dict], position: str) -> Dict:
        """Calculate average stats from weekly data"""
        if not weeks:
            return {}
        
        avg = {}
        
        if position == 'QB':
            pass_yards = [w.get('pass_yards', 0) for w in weeks if w.get('pass_yards')]
            pass_tds = [w.get('pass_tds', 0) for w in weeks if w.get('pass_tds')]
            if pass_yards:
                avg['pass_yards'] = sum(pass_yards) / len(pass_yards)
            if pass_tds:
                avg['pass_tds'] = sum(pass_tds) / len(pass_tds)
        elif position == 'RB':
            rush_yards = [w.get('rush_yards', 0) for w in weeks if w.get('rush_yards')]
            rush_tds = [w.get('rush_tds', 0) for w in weeks if w.get('rush_tds')]
            if rush_yards:
                avg['rush_yards'] = sum(rush_yards) / len(rush_yards)
            if rush_tds:
                avg['rush_tds'] = sum(rush_tds) / len(rush_tds)
        elif position in ['WR', 'TE']:
            rec_yards = [w.get('rec_yards', 0) for w in weeks if w.get('rec_yards')]
            receptions = [w.get('receptions', 0) for w in weeks if w.get('receptions')]
            if rec_yards:
                avg['rec_yards'] = sum(rec_yards) / len(rec_yards)
            if receptions:
                avg['receptions'] = sum(receptions) / len(receptions)
        elif position in ['DL', 'LB', 'DB']:
            tackles = [w.get('tackles', 0) for w in weeks if w.get('tackles')]
            sacks = [w.get('sacks', 0) for w in weeks if w.get('sacks')]
            if tackles:
                avg['tackles'] = sum(tackles) / len(tackles)
            if sacks:
                avg['sacks'] = sum(sacks) / len(sacks)
        
        return avg
    
