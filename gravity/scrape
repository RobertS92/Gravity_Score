def batch_scrape_players(fc_app, player_urls: List[str], batch_size: int = None) -> List[Dict]:
    """
    Scrape multiple player pages in one batch request using Firecrawl batch API
    
    Args:
        fc_app: Firecrawl app instance
        player_urls: List of player URLs to scrape
        batch_size: Number of URLs per batch (defaults to Config.BATCH_SIZE)
    
    Returns:
        List of scraped results
    """
    if not player_urls:
        return []
    
    batch_size = batch_size or Config.BATCH_SIZE
    results = []
    
    for i in range(0, len(player_urls), batch_size):
        batch = player_urls[i:i+batch_size]
        logger.info(f"Processing batch {i//batch_size + 1}/{(len(player_urls)-1)//batch_size + 1} ({len(batch)} URLs)...")
        
        try:
            # Use Firecrawl batch_scrape API
            batch_result = fc_app.batch_scrape(
                batch,
                formats=["markdown", "json"],
                timeout=60000,
                poll_interval=2
            )
            
            # Handle different response formats
            if hasattr(batch_result, "data"):
                batch_data = batch_result.data if batch_result.data else []
            elif isinstance(batch_result, dict) and "data" in batch_result:
                batch_data = batch_result["data"]
            else:
                batch_data = batch_result if isinstance(batch_result, list) else []
            
            results.extend(batch_data)
            logger.info(f"✓ Batch {i//batch_size + 1} completed ({len(batch_data)} results)")
            
            # Brief pause between batches
            time.sleep(Config.REQUEST_DELAY)
            
        except Exception as e:
            logger.warning(f"Batch {i//batch_size + 1} failed: {e}, falling back to individual scraping...")
            # Fallback to individual scraping
            for url in batch:
                try:
                    result = fc_app.scrape(url)
                    results.append(result)
                    time.sleep(Config.REQUEST_DELAY)
                except Exception as seq_error:
                    logger.error(f"Failed to scrape {url}: {seq_error}")
                    continue
    
    return results

