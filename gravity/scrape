    def _parse_rss_feed(self, xml_content: str, max_articles: int) -> List[Dict]:
        """Parse RSS XML into articles list"""
        import re
        articles = []
        
        # Simple XML parsing without external library
        items = re.findall(r'<item>(.*?)</item>', xml_content, re.DOTALL)
        
        for item in items[:max_articles]:
            title_match = re.search(r'<title>(.*?)</title>', item)
            link_match = re.search(r'<link>(.*?)</link>', item)
            date_match = re.search(r'<pubDate>(.*?)</pubDate>', item)
            source_match = re.search(r'<source.*?>(.*?)</source>', item)
            
            if title_match and link_match:
                articles.append({
                    "title": title_match.group(1).replace("&amp;", "&").replace("&quot;", '"'),
                    "url": link_match.group(1),
                    "published": date_match.group(1) if date_match else "",
                    "source": source_match.group(1) if source_match else ""
                })
        
        return articles
    
