    def _calculate_cfb_career_from_years(self, by_year: Dict) -> Dict:
        """Calculate CFB career totals from year-by-year stats"""
        career = {}
        
        # Map of stat names to sum (include both internal names and display names)
        sum_stats = {
            'receptions': 'career_receptions',
            'receivingYards': 'career_receiving_yards',
            'receivingTouchdowns': 'career_receiving_tds',
            'rushingAttempts': 'career_rushing_attempts',
            'rushingYards': 'career_rushing_yards',
            'rushingTouchdowns': 'career_rushing_tds',
            'passingAttempts': 'career_passing_attempts',
            'passingYards': 'career_passing_yards',
            'passingTouchdowns': 'career_passing_tds',
            'interceptions': 'career_interceptions',
            'fumbles': 'career_fumbles',
            'fumblesLost': 'career_fumbles_lost',
            'tackles': 'career_tackles',
            'sacks': 'career_sacks',
            'tacklesForLoss': 'career_tfl',
        }
        
        games = 0
        total_receptions = 0
        total_rec_yards = 0
        total_rec_tds = 0
        total_rush_yards = 0
        total_rush_tds = 0
        
        for season, stats in by_year.items():
            if not stats:
                continue
            
            # Parse numeric value from string (handle commas)
            def parse_num(val):
                if val is None:
                    return 0
                if isinstance(val, (int, float)):
                    return val
                try:
                    return float(str(val).replace(',', ''))
                except ValueError:
                    return 0
            
            # Sum up key stats
            total_receptions += parse_num(stats.get('receptions', 0))
            total_rec_yards += parse_num(stats.get('receivingYards', 0))
            total_rec_tds += parse_num(stats.get('receivingTouchdowns', 0))
            total_rush_yards += parse_num(stats.get('rushingYards', 0))
            total_rush_tds += parse_num(stats.get('rushingTouchdowns', 0))
        
        career['career_receptions'] = int(total_receptions)
        career['career_receiving_yards'] = int(total_rec_yards)
        career['career_receiving_tds'] = int(total_rec_tds)
        career['career_rushing_yards'] = int(total_rush_yards)
        career['career_rushing_tds'] = int(total_rush_tds)
        career['career_total_tds'] = int(total_rec_tds + total_rush_tds)
        career['career_total_yards'] = int(total_rec_yards + total_rush_yards)
        career['total_games'] = len(by_year)  # Number of seasons played
        
        return career
    
