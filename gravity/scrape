    def _parse_espn_ncaab_season_stats(self, stats_data: Dict) -> Dict:
        """Parse ESPN NCAAB splits response to get season stats"""
        result = {}
        
        # Get stat names from the response
        names = stats_data.get("names", [])
        display_names = stats_data.get("displayNames", [])
        
        split_categories = stats_data.get("splitCategories", [])
        
        # NCAAB uses Home/Away splits, not Season totals
        # Combine Home and Away to get season totals
        home_stats = None
        away_stats = None
        home_games = 0
        away_games = 0
        
        for cat in split_categories:
            if cat.get("displayName") == "split":
                for split in cat.get("splits", []):
                    split_name = split.get("displayName", "")
                    stats = split.get("stats", [])
                    
                    # Check for Season or Total first
                    if split_name in ["Season", "All Splits", "Total"]:
                        for i, stat_value in enumerate(stats):
                            if i < len(names):
                                result[names[i]] = stat_value
                                if i < len(display_names):
                                    result[display_names[i]] = stat_value
                        return result
                    
                    # Otherwise collect Home/Away
                    if split_name == "Home" and stats:
                        home_stats = stats
                        try:
                            home_games = int(stats[0]) if stats[0] else 0
                        except:
                            home_games = 0
                    elif split_name == "Away" and stats:
                        away_stats = stats
                        try:
                            away_games = int(stats[0]) if stats[0] else 0
                        except:
                            away_games = 0
        
        # Combine Home + Away stats
        if home_stats or away_stats:
            total_games = home_games + away_games
            result["gamesPlayed"] = total_games
            
            # For averaging stats, do weighted average by games
            if home_stats and away_stats and total_games > 0:
                for i, name in enumerate(names):
                    if i == 0:  # games played already handled
                        continue
                    
                    home_val = home_stats[i] if i < len(home_stats) else "0"
                    away_val = away_stats[i] if i < len(away_stats) else "0"
                    
                    # Parse values (handle format like "6.0-12.4")
                    def parse_val(v):
                        if isinstance(v, (int, float)):
                            return v
                        try:
                            return float(str(v).replace(',', '').split('-')[0])
                        except:
                            return 0
                    
                    home_num = parse_val(home_val)
                    away_num = parse_val(away_val)
                    
                    # Weighted average
                    if home_games > 0 and away_games > 0:
                        weighted = (home_num * home_games + away_num * away_games) / total_games
                        result[name] = round(weighted, 1)
                    elif home_games > 0:
                        result[name] = home_num
                    elif away_games > 0:
                        result[name] = away_num
                    
                    if i < len(display_names):
                        result[display_names[i]] = result[name]
            elif home_stats:
                for i, stat_value in enumerate(home_stats):
                    if i < len(names):
                        result[names[i]] = stat_value
            elif away_stats:
                for i, stat_value in enumerate(away_stats):
                    if i < len(names):
                        result[names[i]] = stat_value
        
        return result
    
