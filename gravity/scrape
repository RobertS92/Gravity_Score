                player_times.append(player_time)
                completed_count += 1
                
                # Update progress bar
                elapsed_time = time.time() - start_time
                print_progress_bar(completed_count, len(players), elapsed_time, player_times)
            
            # Print summary
            print(f"\n{'='*70}")
            print(f"Summary for {player_name}")
            print(f"{'='*70}")
            print(f"Age: {player_data.identity.age or 'N/A'}")
            instagram_followers = player_data.brand.instagram_followers or 0
            print(f"Instagram: {instagram_followers:,} followers")
            twitter_followers = player_data.brand.twitter_followers or 0
            print(f"Twitter: {twitter_followers:,} followers")
            print(f"News mentions (30d): {player_data.brand.news_headline_count_30d or 0}")
            print(f"Sentiment: {player_data.brand.brand_sentiment or 0.0}")
            # Check if NBA or NFL
            if hasattr(player_data.proof, 'all_star_selections'):
                print(f"All-Star Selections: {player_data.proof.all_star_selections or 0}")
            elif hasattr(player_data.proof, 'pro_bowls'):
                print(f"Pro Bowls: {player_data.proof.pro_bowls or 0}")
            print(f"Injury risk: {player_data.risk.injury_risk_score or 0}/100")
            print(f"Data quality: {player_data.data_quality_score or 0}%")
            print(f"Exported to JSON: {json_file}")
            print(f"Exported to CSV: {csv_file}")
            
            return player_data
            
        except Exception as e:
            player_time = time.time() - player_start_time
            
            # Thread-safe error tracking
            with progress_lock:
                failed_collections += 1
                player_times.append(player_time)
                completed_count += 1
                
                # Update progress bar
                elapsed_time = time.time() - start_time
                print_progress_bar(completed_count, len(players), elapsed_time, player_times)
            
            logger.error(f"Failed to collect data for {player_name}: {e}")
            print(f"\n❌ Error collecting data for {player_name}: {e}")
            return None
    
    # Process players in parallel
    if len(players) == 1:
        # Single player - no need for threading overhead
        player_data = process_single_player(players[0], 1)
        if player_data:
            all_player_data.append(player_data)
    else:
        # Multiple players - use parallel processing
        with ThreadPoolExecutor(max_workers=Config.MAX_CONCURRENT_PLAYERS) as executor:
            # Submit all players
            future_to_player = {
                executor.submit(process_single_player, player_info, idx + 1): player_info
                for idx, player_info in enumerate(players)
            }
            
            # Collect results as they complete
            for future in as_completed(future_to_player):
                try:
                    player_data = future.result()
                    if player_data:
                        all_player_data.append(player_data)
                except Exception as e:
                    player_info = future_to_player[future]
                    logger.error(f"Unexpected error processing {player_info.get('name', 'Unknown')}: {e}")
    
    # Final progress update
    elapsed_time = time.time() - start_time
    print_progress_bar(len(players), len(players), elapsed_time, player_times)
    print()  # New line after progress bar
    
    # Final summary
    total_time = time.time() - start_time
    avg_time_per_player = total_time / len(players) if len(players) > 0 else 0
    
    print(f"\n{'='*70}")
    print(f"COLLECTION COMPLETE")
    print(f"{'='*70}")
    print(f"Total players processed: {len(players)}")
    print(f"Successful collections: {successful_collections}")
    print(f"Failed collections: {failed_collections}")
    print(f"Total time: {format_time(total_time)}")
    print(f"Average time per player: {format_time(avg_time_per_player)}")
    
    # Export combined data (both JSON and CSV) if multiple players
    if len(all_player_data) > 1:
        try:
            # Use database if enabled
            if Config.USE_DATABASE:
                logger.info("Exporting to database...")
                db = PlayerDatabase()
                player_dicts = [asdict(p) for p in all_player_data]
                db.bulk_insert(player_dicts)
                print(f"\n✅ Data exported to database: {Config.DATABASE_PATH}")
                print(f"   Total players: {len(all_player_data)}")
            
            # Also export to JSON/CSV files
            output_folder = getattr(collector, 'output_folder', '')
            if output_folder:
                combined_json = os.path.join(output_folder, f"nfl_players_{datetime.now().strftime('%Y%m%d_%H%M%S')}.json")
            else:
                combined_json = f"nfl_players_{datetime.now().strftime('%Y%m%d_%H%M%S')}.json"
            
            with open(combined_json, 'w') as f:
                json.dump([asdict(p) for p in all_player_data], f, indent=2, default=str)
            
            # Export combined CSV
            combined_csv = collector.export_multiple_to_csv(all_player_data)
            
            print(f"\n✅ All data exported to: {output_folder if output_folder else 'current directory'}")
            print(f"   Combined JSON: {combined_json}")
            print(f"   Combined CSV: {combined_csv}")
            if not Config.USE_DATABASE:
                print(f"   Total players: {len(all_player_data)}")
        except Exception as e:
            logger.error(f"Failed to export combined data: {e}")
    
    print(f"{'='*70}")


