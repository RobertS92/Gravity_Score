                data = response.json()
                players = self._parse_espn_roster(data)
                if players:
                    self.cache.set(cache_key, players)
                    logger.info(f"✅ ESPN API: Got {len(players)} players for {team_abbrev}")
                return players
            return []
        except Exception as e:
            logger.debug(f"ESPN roster API failed for {team_abbrev}: {e}")
            return []
    
    def get_espn_nba_roster(self, team_abbrev: str) -> List[Dict]:
        """Get full NBA team roster from ESPN API"""
        cache_key = f"espn_roster_nba_{team_abbrev}"
        cached = self.cache.get(cache_key)
        if cached:
            return cached
        
        try:
            team_id = self._get_espn_nba_team_id(team_abbrev)
            if not team_id:
                return []
            
            roster_url = f"https://site.api.espn.com/apis/site/v2/sports/basketball/nba/teams/{team_id}/roster"
            response = self.session.get(roster_url, headers=self.espn_headers, timeout=15)
            
            if response.status_code == 200:
                data = response.json()
                players = self._parse_espn_roster(data)
                if players:
                    self.cache.set(cache_key, players)
                    logger.info(f"✅ ESPN API: Got {len(players)} NBA players for {team_abbrev}")
                return players
            return []
        except Exception as e:
            logger.debug(f"ESPN NBA roster API failed: {e}")
            return []
    
    def _parse_espn_roster(self, data: Dict) -> List[Dict]:
        """Parse ESPN roster response"""
        players = []
        
        athletes_data = data.get("athletes", [])
        
        # Check if athletes are directly in the array (new ESPN format)
        if athletes_data and isinstance(athletes_data, list):
            # Check if first item is a player object (has 'displayName') or a section (has 'items')
            if len(athletes_data) > 0:
                first_item = athletes_data[0]
                
                if isinstance(first_item, dict) and "displayName" in first_item:
                    # NEW FORMAT: Athletes are directly in the array
                    for athlete in athletes_data:
                        position_data = athlete.get("position", {})
                        position = position_data.get("abbreviation", "") if isinstance(position_data, dict) else ""
                        
                        college_data = athlete.get("college", {})
                        college = college_data.get("name", "") if isinstance(college_data, dict) else ""
                        
                        headshot_data = athlete.get("headshot", {})
                        headshot = headshot_data.get("href", "") if isinstance(headshot_data, dict) else ""
                        
                        players.append({
                            "espn_id": athlete.get("id"),
                            "name": athlete.get("displayName", ""),
                            "position": position,
                            "jersey_number": athlete.get("jersey", ""),
                            "age": athlete.get("age"),
                            "height": athlete.get("displayHeight", ""),
                            "weight": athlete.get("displayWeight", ""),
                            "college": college,
                            "headshot": headshot
                        })
                
                elif isinstance(first_item, dict) and "items" in first_item:
                    # OLD FORMAT: Athletes are in sections with items
                    for section in athletes_data:
                        items = section.get("items", [])
                        for athlete in items:
                            position_data = athlete.get("position", {})
                            position = position_data.get("abbreviation", "") if isinstance(position_data, dict) else ""
                            
                            college_data = athlete.get("college", {})
                            college = college_data.get("name", "") if isinstance(college_data, dict) else ""
                            
                            headshot_data = athlete.get("headshot", {})
                            headshot = headshot_data.get("href", "") if isinstance(headshot_data, dict) else ""
                            
                            players.append({
                                "espn_id": athlete.get("id"),
                                "name": athlete.get("displayName", ""),
                                "position": position,
                                "jersey_number": athlete.get("jersey", ""),
                                "age": athlete.get("age"),
                                "height": athlete.get("height", ""),
                                "weight": athlete.get("weight", ""),
                                "college": college,
                                "headshot": headshot
                            })
        
        return players
    
