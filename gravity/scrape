    def get_complete_cfb_player_data(self, player_name: str, team: str = None) -> Dict:
        """
        Get ALL College Football player data from ESPN APIs.
        Uses CORE API for detailed info + site API for stats/awards.
        
        Returns complete data for:
        - Identity (name, team, position, height, weight, class, high school, recruiting)
        - Stats (current season, career)
        - Awards (All-American, Heisman, Conference awards)
        - Draft projection
        """
