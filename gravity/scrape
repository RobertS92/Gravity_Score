    def _extract_stat(self, stats_dict: Dict, possible_keys: List[str]) -> Optional[Union[int, float]]:
        """
        Extract a stat value from dictionary using multiple possible key names
        
        Args:
            stats_dict: Dictionary containing stats
            possible_keys: List of possible key names to try
        
        Returns:
            Stat value (int, float) or None if not found
        """
        if not stats_dict:
            return None
        
        # Try each possible key
        for key in possible_keys:
            # Try exact match
            if key in stats_dict and stats_dict[key] is not None:
                value = stats_dict[key]
                # Convert to appropriate type
                if isinstance(value, (int, float)):
                    return value
                elif isinstance(value, str):
                    # Try to extract number from string
                    num_match = re.search(r'[\d.]+', value)
                    if num_match:
                        try:
                            return float(num_match.group())
                        except:
                            pass
                return value
            
            # Try case-insensitive match
            for dict_key in stats_dict.keys():
                if isinstance(dict_key, str) and dict_key.lower() == key.lower():
                    value = stats_dict[dict_key]
                    if value is not None:
                        if isinstance(value, (int, float)):
                            return value
                        elif isinstance(value, str):
                            num_match = re.search(r'[\d.]+', value)
                            if num_match:
                                try:
                                    return float(num_match.group())
                                except:
                                    pass
                        return value
        
        return None
    
