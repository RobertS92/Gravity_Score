                patterns = [
                    r'Followers[^>]*>([\d,KM]+)',
                    r'"followers":\s*"?([\d,KM]+)',
                    r'(\d+[KM]?)\s*Followers',
                    r'followers[^:]*:\s*([\d,KM]+)'
                ]
                for pattern in patterns:
                    followers_match = re.search(pattern, html, re.IGNORECASE)
                    if followers_match:
                        parsed = self._parse_number(followers_match.group(1))
                        if parsed and parsed > 0:
                            data['instagram_followers'] = parsed
