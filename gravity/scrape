        Flow:
        1. Scrape page with Firecrawl v2 API (gets clean markdown/JSON)
        2. Convert Firecrawl result to JSON format (includes full markdown)
        3. Feed full markdown to LLM with extraction schema
        4. Return parsed structured data
        
        Args:
            url: URL to scrape
            extraction_schema: Schema defining what data to extract
        
        Returns:
            Parsed structured data from LLM
        """
        # First, scrape the page (without screenshot since v1 API doesn't support it)
        # Add retry logic for rate limiting
        result = None
        for attempt in range(Config.MAX_RETRIES):
            try:
                result = self.scrape(url, screenshot=False)
                if result:
                    break
            except Exception as e:
                error_str = str(e).lower()
                if "429" in error_str or "rate limit" in error_str:
                    wait_time = (2 ** attempt) * 2
                    logger.warning(f"Rate limited on LLM parsing attempt {attempt + 1}, waiting {wait_time}s...")
                    time.sleep(wait_time)
                    continue
                else:
                    logger.warning(f"Scrape error on attempt {attempt + 1}: {e}")
                    if attempt == Config.MAX_RETRIES - 1:
                        return {}
        
        if not result:
            logger.warning(f"Failed to scrape {url[:50]} after {Config.MAX_RETRIES} attempts")
            return {}
        
        # Convert page to JSON format for LLM
        page_json = self._convert_page_to_json(result)
        
