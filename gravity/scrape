    def export_to_csv(self, player_data: PlayerData, filename: str = None) -> str:
        """Export player data to CSV file with flattened structure"""
        if not filename:
            filename = f"{player_data.player_name.replace(' ', '_')}_{datetime.now().strftime('%Y%m%d_%H%M%S')}.csv"
        else:
            # Ensure timestamp is in filename if not already present
            timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
            if timestamp not in filename:
                # Add timestamp before file extension
                name, ext = os.path.splitext(filename)
                filename = f"{name}_{timestamp}{ext}"
        
        # Use output folder if set
        if hasattr(self, 'output_folder') and self.output_folder:
            filename = os.path.join(self.output_folder, os.path.basename(filename))
        
        # Flatten nested data structure
        flat_data = self._flatten_player_data(player_data)
        
        # Get all possible field names (union of all keys)
        fieldnames = sorted(flat_data.keys())
        
        # Write CSV
        with open(filename, 'w', newline='', encoding='utf-8') as f:
