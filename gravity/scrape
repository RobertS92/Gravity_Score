        results = {
            'organizations': [],
            'activities': []
        }
        
        # Search query
        search_query = f"{player_name} charity foundation community philanthropy"
        search_url = f"https://www.google.com/search?q={quote(search_query)}"
        
        result = self.scraper.scrape(search_url)
        
        if result and 'markdown' in result:
            text = result['markdown']
            
            # Look for foundation/charity names
            foundation_pattern = r'([A-Z][A-Za-z\s]+(?:Foundation|Charity|Fund|Initiative))'
            foundation_matches = re.findall(foundation_pattern, text)
            
            for match in foundation_matches[:3]:
                results['organizations'].append(match.strip())
            
            # Look for activities
            activity_keywords = [
                'donated', 'raised', 'scholarship', 'youth camp', 'food drive',
                'back to school', 'thanksgiving', 'christmas', 'hospital visit',
                'community event', 'charity game', 'fundraiser'
            ]
            
            for keyword in activity_keywords:
                if keyword in text.lower():
                    # Extract context
                    pattern = f'([^.]*{keyword}[^.]*)'
                    match = re.search(pattern, text, re.IGNORECASE)
                    if match:
                        results['activities'].append(match.group(1).strip()[:200])
        
        return results

