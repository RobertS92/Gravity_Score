            },
            'proximity': {
                'endorsements': 2, 'endorsement_value': 2, 'market_size': 1
            },
            'velocity': {
                'media_buzz_surge': 2, 'performance_trend': 2, 'age_curve_position': 1
            },
            'risk': {
                'injury_risk_score': 2, 'controversy_risk_score': 2, 'contract_status': 1
            }
        }
        
        # Check all dataclass fields with position-aware weights
        # Use __dataclass_fields__ instead of asdict to avoid recursion issues with nested structures
        for section_name in ['identity', 'brand', 'proof', 'proximity', 'velocity', 'risk']:
            section = getattr(player_data, section_name)
            if section:
                section_weights = important_fields.get(section_name, {})
                # Use __dataclass_fields__ to get actual field names (avoids recursion from asdict)
                if hasattr(section, '__dataclass_fields__'):
                    for field_name in section.__dataclass_fields__.keys():
                        # Skip excluded fields for this position
                        if section_name == 'proof' and field_name in excluded_proof_fields:
                            continue
                        
                        # For proof section, only count relevant fields
                        if section_name == 'proof' and field_name not in relevant_proof_fields and field_name not in ['pro_bowls', 'all_pro_selections', 'super_bowl_wins', 'awards', 'career_earnings', 'off_field_achievements', 'community_involvement', 'charitable_organizations']:
                            # Only count if it's a general field or position-relevant
                            if field_name not in ['career_stats', 'current_season_stats', 'last_season_stats']:
                                continue
                        
                        # Get field value directly
                        field_value = getattr(section, field_name, None)
                        
                        weight = section_weights.get(field_name, 1)  # Default weight of 1
                        total_weight += weight
                        
                        if field_value is not None:
                            if isinstance(field_value, (list, dict)):
                                if field_value:  # Not empty
                                    filled_weight += weight
                            else:
                                filled_weight += weight
        
        if total_weight == 0:
            return 0.0
        
        return round((filled_weight / total_weight) * 100, 1)
    
    def export_to_json(self, player_data: PlayerData, filename: str = None) -> str:
        """Export player data to JSON file"""
        if not filename:
            filename = f"{player_data.player_name.replace(' ', '_')}_{datetime.now().strftime('%Y%m%d_%H%M%S')}.json"
        else:
            # Ensure timestamp is in filename if not already present
            timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
            if timestamp not in filename:
                # Add timestamp before file extension
                name, ext = os.path.splitext(filename)
                filename = f"{name}_{timestamp}{ext}"
        
        # Use output folder if set
        if hasattr(self, 'output_folder') and self.output_folder:
            filename = os.path.join(self.output_folder, os.path.basename(filename))
        
        data_dict = asdict(player_data)
        
        with open(filename, 'w') as f:
            json.dump(data_dict, f, indent=2, default=str)
        
        logger.info(f"Data exported to {filename}")
