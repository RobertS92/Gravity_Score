        cached = self.cache.get(cache_key)
        if cached:
            logger.info(f"⚡ ESPN Cache hit for CFB player {player_name}")
            return cached
        
        try:
            # Step 1: Find player ID
            player_id = self._search_espn_cfb_player(player_name, team)
            if not player_id:
                logger.warning(f"ESPN: CFB player not found: {player_name}")
                return {}
            
            result = {
                "espn_id": player_id,
                "source": "espn_api",
                "identity": {},
                "stats": {
                    "current_season": {},
                    "career": {},
                    "by_year": {}
                },
                "awards": [],
                "injuries": [],
                "draft_projection": {}
            }
            
            # Step 2: Get CORE API data (has detailed player info)
            core_url = f"https://sports.core.api.espn.com/v2/sports/football/leagues/college-football/athletes/{player_id}"
            core_resp = self.session.get(core_url, headers=self.espn_headers, timeout=10)
            
            if core_resp.status_code == 200:
                core_data = core_resp.json()
                
                # Parse detailed info from core API
                birth_place = core_data.get("birthPlace", {})
                position = core_data.get("position", {})
                
                result["identity"] = {
                    "name": core_data.get("fullName", core_data.get("displayName", "")),
                    "first_name": core_data.get("firstName", ""),
                    "last_name": core_data.get("lastName", ""),
                    "jersey_number": core_data.get("jersey"),
                    "position": position.get("abbreviation", ""),
                    "position_name": position.get("displayName", position.get("name", "")),
                    "height": core_data.get("displayHeight", ""),
                    "weight": core_data.get("displayWeight", ""),
                    "age": core_data.get("age"),
                    "birth_date": core_data.get("dateOfBirth"),
                    "birth_city": birth_place.get("city", ""),
                    "birth_state": birth_place.get("state", ""),
                    "birth_country": birth_place.get("country", "USA"),
                    "hometown": f"{birth_place.get('city', '')}, {birth_place.get('state', '')}".strip(", "),
                    "class_year": core_data.get("experience", {}).get("displayValue", "") if isinstance(core_data.get("experience"), dict) else "",
                    "eligibility": core_data.get("experience", {}).get("years") if isinstance(core_data.get("experience"), dict) else None,
                    "active": core_data.get("active", True),
                    "status": "Active" if core_data.get("active", True) else "Inactive"
                }
                
                logger.info(f"🏈 Core API: {result['identity']['name']} - {result['identity']['position']}, From: {result['identity']['hometown']}")
            
            # Step 3: Get team info from site API
            player_url = f"https://site.api.espn.com/apis/common/v3/sports/football/college-football/athletes/{player_id}"
            resp = self.session.get(player_url, headers=self.espn_headers, timeout=10)
            
            if resp.status_code == 200:
                data = resp.json()
                player = data.get("athlete", data)
                
                # Add team/college info
                team_info = player.get("team", {})
                result["identity"]["team"] = team_info.get("displayName", "")
                result["identity"]["team_abbrev"] = team_info.get("abbreviation", "")
                result["identity"]["college"] = team_info.get("displayName", "")
                result["identity"]["headshot_url"] = player.get("headshot", {}).get("href", "")
                
                # Get conference from team
                if team_info.get("id"):
                    conf_info = self._get_cfb_team_conference(team_info.get("id"))
                    result["identity"]["conference"] = conf_info
                
                # Parse injuries
                for injury in player.get("injuries", []):
                    result["injuries"].append({
                        "type": injury.get("type", {}).get("description", ""),
                        "status": injury.get("status", ""),
                        "date": injury.get("date", ""),
                        "details": injury.get("longComment", "")
                    })
            
            # Step 4: Get AWARDS from overview API
            overview_url = f"https://site.api.espn.com/apis/common/v3/sports/football/college-football/athletes/{player_id}/overview"
            overview_resp = self.session.get(overview_url, headers=self.espn_headers, timeout=10)
            
            if overview_resp.status_code == 200:
                overview_data = overview_resp.json()
                awards_sections = overview_data.get("awards", [])
                
                for section in awards_sections:
                    award_name = section.get("name", "")
                    display_count = section.get("displayCount", "1x")
                    seasons = section.get("seasons", [])
                    
                    for year in seasons:
                        result["awards"].append({
                            "name": award_name,
                            "year": int(year) if year else None,
                            "type": award_name
                        })
                    
                    if not seasons and award_name:
                        result["awards"].append({
                            "name": award_name,
                            "type": award_name
                        })
                
                logger.info(f"🏆 Awards API: Found {len(result['awards'])} awards for {player_name}")
            
            # Step 5: Get current season stats from splits endpoint
            # (statistics endpoint doesn't work for CFB)
            current_season = get_season_identifier('cfb')  # e.g., "2025" for 2025 season
            splits_url = f"https://site.api.espn.com/apis/common/v3/sports/football/college-football/athletes/{player_id}/splits?season={current_season}"
            splits_resp = self.session.get(splits_url, headers=self.espn_headers, timeout=15)
            
            if splits_resp.status_code == 200:
                splits_data = splits_resp.json()
                current_stats = self._parse_espn_cfb_season_stats(splits_data)
                if current_stats:
                    result["stats"]["current_season"] = current_stats
                    result["stats"]["by_year"][current_season] = current_stats
                    logger.info(f"📊 CFB Stats: {len(current_stats)} stats for {current_season} season")
            
            # Get gamelog for current season (ALL games)
            current_season_gamelog = self.get_espn_cfb_gamelog(player_id, season=current_season)
            
            if current_season_gamelog:
                result["current_season_gamelog"] = current_season_gamelog
                result["games_played_current_season"] = len(current_season_gamelog)
                
                # Get historical gamelogs
                result["gamelog_by_year"] = {}
                for year in range(int(current_season) - 1, int(current_season) - 4, -1):
                    historical_gamelog = self.get_espn_cfb_gamelog(player_id, season=str(year))
                    if historical_gamelog:
                        result["gamelog_by_year"][str(year)] = historical_gamelog
            
            # Step 6: Get ALL previous seasons stats (complete college career)
            # College players typically have 4-5 years max
            seasons_found = 1 if result["stats"]["by_year"].get(current_season) else 0
            
            # Go back 5-6 years for college careers (dynamic)
            current_season_int = int(current_season)
            for season in range(current_season_int - 1, current_season_int - 6, -1):
                try:
                    prev_splits_url = f"https://site.api.espn.com/apis/common/v3/sports/football/college-football/athletes/{player_id}/splits?season={season}"
                    prev_splits_resp = self.session.get(prev_splits_url, headers=self.espn_headers, timeout=10)
                    
                    if prev_splits_resp.status_code == 200:
                        prev_splits_data = prev_splits_resp.json()
                        season_stats = self._parse_espn_cfb_season_stats(prev_splits_data)
                        
                        if season_stats:
                            result["stats"]["by_year"][str(season)] = season_stats
                            seasons_found += 1
                except Exception as e:
                    logger.debug(f"Failed to get CFB {season} stats for {player_name}: {e}")
            
            logger.info(f"📊 CFB Stats: Found {seasons_found} seasons of data for {player_name}")
            
            # Step 7: Calculate career totals
            result["stats"]["career"] = self._calculate_cfb_career_from_years(result["stats"]["by_year"])
            
            # Count CFB-specific awards
            award_names = [a.get("name", "").lower() for a in result["awards"]]
            result["heisman_winner"] = any("heisman" in a and "winner" in a for a in award_names)
            result["heisman_finalist"] = any("heisman" in a for a in award_names)
            result["all_american"] = sum(1 for a in award_names if "all-america" in a or "all america" in a)
            result["all_american_first_team"] = sum(1 for a in award_names if "all-america" in a and "first" in a)
            result["conference_honors"] = sum(1 for a in award_names if any(conf in a for conf in ["sec", "big ten", "big 12", "acc", "pac-12", "big east"]))
            
            logger.info(f"📊 Awards: All-American={result['all_american']}, Heisman={result['heisman_finalist']}")
            
            # Cache and return
            if result["identity"].get("name"):
                self.cache.set(cache_key, result)
                logger.info(f"✅ ESPN API: Complete CFB data for {player_name} - {result['identity'].get('team', '?')}")
            
            return result
            
        except Exception as e:
