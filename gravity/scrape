                if isinstance(llm_data, dict):
                    logger.warning(f"Dict keys: {list(llm_data.keys())}")
                    logger.warning(f"Dict values preview: {str({k: str(v)[:100] for k, v in list(llm_data.items())[:3]})}")
                logger.warning(f"Full data preview: {str(llm_data)[:500]}")
        else:
            if isinstance(llm_data, dict) and len(llm_data) == 0:
                logger.warning(f"LLM parsing returned empty dict for {source_name}")
            elif llm_data is None:
                logger.warning(f"LLM parsing returned None for {source_name}")
            else:
                logger.warning(f"LLM parsing returned empty/falsy value for {source_name}: {type(llm_data)}")
            
            logger.warning(f"This could mean:")
            logger.warning(f"  1) LLM parsing is disabled (USE_LLM_PARSING={Config.USE_LLM_PARSING})")
            logger.warning(f"  2) LLM failed to parse the page")
            logger.warning(f"  3) Page scraping failed (Firecrawl timeout/error)")
            logger.warning(f"  4) LLM returned data in unexpected format")
            
            if not Config.USE_LLM_PARSING:
                logger.error(f"⚠️  LLM parsing is DISABLED! Set USE_LLM_PARSING=true to enable")
    except Exception as e:
        logger.error(f"LLM parsing failed for {source_name}: {type(e).__name__}: {e}")
        import traceback
        logger.debug(f"Full traceback:\n{traceback.format_exc()}")
    
    return []

def collect_players_by_selection(collector: NFLPlayerCollector, selection: str = None) -> List[Dict]:
