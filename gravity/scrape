    def _clean_stat_value(self, value, as_type='float'):
        """
        Convert stat string to numeric type.
        
        Examples:
            "3,587" -> 3587.0
            "64" -> 64.0
            0 -> 0.0
            "Unknown" -> None
            "" -> None
        """
        if value is None or value == "" or value == "Unknown":
            return None
        
        if isinstance(value, (int, float)):
            return float(value) if as_type == 'float' else int(value)
        
        # Remove commas and convert
        try:
            cleaned = str(value).replace(',', '').strip()
            if not cleaned:
                return None
            return float(cleaned) if as_type == 'float' else int(float(cleaned))
        except (ValueError, AttributeError):
            return None
    
    def _calculate_passer_rating(self, comp, att, yards, tds, ints):
        """
        Calculate NFL passer rating using official formula.
        
        Formula:
        a = ((comp / att) - 0.3) * 5
        b = ((yards / att) - 3) * 0.25
        c = (tds / att) * 20
        d = 2.375 - ((ints / att) * 25)
        
        Each component is capped between 0 and 2.375
        Rating = ((a + b + c + d) / 6) * 100
        
        Args:
            comp: Completions
            att: Attempts
            yards: Passing yards
            tds: Touchdowns
            ints: Interceptions
            
        Returns:
            Passer rating (float) or None if invalid inputs
        """
        if not att or att == 0:
            return None
        
        try:
            # Ensure all values are numeric
            comp = float(comp) if comp else 0
            att = float(att)
            yards = float(yards) if yards else 0
            tds = float(tds) if tds else 0
            ints = float(ints) if ints else 0
            
            # Calculate components with capping
            a = max(0, min(2.375, ((comp / att) - 0.3) * 5))
            b = max(0, min(2.375, ((yards / att) - 3) * 0.25))
            c = max(0, min(2.375, (tds / att) * 20))
            d = max(0, min(2.375, 2.375 - ((ints / att) * 25)))
            
            # Final rating
            rating = ((a + b + c + d) / 6) * 100
            return round(rating, 1)
        except (ValueError, TypeError, ZeroDivisionError):
            return None
    
    def _estimate_pff_grade(self, pro_bowls: int, all_pro: int, position: str) -> float:
        """
        Estimate PFF grade from accolades when PFF subscription not available.
        
        PFF grades range from 0-100:
        - 90+: Elite
        - 80-89: Above average
        - 70-79: Average
        - 60-69: Below average
        - <60: Poor
        
        Args:
            pro_bowls: Number of Pro Bowl selections
            all_pro: Number of All-Pro selections
            position: Player position
            
        Returns:
            Estimated PFF grade (float)
        """
        base = 60.0  # Average NFL player baseline
        
        try:
            # Ensure numeric inputs
            pro_bowls = int(pro_bowls) if pro_bowls else 0
            all_pro = int(all_pro) if all_pro else 0
            
            # Add for Pro Bowls (diminishing returns)
            if pro_bowls > 0:
                base += min(pro_bowls * 3, 15)  # Cap at +15
            
            # Add for All-Pro (more significant)
            if all_pro > 0:
                base += min(all_pro * 5, 15)  # Cap at +15
            
            # Position adjustments (premium positions typically graded higher)
            premium_positions = ['QB', 'WR', 'DE', 'CB', 'EDGE', 'LT', 'RT']
            if position in premium_positions:
                base += 2
            
            # Cap at 95 (true elite reserved for actual PFF data)
            return min(base, 95.0)
        except (ValueError, TypeError):
            return 60.0  # Return average if calculation fails
    
    def _clean_stats_dict(self, stats_dict):
        """Recursively clean all stat values in a dictionary"""
        if not isinstance(stats_dict, dict):
            return stats_dict
        
        cleaned = {}
        for key, value in stats_dict.items():
            if isinstance(value, dict):
                cleaned[key] = self._clean_stats_dict(value)
            elif key in ['name', 'team', 'position', 'status', 'year']:  # Keep strings
                cleaned[key] = value
            else:  # Convert to numeric
                numeric_val = self._clean_stat_value(value)
                cleaned[key] = numeric_val if numeric_val is not None else 0
        return cleaned
    
    def _parse_espn_season_stats(self, stats_data: Dict) -> Dict:
        """Parse ESPN splits response to get season stats"""
        result = {}
        
        split_categories = stats_data.get("splitCategories", [])
        
        for cat in split_categories:
            if cat.get("displayName") == "split":
                for split in cat.get("splits", []):
                    if split.get("displayName") == "All Splits":
                        # This is the total season stats
                        stats = split.get("stats", [])
                        names = stats_data.get("names", [])
                        
                        for i, stat_value in enumerate(stats):
                            if i < len(names):
