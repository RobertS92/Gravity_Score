    def _calculate_sentiment_llm_batch(self, texts: List[str]) -> List[float]:
        """Calculate sentiment for multiple texts using Ollama (batch processing)"""
        if not texts or not self.use_llm or not self.ollama_available:
            return [self._calculate_sentiment_keyword(t) for t in texts]
        
        try:
            # Combine headlines with separators
            combined_text = "\n---\n".join([f"{i+1}. {t[:200]}" for i, t in enumerate(texts[:20])])
            
            response = requests.post(
                f"{Config.OLLAMA_BASE_URL}/api/generate",
                json={
                    "model": Config.OLLAMA_MODEL,
                    "prompt": f"""Analyze sentiment for these NFL news headlines. Return ONLY comma-separated numbers between -1.0 and 1.0, one per headline:
