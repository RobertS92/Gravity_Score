        This fetches WNBA + Women's College Basketball stats for the same player.
        """
        cache_key = f"espn_complete_wnba_{player_name}"
        cached = self.cache.get(cache_key)
        if cached:
            logger.info(f"📦 Cache hit: WNBA data for {player_name}")
