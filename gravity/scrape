                if keyword in text_lower:
                    # Only count if player name appears near the keyword (within 150 chars)
                    pattern = f'({player_name_lower}[^.]{{0,150}}{keyword}[^.]*|{keyword}[^.]{{0,150}}{player_name_lower}[^.]*)'
                    matches = re.findall(pattern, text_lower, re.IGNORECASE)
                    
                    # Filter out false positives - must have actual controversy context
                    controversy_context = ['arrested', 'charged', 'suspended', 'fine', 'violation', 
                                         'investigation', 'lawsuit', 'disciplinary', 'banned']
                    
                    for match in matches[:1]:  # Limit to 1 per keyword
