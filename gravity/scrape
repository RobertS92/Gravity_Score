    def _find_previous_player_data(self, player_name: str) -> Optional[Dict]:
        """Find and load previous player data from scrapes folder"""
        try:
            if not os.path.exists(self.scrapes_base_dir):
                return None
            
            # Search all subdirectories (date folders)
            player_files = []
            for root, dirs, files in os.walk(self.scrapes_base_dir):
                for file in files:
                    # Look for JSON files matching player name pattern
                    if file.endswith('.json') and player_name.replace(' ', '_').lower() in file.lower():
                        filepath = os.path.join(root, file)
                        try:
                            # Get file modification time
                            mtime = os.path.getmtime(filepath)
                            player_files.append((filepath, mtime))
                        except:
                            continue
            
            if not player_files:
                return None
            
            # Get most recent file
            latest_file = max(player_files, key=lambda x: x[1])
            filepath = latest_file[0]
            
            logger.info(f"📂 Found previous data: {filepath}")
            
            # Load JSON data
            with open(filepath, 'r', encoding='utf-8') as f:
                data = json.load(f)
            
            # Check data quality
            quality_score = data.get('data_quality_score', 0)
            collection_timestamp = data.get('collection_timestamp', '')
            
            # Parse timestamp
            try:
                if collection_timestamp and date_parser:
                    collection_date = date_parser.parse(collection_timestamp)
                    if collection_date.tzinfo:
                        collection_date = collection_date.replace(tzinfo=None)
                    days_old = (datetime.now() - collection_date).days
                elif collection_timestamp:
                    # Fallback parsing without dateutil
                    try:
                        collection_date = datetime.fromisoformat(collection_timestamp.replace('Z', '+00:00'))
                        if collection_date.tzinfo:
                            collection_date = collection_date.replace(tzinfo=None)
                        days_old = (datetime.now() - collection_date).days
                    except:
                        days_old = 999
                else:
                    days_old = 999
            except:
                days_old = 999
            
            logger.info(f"   Quality score: {quality_score}, Age: {days_old} days")
            
            # Only use if quality is decent and not too old
            if quality_score >= 50 and days_old < 90:  # At least 50% quality, less than 90 days old
                return data
            else:
                logger.info(f"   Previous data quality too low ({quality_score}) or too old ({days_old} days), will re-collect")
                return None
                
        except Exception as e:
            logger.debug(f"Error loading previous data: {e}")
            return None
    
