    def _parse_espn_gamelog(self, data: Dict) -> List[Dict]:
        """Parse ESPN gamelog response - handles both NFL and NBA formats"""
        games = []
        
        try:
            # Get stat labels for mapping
            labels = data.get("labels", [])
            names = data.get("names", [])
            
            # Get events dict (NBA/NFL use dict, not list)
            events_dict = data.get("events", {})
            if not isinstance(events_dict, dict):
                logger.debug(f"Events is not a dict: {type(events_dict)}")
                return games
            
            # Build event ID to event info mapping
            event_info = {}
            for event_id, event_data in events_dict.items():
                if isinstance(event_data, dict):
                    opponent = event_data.get("opponent", {})
                    opponent_name = opponent.get("displayName", "") if isinstance(opponent, dict) else str(opponent)
                    
                    event_info[event_id] = {
                        "date": event_data.get("gameDate", ""),
                        "opponent": opponent_name,
                        "result": event_data.get("gameResult", ""),
                        "score": event_data.get("score", "")
                    }
            
            # Extract stats from seasonTypes structure (NBA/NFL format)
            season_types = data.get("seasonTypes", [])
            for season_type in season_types:
                if not isinstance(season_type, dict):
                    continue
                    
                categories = season_type.get("categories", [])
                for category in categories:
                    if not isinstance(category, dict):
                        continue
                    
                    # Only process event-level data (not totals/summaries)
                    if category.get("type") != "event":
                        continue
                    
                    category_events = category.get("events", [])
                    for event in category_events:
                        if not isinstance(event, dict):
                            continue
                        
                        event_id = event.get("eventId", "")
                        stat_values = event.get("stats", [])
                        
                        if event_id and event_id in event_info:
                            # Build stats dict from labels and values
                            stats_dict = {}
                            for i, value in enumerate(stat_values):
                                if i < len(labels) and i < len(names):
                                    stats_dict[names[i]] = value
                                    stats_dict[labels[i]] = value
                            
                            game = {
                                **event_info[event_id],
                                "stats": stats_dict,
                                "event_id": event_id
                            }
                            games.append(game)
            
            # Sort by date (most recent first)
            games.sort(key=lambda x: x.get("date", ""), reverse=True)
            
        except Exception as e:
            logger.error(f"Error parsing gamelog: {e}")
            import traceback
            logger.debug(f"Traceback: {traceback.format_exc()}")
        
        return games
    
