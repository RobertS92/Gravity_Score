    def _parse_nba_stats_player(self, data: Dict, player_id: str) -> Dict:
        """Parse NBA Stats API response"""
        result_sets = data.get("resultSets", [])
        
        result = {
            "player_id": player_id,
            "info": {},
            "career_stats": {},
            "current_season_stats": {}
        }
        
        # Parse player info
        for rs in result_sets:
            name = rs.get("name", "")
            headers = rs.get("headers", [])
            rows = rs.get("rowSet", [])
            
            if name == "CommonPlayerInfo" and rows:
                row = rows[0]
                for i, header in enumerate(headers):
                    if i < len(row):
                        result["info"][header] = row[i]
            
            elif name == "PlayerHeadlineStats" and rows:
                row = rows[0]
                for i, header in enumerate(headers):
                    if i < len(row):
                        result["current_season_stats"][header] = row[i]
        
        return result
    
