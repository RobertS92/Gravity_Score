    def analyze_news(self, player_name: str, days: int = 30) -> Dict:
        """Comprehensive news analysis"""
        data = {
            'articles_30d': [],
            'articles_7d': [],
            'headlines': [],
            'sentiment_scores': [],
            'topics': []
        }
        
        # Try multiple news sources
        articles = []
        
        # Method 1: Google News RSS
        rss_url = f"https://news.google.com/rss/search?q={quote(player_name + ' NFL')}&hl=en-US&gl=US&ceid=US:en"
        result = self.scraper.scrape(rss_url)
        
        if result and 'markdown' in result:
            text = result['markdown']
            rss_articles = self._parse_rss(text)
            articles.extend(rss_articles)
            logger.info(f"Found {len(rss_articles)} articles from RSS feed")
        
        # Method 2: Google News web search (if RSS fails or returns few results)
        if len(articles) < 5:
            search_url = f"https://news.google.com/search?q={quote(player_name + ' NFL')}&hl=en-US&gl=US&ceid=US:en"
            search_result = self.scraper.scrape(search_url)
            
            if search_result and 'markdown' in search_result:
                text = search_result['markdown']
                # Extract headlines from Google News page
                web_articles = self._parse_google_news_page(text, player_name)
                articles.extend(web_articles)
                logger.info(f"Found {len(web_articles)} articles from Google News page")
        
        # Method 3: Regular Google search for recent news
        if len(articles) < 10:
            google_search = f"https://www.google.com/search?q={quote(player_name + ' NFL news')}&tbs=qdr:m"  # Last month
            google_result = self.scraper.scrape(google_search)
            
            if google_result and 'markdown' in google_result:
                text = google_result['markdown']
                # Extract news headlines from search results
                search_articles = self._parse_google_search_news(text, player_name)
                articles.extend(search_articles)
                logger.info(f"Found {len(search_articles)} articles from Google search")
        
        # Time filtering
        now = datetime.now()
        week_ago = now - timedelta(days=7)
        month_ago = now - timedelta(days=30)
        
        # Collect all headlines first for batch processing
        headlines_to_analyze = []
        
        for article in articles:
            # Parse date
            pub_date = self._parse_date(article.get('date', ''))
            
            # If no date, try to infer from article content or default to recent
            if not pub_date:
                # Try to extract date from title or description
                title = article.get('title', '').lower()
                desc = article.get('description', '').lower()
                
                # Look for relative time indicators
                if any(word in title or word in desc for word in ['today', 'yesterday', 'hours ago', 'just']):
                    pub_date = now - timedelta(days=1)
                elif any(word in title or word in desc for word in ['this week', 'days ago']):
                    pub_date = now - timedelta(days=3)
                elif any(word in title or word in desc for word in ['last week', 'week ago']):
                    pub_date = now - timedelta(days=7)
                else:
                    # Default to recent (within last week) to ensure 7d count
                    pub_date = now - timedelta(days=3)  # Default to 3 days ago
            
            if pub_date >= month_ago:
                data['articles_30d'].append(article)
            if pub_date >= week_ago:
                data['articles_7d'].append(article)
            
            # Collect headline
            if 'title' in article:
                headline = article['title']
                data['headlines'].append(headline)
                headlines_to_analyze.append(headline)
                
                # Extract topics
                topics = self._extract_topics(headline)
                data['topics'].extend(topics)
        
        # Batch sentiment analysis (more cost-effective for LLM)
        if headlines_to_analyze:
            if self.use_llm and len(headlines_to_analyze) > 1:
                # Use batch processing for multiple headlines
                logger.info(f"Analyzing sentiment for {len(headlines_to_analyze)} headlines using LLM batch processing...")
                data['sentiment_scores'] = self._calculate_sentiment_llm_batch(headlines_to_analyze)
            else:
                # Individual analysis (keyword-based or single LLM call)
                data['sentiment_scores'] = []
                for headline in headlines_to_analyze:
                    if self.use_llm:
                        sentiment = self._calculate_sentiment_llm(headline)
                    else:
                        sentiment = self._calculate_sentiment_keyword(headline)
                    data['sentiment_scores'].append(sentiment)
        
        # Calculate aggregates
        results = {
            'news_headline_count_30d': len(data['articles_30d']),
            'news_headline_count_7d': len(data['articles_7d']),
            'brand_sentiment': self._average_sentiment(data['sentiment_scores']),
            'mention_velocity': len(data['articles_7d']) / 7 if data['articles_7d'] else 0,
            'top_topics': self._get_top_items(data['topics'], 5),
            'recent_headlines': data['headlines'][:10]
        }
        
        # Log sentiment analysis details
        avg_sentiment = results['brand_sentiment']
        if avg_sentiment > 0.3:
            sentiment_label = "Very Positive"
        elif avg_sentiment > 0.1:
            sentiment_label = "Positive"
        elif avg_sentiment > -0.1:
            sentiment_label = "Neutral"
        elif avg_sentiment > -0.3:
            sentiment_label = "Negative"
        else:
            sentiment_label = "Very Negative"
        
        logger.info(f"News analysis for {player_name}: {results['news_headline_count_30d']} articles (30d), "
                   f"{results['news_headline_count_7d']} articles (7d), "
                   f"sentiment: {avg_sentiment:.3f} ({sentiment_label}), "
                   f"velocity: {results['mention_velocity']:.2f} mentions/day")
        
        return results
    
    def _parse_rss(self, text: str) -> List[Dict]:
        """Parse RSS feed content"""
        articles = []
        
        # Simple RSS parsing
        items = re.findall(r'<item>(.*?)</item>', text, re.DOTALL)
        
        for item in items:
            article = {}
            
            # Extract title
            title_match = re.search(r'<title>(.*?)</title>', item)
            if title_match:
                article['title'] = title_match.group(1)
            
            # Extract date
            date_match = re.search(r'<pubDate>(.*?)</pubDate>', item)
            if date_match:
                article['date'] = date_match.group(1)
            
            # Extract link
            link_match = re.search(r'<link>(.*?)</link>', item)
            if link_match:
                article['link'] = link_match.group(1)
            
            # Extract source
            source_match = re.search(r'<source[^>]*>(.*?)</source>', item)
            if source_match:
                article['source'] = source_match.group(1)
            
            if article:
                articles.append(article)
        
        return articles
    
    def _parse_google_news_page(self, text: str, player_name: str) -> List[Dict]:
        """Parse Google News HTML page for headlines"""
        articles = []
        
        # Look for article titles in the markdown/text
        # Google News typically has headlines in various formats
        # Pattern 1: Headlines that contain the player name
        headline_patterns = [
            r'([A-Z][^.!?]*' + re.escape(player_name) + r'[^.!?]*[.!?])',  # Sentences with player name
            r'##\s+(.+?)\n',  # Markdown headers
            r'\*\*(.+?)\*\*',  # Bold text (often headlines)
            r'\[(.+?)\]\(http',  # Markdown links
        ]
        
        # Extract potential headlines
        headlines = set()
        for pattern in headline_patterns:
            matches = re.findall(pattern, text, re.IGNORECASE | re.MULTILINE)
            for match in matches:
                headline = match.strip() if isinstance(match, str) else match[0].strip()
                if len(headline) > 20 and len(headline) < 200:  # Reasonable headline length
                    headlines.add(headline)
        
        # Convert to article format
        for headline in list(headlines)[:20]:  # Limit to 20 headlines
            articles.append({
                'title': headline,
                'date': '',  # Will be parsed or defaulted
                'link': '',
                'source': 'Google News'
            })
        
        return articles
    
    def _parse_google_search_news(self, text: str, player_name: str) -> List[Dict]:
        """Parse Google search results for news headlines"""
        articles = []
        
        # Look for news headlines in search results
        # Google search results often have headlines in specific patterns
        patterns = [
            r'([A-Z][^.!?]*' + re.escape(player_name) + r'[^.!?]*[.!?])',  # Sentences with player name
            r'<h3[^>]*>(.+?)</h3>',  # HTML h3 tags (often headlines)
            r'##\s+(.+?)\n',  # Markdown headers
            r'\*\*(.+?)\*\*',  # Bold text
        ]
        
        headlines = set()
        for pattern in patterns:
            matches = re.findall(pattern, text, re.IGNORECASE | re.MULTILINE | re.DOTALL)
            for match in matches:
                headline = match.strip() if isinstance(match, str) else match[0].strip()
                # Filter for relevant headlines
                if (player_name.lower() in headline.lower() and 
                    len(headline) > 15 and len(headline) < 200 and
                    any(word in headline.lower() for word in ['nfl', 'football', 'chiefs', 'game', 'season', 'player'])):
                    headlines.add(headline)
        
        # Also look for time indicators (e.g., "2 hours ago", "3 days ago")
        time_pattern = r'(\d+)\s+(hour|day|week|month)s?\s+ago'
        
        for headline in list(headlines)[:15]:  # Limit to 15 headlines
            # Try to extract time from surrounding text
            time_match = re.search(time_pattern, text[text.find(headline):text.find(headline)+200], re.IGNORECASE)
            date_str = ''
            if time_match:
                # Convert relative time to approximate date
                amount = int(time_match.group(1))
                unit = time_match.group(2).lower()
                if unit == 'hour':
                    date_str = (datetime.now() - timedelta(hours=amount)).isoformat()
                elif unit == 'day':
                    date_str = (datetime.now() - timedelta(days=amount)).isoformat()
                elif unit == 'week':
                    date_str = (datetime.now() - timedelta(weeks=amount)).isoformat()
                elif unit == 'month':
                    date_str = (datetime.now() - timedelta(days=amount*30)).isoformat()
            
            articles.append({
                'title': headline,
                'date': date_str,
                'link': '',
                'source': 'Google Search'
            })
        
        return articles
    
    def _parse_date(self, date_str: str) -> Optional[datetime]:
        """Parse date from various formats"""
        if not date_str:
            return None
            
        date_str = date_str.strip()
        
        # Try common RSS/feed formats
        formats = [
            '%a, %d %b %Y %H:%M:%S %Z',
            '%a, %d %b %Y %H:%M:%S',
            '%Y-%m-%dT%H:%M:%S%z',
            '%Y-%m-%dT%H:%M:%S',
            '%Y-%m-%d',
            '%B %d, %Y',
            '%b %d, %Y',
            '%m/%d/%Y',
            '%d %b %Y',
            '%d %B %Y'
        ]
        
        # Clean up common suffixes
        date_str = date_str.replace(' GMT', '').replace(' UTC', '').replace(' EST', '').replace(' PST', '')
        
        for fmt in formats:
            try:
                return datetime.strptime(date_str, fmt)
            except:
                continue
        
        # Try to extract date from relative time (e.g., "2 hours ago", "3 days ago")
        relative_match = re.search(r'(\d+)\s*(hour|day|week|month)s?\s*ago', date_str.lower())
        if relative_match:
            amount = int(relative_match.group(1))
            unit = relative_match.group(2)
            now = datetime.now()
            if unit == 'hour':
                return now - timedelta(hours=amount)
            elif unit == 'day':
                return now - timedelta(days=amount)
            elif unit == 'week':
                return now - timedelta(weeks=amount)
            elif unit == 'month':
                return now - timedelta(days=amount * 30)
        
        return None
    
    def _calculate_sentiment_llm(self, text: str) -> float:
        """Calculate sentiment using LLM - tries OpenAI first, then Ollama as fallback"""
        if not text or not self.use_llm:
