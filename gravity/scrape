def _scrape_with_timeout(scraper, url: str, timeout: int = 30000) -> Optional[Dict]:
    """Scrape with custom timeout handling - uses Firecrawl v2 API directly with custom timeout"""
    try:
        # Use Firecrawl v2 API directly with custom timeout
        endpoint = "https://api.firecrawl.dev/v2/scrape"
        payload = {
            "url": url,
            "formats": ["markdown", "html", "links"],  # Get clean markdown from Firecrawl
            "onlyMainContent": True,
            "waitFor": 2000,
            "timeout": timeout
        }
        
        logger.debug(f"Scraping {url[:60]} with timeout {timeout}ms using Firecrawl v2")
        response = scraper.session.post(endpoint, json=payload, timeout=(timeout // 1000) + 10)
        
        if response.status_code == 200:
            result = response.json()
            # Handle v2 API response format
            if result.get('success') and 'data' in result:
                data = result['data']
                markdown_len = len(data.get('markdown', '')) if data.get('markdown') else 0
                logger.debug(f"Scrape successful: markdown={markdown_len} chars, html={bool(data.get('html'))}")
                return data
            elif result.get('success') and 'markdown' in result:
                # Sometimes data is at top level
                logger.debug(f"Scrape successful (top-level data)")
                return result
            elif 'markdown' in result or 'html' in result:
                # Direct data response
                logger.debug(f"Scrape successful (direct data)")
                return result
            else:
                logger.warning(f"Firecrawl returned success but unexpected structure: {list(result.keys())}")
                return result
        elif response.status_code == 408:
            raise Exception(f"Scrape timeout (408) for {url[:50]}")
        else:
            logger.warning(f"Firecrawl returned {response.status_code} for {url[:50]}")
            try:
                error_data = response.json()
                logger.debug(f"Error details: {error_data}")
            except:
                logger.debug(f"Error response: {response.text[:200]}")
            return None
    except requests.exceptions.Timeout:
        logger.warning(f"Request timeout for {url[:50]}")
        raise Exception(f"Request timeout for {url[:50]}")
    except Exception as e:
        logger.warning(f"Scrape error for {url[:50]}: {e}")
        raise e

