            'moderate': ['sprain', 'strain', 'hamstring', 'concussion', 'bruised'],
            'minor': ['questionable', 'probable', 'day-to-day', 'sore']
        }
        
        # Position injury rates (percentage)
        self.position_injury_rates = {
            'RB': 65, 'WR': 55, 'TE': 48, 'OL': 45,
            'QB': 40, 'LB': 52, 'DB': 50, 'DL': 48,
            'K': 15, 'P': 12
        }
        
        # Controversy keywords
        self.controversy_keywords = [
            'arrested', 'charged', 'suspended', 'investigation', 'lawsuit',
