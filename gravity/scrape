    def get_espn_nba_full_stats(self, player_name: str, team: str = None) -> Dict:
        """
        Get comprehensive NBA player stats from ESPN API.
        Returns current season, career stats, awards, and achievements.
        """
        cache_key = f"espn_full_stats_nba_{player_name}"
        cached = self.cache.get(cache_key)
        if cached:
            logger.info(f"⚡ ESPN NBA Stats Cache hit for {player_name}")
            return cached
        
        try:
            player_id = self._search_espn_nba_player(player_name, team)
            if not player_id:
                logger.debug(f"ESPN NBA Stats: Player not found: {player_name}")
                return {}
            
            result = {
                "espn_id": player_id,
                "current_season_stats": {},
                "career_stats": {},
                "season_by_season": [],
                "awards": [],
                "achievements": [],
                "all_star_selections": 0,
                "all_nba_selections": 0,
                "championships": 0,
                "mvp_awards": 0
            }
            
            # Get player stats
            stats_url = f"https://site.api.espn.com/apis/common/v3/sports/basketball/nba/athletes/{player_id}/statistics"
            response = self.session.get(stats_url, headers=self.espn_headers, timeout=15)
            
            if response.status_code == 200:
                stats_data = response.json()
                result = self._parse_espn_nba_full_stats(stats_data, result)
            
            # Get player overview for awards
            player_url = f"https://site.api.espn.com/apis/common/v3/sports/basketball/nba/athletes/{player_id}"
            response2 = self.session.get(player_url, headers=self.espn_headers, timeout=10)
            
            if response2.status_code == 200:
                player_data = response2.json()
                result = self._parse_espn_nba_awards(player_data, result)
            
            # Get gamelog for current season (ALL games)
            current_year = datetime.now().year
            current_season_gamelog = self.get_espn_nba_gamelog(player_id, season=current_year)
            
            # If no data for current season, try previous season (fallback)
            gamelog_season = current_year
            if not current_season_gamelog:
                logger.debug(f"No gamelog for {current_year} season, trying {current_year - 1}...")
                current_season_gamelog = self.get_espn_nba_gamelog(player_id, season=current_year - 1)
                gamelog_season = current_year - 1
            
            if current_season_gamelog:
                # Store ALL current season games
                result["current_season_gamelog"] = current_season_gamelog
                result["recent_games"] = current_season_gamelog[-5:]  # Last 5 for quick reference
                result["games_played_current_season"] = len(current_season_gamelog)
                logger.info(f"📊 Gamelog: {len(current_season_gamelog)} games from {gamelog_season} season")
                
                # Also get historical gamelogs for previous seasons (last 3 years before gamelog_season)
                result["gamelog_by_year"] = {}
                for year in range(gamelog_season - 1, gamelog_season - 4, -1):
                    if year > 2000:  # Sanity check
                        historical_gamelog = self.get_espn_nba_gamelog(player_id, season=year)
                        if historical_gamelog:
                            result["gamelog_by_year"][str(year)] = historical_gamelog
                
                if result["gamelog_by_year"]:
                    total_historical = sum(len(games) for games in result["gamelog_by_year"].values())
                    logger.info(f"📊 Historical: {total_historical} games across {len(result['gamelog_by_year'])} seasons")
            else:
                logger.debug(f"No gamelog data found for {player_name} (tried {current_year} and {current_year - 1})")
            
            if result.get("current_season_stats") or result.get("career_stats"):
                self.cache.set(cache_key, result)
                logger.info(f"✅ ESPN NBA Stats API: Got full stats for {player_name}")
            
            return result
            
        except Exception as e:
            logger.debug(f"ESPN NBA full stats failed for {player_name}: {e}")
            return {}
    
    def _parse_espn_nba_full_stats(self, stats_data: Dict, result: Dict) -> Dict:
        """Parse ESPN NBA statistics response"""
        splits = stats_data.get("splits", {})
        categories = splits.get("categories", [])
        
        for category in categories:
            cat_name = category.get("name", "").lower()
            stats_list = category.get("stats", [])
            
            for stat in stats_list:
                stat_name = stat.get("name", "")
                display_value = stat.get("displayValue", "")
                
                if cat_name not in result["current_season_stats"]:
                    result["current_season_stats"][cat_name] = {}
                result["current_season_stats"][cat_name][stat_name] = display_value
        
        # Season by season
        seasons = stats_data.get("seasons", [])
        for season in seasons:
            season_stats = {
                "year": season.get("year"),
                "team": season.get("team", {}).get("displayName", ""),
                "stats": {}
            }
            
            for cat in season.get("categories", []):
                cat_name = cat.get("name", "").lower()
                season_stats["stats"][cat_name] = {}
                for stat in cat.get("stats", []):
                    season_stats["stats"][cat_name][stat.get("name", "")] = stat.get("displayValue", "")
            
            if season_stats["stats"]:
                result["season_by_season"].append(season_stats)
        
        return result
    
    def _parse_espn_nba_awards(self, player_data: Dict, result: Dict) -> Dict:
        """Parse ESPN NBA player data for awards"""
        athlete = player_data.get("athlete", player_data)
        
        awards = athlete.get("awards", [])
        for award in awards:
            award_info = {
                "name": award.get("name", ""),
                "year": award.get("year"),
                "type": award.get("type", "")
            }
            result["awards"].append(award_info)
            
            name_lower = award_info["name"].lower()
            if "all-star" in name_lower:
                result["all_star_selections"] += 1
            if "all-nba" in name_lower:
                result["all_nba_selections"] += 1
            if "champion" in name_lower:
                result["championships"] += 1
            if "mvp" in name_lower and "finals" not in name_lower:
                result["mvp_awards"] += 1
        
        honors = athlete.get("honors", [])
        for honor in honors:
            result["achievements"].append({
                "name": honor.get("name", ""),
                "description": honor.get("description", ""),
                "year": honor.get("year")
            })
        
        return result
    
