    def _get_wikipedia_achievements(self, player_name: str) -> Dict:
        """Get achievements from Wikipedia"""
        data = {
            'awards': [],
            'pro_bowls': 0,
            'all_pro_selections': 0,
            'super_bowl_wins': 0
        }
        
        url = f"https://en.wikipedia.org/wiki/{player_name.replace(' ', '_')}"
        result = self.scraper.scrape(url)
        
        if result and 'markdown' in result:
            text = result['markdown']
            text_lower = text.lower()
            
            # Count achievements
            data['pro_bowls'] = text_lower.count('pro bowl')
            data['all_pro_selections'] = text_lower.count('all-pro')
            data['super_bowl_wins'] = text_lower.count('super bowl champion')
            
            # Extract NFL awards with years
            nfl_awards = [
                ('MVP', r'(\d{4})\s+.*?NFL.*?MVP', 'NFL MVP'),
                ('Offensive Player of the Year', r'(\d{4})\s+.*?Offensive Player of the Year', 'OPOY'),
                ('Defensive Player of the Year', r'(\d{4})\s+.*?Defensive Player of the Year', 'DPOY'),
                ('Rookie of the Year', r'(\d{4})\s+.*?Rookie of the Year', 'ROY'),
                ('Comeback Player of the Year', r'(\d{4})\s+.*?Comeback Player', 'CPOY'),
                ('Walter Payton Man of the Year', r'(\d{4})\s+.*?Walter Payton.*?Man of the Year', 'WPMOY'),
                ('Offensive Rookie of the Year', r'(\d{4})\s+.*?Offensive Rookie of the Year', 'OROY'),
                ('Defensive Rookie of the Year', r'(\d{4})\s+.*?Defensive Rookie of the Year', 'DROY'),
                ('Super Bowl MVP', r'(\d{4})\s+.*?Super Bowl.*?MVP', 'SB MVP'),
                ('Pro Bowl MVP', r'(\d{4})\s+.*?Pro Bowl.*?MVP', 'PB MVP'),
            ]
            
            for award_name, pattern, short_name in nfl_awards:
                award_years = set()
                matches = re.finditer(pattern, text, re.IGNORECASE)
                for match in matches:
                    year = int(match.group(1))
                    if 2000 <= year <= datetime.now().year:
                        award_years.add(year)
                
                # Add awards with years
                for year in sorted(award_years, reverse=True):
                    data['awards'].append(f"{year} NFL {award_name}")
            
            # Also check for Hall of Fame (no year needed)
            if 'hall of fame' in text_lower or 'pro football hall of fame' in text_lower:
                data['awards'].append('Pro Football Hall of Fame')
            
            # Extract college
            college_match = re.search(r'College[:\s]+([A-Za-z\s]+)', text)
            if college_match:
                data['college'] = college_match.group(1).strip()
        
        return data
    
