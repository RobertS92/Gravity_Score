def _get_team_abbrev(team_name: str) -> Optional[str]:
    """Convert team name to abbreviation for ESPN API"""
    # Reverse lookup from full name to abbreviation
    teams = get_nfl_teams()
    
    # Direct match
    for abbrev, name in teams.items():
        if name.lower() == team_name.lower():
            return abbrev
    
    # Partial match
    team_lower = team_name.lower()
    for abbrev, name in teams.items():
        if team_lower in name.lower() or name.lower() in team_lower:
            return abbrev
    
    return None

