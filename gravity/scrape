    def _parse_year_range(self, years_str: str) -> list:
        """
        Parse year ranges and lists like "2018–2023" or "2018, 2020, 2022–2024"
        Returns list of individual years
        """
        years = []
        
        # Split by commas
        parts = re.split(r'[,،]', years_str)
        
        for part in parts:
            part = part.strip()
            
            # Check for range (2018–2023, 2018-2023, 2018−2023)
            range_match = re.search(r'(\d{4})\s*[–−-]\s*(\d{4})', part)
            if range_match:
                start_year = int(range_match.group(1))
                end_year = int(range_match.group(2))
                years.extend(range(start_year, end_year + 1))
            else:
                # Single year
                year_match = re.search(r'(\d{4})', part)
                if year_match:
                    years.append(int(year_match.group(1)))
        
        # Filter to valid years (2000-present)
        current_year = datetime.now().year
        return [y for y in years if 2000 <= y <= current_year]
    
    def _parse_super_bowl_roman_numerals(self, roman_str: str) -> list:
        """
        Convert Super Bowl Roman numerals to years
        LIV = 54 = 2020, LVII = 57 = 2023, LVIII = 58 = 2024
        """
        roman_to_int = {
            'I': 1, 'V': 5, 'X': 10, 'L': 50, 'C': 100, 'D': 500, 'M': 1000
        }
        
        def roman_to_decimal(roman):
            """Convert Roman numeral to decimal"""
            result = 0
            prev_value = 0
            for char in reversed(roman.upper()):
                value = roman_to_int.get(char, 0)
                if value < prev_value:
                    result -= value
                else:
                    result += value
                prev_value = value
            return result
        
        years = []
        
        # Split by commas
        parts = re.split(r'[,،]', roman_str)
        
        for part in parts:
            part = part.strip()
            # Extract Roman numeral (like "LVIII" or "LIV")
            roman_match = re.search(r'([IVXLCDM]+)', part.upper())
            if roman_match:
                roman = roman_match.group(1)
                sb_number = roman_to_decimal(roman)
                # Super Bowl I was in 1967 season (played in Jan 1967)
                # Super Bowl number = year - 1966
                year = 1966 + sb_number
                if 2000 <= year <= datetime.now().year:
                    years.append(year)
        
        return years
    
    def _extract_number(self, text: str, pattern: str) -> Optional[int]:
        """Extract number from text using pattern"""
        match = re.search(pattern, text)
        if match:
            try:
                return int(match.group(1).replace(',', ''))
            except:
                pass
        return None

