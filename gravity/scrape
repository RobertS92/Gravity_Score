def _construct_player_url(player_name: str) -> str:
    """
    Construct NFL.com player URL from player name
    
    Args:
        player_name: Full player name (e.g., "C.J. Stroud", "Derek Stingley Jr.")
    
    Returns:
        NFL.com player URL (e.g., "https://www.nfl.com/players/cj-stroud/")
    """
    # Convert name to slug format:
    # - Lowercase
    # - Replace spaces with hyphens
    # - Remove periods (C.J. -> cj)
    # - Remove apostrophes
    # - Handle suffixes (Jr., Sr., III, II)
    slug = player_name.lower()
    slug = slug.replace('.', '')  # Remove periods (C.J. -> cj)
    slug = slug.replace("'", '')  # Remove apostrophes
    slug = slug.replace(' ', '-')  # Replace spaces with hyphens
    slug = slug.replace('jr.', 'jr').replace('sr.', 'sr')  # Handle suffixes
    slug = slug.replace('iii', '').replace('ii', '')  # Remove roman numerals
    slug = slug.strip('-')  # Remove leading/trailing hyphens
    
    return f"https://www.nfl.com/players/{slug}/"

def get_team_roster(collector: NFLPlayerCollector, team_name: str) -> List[Dict]:
    """Get roster for a specific team - ESPN API first (instant), then scraping fallback"""
    logger.info(f"Fetching roster for {team_name}...")
    
    players = []
    
    # =========================================================================
    # FAST PATH: Try ESPN API first (instant, no scraping needed)
    # =========================================================================
    if Config.USE_DIRECT_APIS:
        try:
            api = get_direct_api()
            
            # Get team abbreviation from name
            team_abbrev = _get_team_abbrev(team_name)
            if team_abbrev:
                espn_roster = api.get_espn_nfl_roster(team_abbrev)
                
                if espn_roster and len(espn_roster) >= 30:
                    logger.info(f"⚡ ESPN API: Got {len(espn_roster)} players for {team_name} (instant)")
                    
                    # Convert ESPN format to our format
                    for player in espn_roster:
                        players.append({
                            'name': player.get('name', ''),
                            'position': player.get('position', 'UNK'),
                            'jersey_number': player.get('jersey_number'),
                            'team': team_name,
                            'age': player.get('age'),
                            'college': player.get('college', ''),
                            'espn_id': player.get('espn_id')
                        })
                    
                    logger.info(f"✅ ESPN API: Complete roster for {team_name}, skipping scraping")
                    return players
                elif espn_roster:
                    logger.info(f"📊 ESPN API: Partial roster ({len(espn_roster)} players), will supplement...")
                    for player in espn_roster:
                        players.append({
                            'name': player.get('name', ''),
                            'position': player.get('position', 'UNK'),
                            'jersey_number': player.get('jersey_number'),
                            'team': team_name
                        })
        except Exception as e:
            logger.debug(f"ESPN API roster failed for {team_name}: {e}")
    
    # =========================================================================
    # FALLBACK: Scrape with LLM parsing
    # =========================================================================
    # Use LLM parsing as FALLBACK method
    sources = [
        ("NFL.com Sitemap Roster", "NFL_SITEMAP"),
        ("ESPN", "ESPN"),
        ("Pro Football Reference", "Pro Football Reference"),
        ("NFL.com", "NFL.com")
    ]
    
    for source_name, source_key in sources:
        try:
            logger.info(f"Trying {source_name} with LLM parsing for {team_name}...")
            logger.info(f"LLM parsing enabled: {Config.USE_LLM_PARSING}")
            
            # Try LLM parsing with timeout protection
            source_players = None
            if Config.USE_LLM_PARSING:
                try:
                    source_players = _get_roster_with_llm(collector, team_name, source_key)
                except Exception as llm_error:
                    logger.warning(f"LLM parsing failed for {source_name}: {llm_error}")
                    source_players = None
            
            logger.info(f"{source_name} LLM parsing returned {len(source_players) if source_players else 0} players")
            if source_players:
                logger.info(f"Sample players from {source_name}: {[p.get('name', 'N/A') for p in source_players[:3]]}")
            if source_players and len(source_players) > 0:
                # Merge with existing players (avoid duplicates)
                existing_names = {p['name'] for p in players}
                for player in source_players:
                    if player.get('name') and player['name'] not in existing_names:
                        players.append(player)
                        existing_names.add(player['name'])
                
                logger.info(f"✓ {source_name}: Found {len(source_players)} players (total: {len(players)})")
                
                # Accept any players found - even if less than 53
                if len(players) >= 30:
                    logger.info(f"✓ Found {len(players)} players from {source_name} for {team_name} - good enough, proceeding")
                    # Continue to try other sources to get more players, but we have enough
                elif len(players) >= 10:
                    logger.info(f"✓ Found {len(players)} players from {source_name} - continuing to get more...")
            else:
                logger.warning(f"{source_name} LLM parsing returned no players for {team_name}")
        except Exception as e:
            error_str = str(e).lower()
            if "timeout" in error_str or "408" in error_str:
                logger.warning(f"{source_name} timed out for {team_name}, trying next source...")
            else:
                logger.error(f"{source_name} LLM parsing failed for {team_name}: {type(e).__name__}: {e}")
                import traceback
                logger.debug(f"Full traceback:\n{traceback.format_exc()}")
            
            continue
    
    # If we still have very few players OR LLM failed completely, try regex extraction as fallback
    # Also try regex immediately if LLM is disabled or times out frequently
    if len(players) < 10:
        if len(players) == 0:
            logger.warning(f"⚠️  LLM extraction returned 0 players for {team_name}, trying regex extraction as fallback...")
        else:
            logger.warning(f"Only found {len(players)} players via LLM, trying regex extraction as fallback...")
        
        # Try regex extraction immediately (don't wait for all LLM attempts to fail)
        # This is critical when LLM times out (which happens frequently with large roster pages)
        try:
            logger.info(f"🔄 Starting regex fallback extraction for {team_name}...")
            # Try all sources with regex extraction
            sources_regex = [
                ("NFL.com Sitemap", lambda: _get_nfl_sitemap_roster_regex(collector, team_name)),
                ("ESPN", lambda: _get_espn_roster_regex(collector, team_name)),
                ("NFL.com", lambda: _get_nfl_roster_regex(collector, team_name)),
                ("Pro Football Reference", lambda: _get_pfr_roster_regex(collector, team_name))
            ]
            
            # Try sources sequentially (parallel might overwhelm Firecrawl)
            for source_name, get_func in sources_regex:
                try:
                    logger.info(f"Trying regex extraction from {source_name}...")
                    regex_players = get_func()
                    if regex_players and len(regex_players) > 0:
                        existing_names = {p['name'] for p in players}
                        added = 0
                        for player in regex_players:
                            if player.get('name') and player['name'] not in existing_names:
                                players.append(player)
                                existing_names.add(player['name'])
                                added += 1
                        if added > 0:
                            logger.info(f"✓ Regex extraction from {source_name} added {added} players (total: {len(players)})")
                        if len(players) >= 30:
                            logger.info(f"✓ Found {len(players)} players - sufficient, stopping regex extraction")
                            break  # We have enough players
                except Exception as e:
                    logger.debug(f"Regex extraction from {source_name} failed: {e}")
                    continue
        except Exception as e:
            logger.debug(f"Regex extraction fallback failed: {e}")
    
    # Final validation: filter out any remaining false positives
    logger.info(f"Final validation: checking {len(players)} players for false positives...")
    if len(players) == 0:
        logger.warning(f"⚠️  No players found before validation for {team_name}")
        logger.warning(f"This could mean:")
        logger.warning(f"  1. LLM parsing is disabled (USE_LLM_PARSING={Config.USE_LLM_PARSING})")
        logger.warning(f"  2. All sources failed to extract players")
        logger.warning(f"  3. Firecrawl API issues")
        logger.warning(f"  4. Page structure changed")
    else:
        logger.info(f"Before validation: {len(players)} players found")
        logger.info(f"Sample names: {[p.get('name', 'N/A') for p in players[:5]]}")
    
    validated_players = []
    valid_positions = ['QB', 'RB', 'WR', 'TE', 'OL', 'C', 'G', 'T', 'DL', 'DE', 'DT', 
                      'LB', 'ILB', 'OLB', 'DB', 'CB', 'S', 'FS', 'SS', 'K', 'P', 'LS', 
                      'NT', 'EDGE', 'HB', 'FB', 'OT', 'OG']
    
    filtered_count = 0
    for player in players:
        name = player.get('name', '').strip()
        position = player.get('position', '').strip().upper()
        
        # Must have a valid name (relaxed: allow shorter names like "C.J.")
        if not name:
            filtered_count += 1
            logger.debug(f"Filtered: empty name")
            continue
        
        # Must have at least first and last name (or first middle last)
        name_parts = name.split()
        if len(name_parts) < 2:
            filtered_count += 1
            logger.debug(f"Filtered: {name} (only {len(name_parts)} name part(s))")
            continue
        
        # Position validation - allow UNK if position not found (will be filled later)
        if position and position not in valid_positions and position != 'UNK':
            filtered_count += 1
            logger.debug(f"Filtered: {name} (invalid position: {position})")
            continue
        
        # If no position, set to UNK (will be filled during data collection)
        if not position or position == '':
            position = 'UNK'
            player['position'] = 'UNK'
        
        # Must not be a college/team name (more specific check)
        college_indicators = ['university', 'college', 'school', 'tech', 'a&m']
        team_indicators = ['team', 'player', 'roster', 'total', 'active', 'inactive']
        # Only filter if the ENTIRE name matches these patterns
        name_lower = name.lower()
        if any(indicator == name_lower or name_lower.endswith(' ' + indicator) for indicator in college_indicators + team_indicators):
            filtered_count += 1
            logger.debug(f"Filtered: {name} (looks like college/team)")
            continue
        
        # Relaxed name format check - allow more variations
        # Only filter if it's clearly not a name (all numbers, special chars only, etc.)
        if name.replace(' ', '').replace('.', '').replace('-', '').replace("'", '').isdigit():
            filtered_count += 1
            logger.debug(f"Filtered: {name} (all numbers)")
            continue
        
        validated_players.append(player)
    
    if filtered_count > 0:
        logger.info(f"Filtered out {filtered_count} invalid players during validation")
    
    players = validated_players
    logger.info(f"After final validation: {len(players)} valid players")
    
    if not players:
        logger.error(f"❌ Could not fetch roster for {team_name} from any source")
        logger.error("This is a critical error - no players found means no data can be collected")
        return []
    elif len(players) > 60:
        logger.warning(f"⚠️  Found {len(players)} players (expected ~53) - may include practice squad or duplicates")
        logger.info(f"Proceeding with {len(players)} players - data collection will continue")
    elif len(players) < 20:
        logger.warning(f"⚠️  Only found {len(players)} players for {team_name} (expected ~53 on active roster)")
        logger.warning("This may be due to: practice squad players, injured reserve, or incomplete roster data")
        logger.info(f"Proceeding with {len(players)} players - data collection will continue")
    else:
        logger.info(f"✓ Successfully found {len(players)} total players for {team_name}")
    
    return players

def _get_nfl_roster(collector: NFLPlayerCollector, team_name: str) -> List[Dict]:
    """Get roster from NFL.com with retry logic"""
    # Use proper team slug mapping
    team_slug = _get_team_slug_for_nfl(team_name)
    roster_urls = [
        f"https://www.nfl.com/teams/{team_slug}/roster",
        f"https://www.nfl.com/teams/{team_slug}/roster/active"
    ]
    logger.info(f"NFL.com team slug: {team_slug}, trying URLs: {roster_urls}")
    
    players = []
    last_exception = None
    
    # Try each URL format
    for roster_url in roster_urls:
        logger.debug(f"Trying NFL.com URL: {roster_url}")
        
        # Try with retries and increased timeout
        for attempt in range(Config.ROSTER_RETRIES + 1):  # +1 to include initial attempt
            try:
                logger.debug(f"NFL.com attempt {attempt + 1}/{Config.ROSTER_RETRIES + 1} for {team_name} at {roster_url}")
                # Use a custom scrape with longer timeout
                result = _scrape_with_timeout(collector.scraper, roster_url, timeout=Config.ROSTER_TIMEOUT)
                
                if result:
                    logger.info(f"NFL.com returned result with keys: {list(result.keys())}")
                    # Try markdown first
                    if 'markdown' in result:
                        text = result['markdown']
                        logger.info(f"NFL.com markdown length: {len(text)} chars")
                        if text and len(text) > 100:  # Ensure we got meaningful content
                            # Log a sample BEFORE extraction to see what we're working with
                            logger.info(f"Content preview (first 1000 chars): {text[:1000]}")
                            players = _extract_players_from_text(text, team_name)
                            if players:
                                logger.info(f"✓ Successfully fetched {len(players)} players from NFL.com for {team_name}")
                                return players
                            else:
                                logger.error(f"❌ NFL.com returned content ({len(text)} chars) but NO players extracted for {team_name}")
                                logger.error("This means the extraction patterns are not matching the content format")
                                logger.error(f"Full content sample (first 2000 chars): {text[:2000]}")
                        else:
                            logger.error(f"❌ NFL.com returned empty or too short markdown ({len(text) if text else 0} chars) for {team_name}")
                    else:
                        logger.warning(f"NFL.com result has no 'markdown' key. Available keys: {list(result.keys())}")
                    
                    # Try HTML as fallback
                    if 'html' in result and not players:
                        html_text = result['html']
                        logger.debug(f"Trying HTML extraction, length: {len(html_text)} chars")
                        if html_text and len(html_text) > 100:
                            players = _extract_players_from_text(html_text, team_name)
                            if players:
                                logger.info(f"✓ Successfully fetched {len(players)} players from NFL.com HTML for {team_name}")
                                return players
                else:
                    logger.warning(f"NFL.com returned no result (None) for {team_name}")
                    # Try fallback: use regular scrape method
                    try:
                        logger.debug("Trying regular Firecrawl scrape as fallback...")
                        fallback_result = collector.scraper.scrape(roster_url, screenshot=False)
                        if fallback_result and 'markdown' in fallback_result:
                            text = fallback_result['markdown']
                            if text and len(text) > 100:
                                players = _extract_players_from_text(text, team_name)
                                if players:
                                    logger.info(f"✓ Successfully fetched {len(players)} players from NFL.com (fallback) for {team_name}")
                                    return players
                    except Exception as fallback_e:
                        logger.debug(f"Fallback scrape also failed: {fallback_e}")
                
                # If we got players from this URL, return them
                if players:
                    return players
                
                # If no players found, wait and retry
                if attempt < Config.ROSTER_RETRIES:
                    wait_time = (attempt + 1) * 5  # Exponential backoff: 5s, 10s
                    logger.debug(f"Retrying NFL.com roster in {wait_time} seconds...")
                    time.sleep(wait_time)
            except Exception as e:
                last_exception = e
                error_str = str(e).lower()
                if "timeout" in error_str or "408" in error_str or "scrape timeout" in error_str:
                    if attempt < Config.ROSTER_RETRIES:
                        wait_time = (attempt + 1) * 5
                        logger.warning(f"NFL.com timeout (attempt {attempt + 1}/{Config.ROSTER_RETRIES + 1}), retrying in {wait_time}s...")
                        time.sleep(wait_time)
                        continue
                    else:
                        logger.warning(f"NFL.com timed out after {Config.ROSTER_RETRIES + 1} attempts for {roster_url}")
                        # Try next URL format
                        break
                else:
                    logger.debug(f"NFL.com roster fetch failed for {roster_url}: {e}")
                    # Try next URL format
                    break
        
        # If we got players from this URL, return them
        if players:
            return players
    
    # If we get here, none of the URL formats worked
    if not players:
        error_msg = f"No players found from NFL.com for {team_name} (tried {len(roster_urls)} URL formats)"
        if last_exception:
            error_msg += f" - Last error: {last_exception}"
        raise Exception(error_msg)
    
    return players

